---
import "@/styles/global.css"
import SyncPanel from "@/components/ui/SyncPanel"
import ThemeToggle from "@/components/ui/ThemeToggle"
import CalibrationBanner from "@/components/ui/CalibrationBanner"
import OnboardingFlow from "@/components/ui/OnboardingFlow"
import { KeyboardShortcutsHelp } from "@/components/ui/KeyboardShortcuts"
import RecentTests from "@/components/ui/RecentTests"
import Icon from "@/components/ui/Icon.astro"
import LanguageSwitcher from "@/components/ui/LanguageSwitcher"
import { translations } from "@/i18n/translations"

interface Props {
  title?: string
  description?: string
  canonicalUrl?: string
  ogImage?: string
  schemaJson?: Record<string, any> | Record<string, any>[]
  robots?: string
}

const {
  title = "CogniArena — Free Reaction Time Test & Cognitive Assessments",
  description = "Take the free reaction time test and measure your reflexes in milliseconds. 23+ cognitive assessments including IQ test, typing test, memory games. 100% anonymous, runs in your browser.",
  canonicalUrl = "https://cogniarena.com",
  ogImage,
  schemaJson,
  robots = "index, follow",
} = Astro.props

// Organization + WebSite schema — injected on every page for knowledge panel / sitelinks
const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "CogniArena",
  url: "https://cogniarena.com",
  logo: "https://cogniarena.com/favicon.svg",
  description:
    "Free online cognitive assessment platform with 23+ brain tests measuring reaction time, memory, reasoning, focus, and motor skills.",
  foundingDate: "2025",
  sameAs: [],
}

const webSiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "CogniArena",
  url: "https://cogniarena.com",
}

// Default structured data for the site (fallback when page provides no schema)
const defaultSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: title,
  description: description,
  url: canonicalUrl,
  publisher: {
    "@type": "Organization",
    name: "CogniArena",
    url: "https://cogniarena.com",
  },
}

// Build final schema array: page schemas + global org/webSite schemas
const pageSchemas = Array.isArray(schemaJson)
  ? schemaJson
  : [schemaJson || defaultSchema]
const finalSchemas = [...pageSchemas, orgSchema, webSiteSchema]

const { pathname } = Astro.url

// Determine active state indicators
const isReactionOpen =
  pathname.includes("/tests/reaction-time") ||
  pathname.includes("/tests/f1-lights") ||
  pathname.includes("/tests/sound-reaction") ||
  pathname.includes("/tests/choice-reaction") ||
  pathname.includes("/tests/go-no-go")
const isMemoryOpen =
  pathname.includes("/tests/sequence-memory") ||
  pathname.includes("/tests/number-memory") ||
  pathname.includes("/tests/visual-pattern") ||
  pathname.includes("/tests/dual-n-back") ||
  pathname.includes("/tests/verbal-memory")
const isReasoningOpen =
  pathname.includes("/tests/pattern-reasoning") ||
  pathname.includes("/tests/spatial-orientation")
const isFocusOpen =
  pathname.includes("/tests/stroop") ||
  pathname.includes("/tests/trail-making") ||
  pathname.includes("/tests/focus-challenge") ||
  pathname.includes("/adhd-test") ||
  pathname.includes("/color-game") ||
  pathname.includes("/gauntlet")
const isMotorOpen =
  pathname.includes("/tests/click-speed") ||
  pathname.includes("/tests/aim-trainer") ||
  pathname.includes("/tests/mouse-accuracy") ||
  pathname.includes("/tests/flick-trainer") ||
  pathname.includes("/tests/typing-speed") ||
  pathname.includes("/tests/aim-coordination")
const isExecutiveOpen =
  pathname.includes("/tests/trail-making") ||
  pathname.includes("/tests/decision-speed") ||
  pathname.includes("/tests/planning") ||
  pathname.includes("/tests/prioritization") // Keep default closed unless clicked
const isScienceOpen = pathname.includes("/learn/")
const isHomeActive = pathname === "/"
const isTestsActive = pathname.startsWith("/tests")
const isHistoryActive = pathname === "/history"
const isProfileActive = pathname === "/dashboard"
---

<html lang="en">
  <head>
    <script is:inline>
      const stored = localStorage.getItem("theme")
      const systemDark = window.matchMedia(
        "(prefers-color-scheme: dark)"
      ).matches
      const theme = stored || (systemDark ? "dark" : "light")
      if (theme === "dark") {
        document.documentElement.classList.add("dark")
      } else {
        document.documentElement.classList.remove("dark")
      }
      const lang = localStorage.getItem("language") || "en"
      if (lang !== "en") {
        document.documentElement.lang = lang
      }
    </script>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=5.0"
    />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="cogniarena" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={canonicalUrl} />
    <link rel="alternate" hreflang="es" href={canonicalUrl} />
    <link rel="alternate" hreflang="fr" href={canonicalUrl} />
    <link rel="alternate" hreflang="de" href={canonicalUrl} />
    <link rel="alternate" hreflang="pt" href={canonicalUrl} />
    <link rel="alternate" hreflang="ja" href={canonicalUrl} />
    <title>{title}</title>

    <!-- Meta tags for SEO -->
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />

    <!-- Open Graph tags for Social Sharing -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="CogniArena" />
    <meta property="og:image" content={ogImage || "/og-image.svg"} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="CogniArena — Free Reaction Time Test & Cognitive Assessments"
    />

    <!-- Twitter card tags -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage || "/og-image.svg"} />

    <!-- Theme Color -->
    <meta
      name="theme-color"
      content="#000000"
      media="(prefers-color-scheme: dark)"
    />
    <meta
      name="theme-color"
      content="#f8fafc"
      media="(prefers-color-scheme: light)"
    />

    <!-- JSON-LD Structured Data -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify(finalSchemas[0])}
    />
    {
      finalSchemas.length > 1 &&
        finalSchemas
          .slice(1)
          .map((s: any) => (
            <script type="application/ld+json" set:html={JSON.stringify(s)} />
          ))
    }

    <!-- Preconnect + Web Fonts (instead of CSS @import for performance) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin="anonymous"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap"
    />

    <!-- i18n: Embed translations data + load translation engine -->
    <script
      is:inline
      set:html={`window.__i18nData = ${JSON.stringify(translations)};`}
    />
    <script is:inline src="/i18n.js"></script>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-9WHJWEWD5L"
    ></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || []
      function gtag() {
        dataLayer.push(arguments)
      }
      gtag("js", new Date())
      gtag("config", "G-9WHJWEWD5L")
    </script>

    <!-- Google AdSense: Uncomment and replace ca-pub-XXXXXXXXXXXXXXXX with your publisher ID before enabling ads -->
    <!--
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXXXXXXXX" crossorigin="anonymous"></script>
    -->
  </head>
  <body
    class="flex min-h-screen flex-col bg-background text-foreground antialiased"
  >
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[100] focus:rounded-md focus:bg-accent focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:text-white"
      >Skip to content</a
    >

    <!-- Onboarding Flow -->
    <OnboardingFlow client:load />

    <!-- Keyboard Shortcuts Help Modal -->
    <KeyboardShortcutsHelp client:load />
    <div class="flex min-h-screen flex-1 flex-col lg:flex-row">
      <!-- Desktop Sidebar Layout -->
      <aside
        class="hidden w-64 shrink-0 flex-col gap-8 border-r border-card-border bg-card p-6 lg:flex"
      >
        <div class="flex flex-col gap-2">
          <a
            href="/"
            class="flex items-center gap-2 transition-opacity hover:opacity-90"
          >
            <img
              src="/favicon.svg"
              alt="CogniArena"
              width="32"
              height="32"
              class="h-8 w-8"
            />
            <span class="text-lg font-bold tracking-tight text-foreground"
              >CogniArena</span
            >
          </a>
          <span
            class="px-1 text-[10px] tracking-widest text-muted uppercase"
            data-i18n="nav.tagline">Discover Your Cognitive Potential</span
          >
        </div>

        <nav class="flex flex-1 flex-col gap-3.5 overflow-y-auto pr-1">
          <!-- Ecosystem -->
          <div class="flex flex-col gap-1">
            <span
              class="mb-1 px-2 font-mono text-[10px] font-semibold tracking-widest text-muted uppercase"
              data-i18n="nav.ecosystem">Ecosystem</span
            >
            <a
              href="/"
              class={`flex items-center gap-2.5 px-3 py-2 rounded-md text-xs transition-standard hover:bg-subtle ${pathname === "/" ? "bg-accent/15 border-l-2 border-accent text-accent font-semibold" : "text-muted hover:text-foreground"}`}
            >
              <Icon name="home" size={16} />
              <span data-i18n="nav.home">Home Overview</span>
            </a>
            <a
              href="/benchmarks"
              class={`flex items-center gap-2.5 px-3 py-2 rounded-md text-xs transition-standard hover:bg-subtle ${pathname.includes("/benchmarks") ? "bg-accent/15 border-l-2 border-accent text-accent font-semibold" : "text-muted hover:text-foreground"}`}
            >
              <Icon name="chart-bar" size={16} />
              <span data-i18n="nav.benchmarks">Population Benchmarks</span>
            </a>
            <a
              href="/dashboard"
              class={`flex items-center gap-2.5 px-3 py-2 rounded-md text-xs transition-standard hover:bg-subtle ${pathname.includes("/dashboard") ? "bg-accent/15 border-l-2 border-accent text-accent font-semibold" : "text-muted hover:text-foreground"}`}
            >
              <Icon name="chart-bar" size={16} />
              <span data-i18n="nav.dashboard">Dashboard</span>
            </a>
            <a
              href="/records"
              class={`flex items-center gap-2.5 px-3 py-2 rounded-md text-xs transition-standard hover:bg-subtle ${pathname === "/records" ? "bg-accent/15 border-l-2 border-accent text-accent font-semibold" : "text-muted hover:text-foreground"}`}
            >
              <Icon name="clipboard" size={16} />
              <span data-i18n="nav.records">Personal Records</span>
            </a>
            <a
              href="/brain-games"
              class={`flex items-center gap-2.5 px-3 py-2 rounded-md text-xs transition-standard hover:bg-subtle ${pathname === "/brain-games" ? "bg-accent/15 border-l-2 border-accent text-accent font-semibold" : "text-muted hover:text-foreground"}`}
            >
              <Icon name="brain" size={16} />
              <span data-i18n="nav.brain_games">Brain Games</span>
            </a>
            <a
              href="/gauntlet"
              class={`flex items-center gap-2.5 px-3 py-2 rounded-md text-xs transition-standard hover:bg-subtle ${pathname.includes("/gauntlet") ? "bg-accent/15 border-l-2 border-accent text-accent font-semibold" : "text-muted hover:text-foreground"}`}
            >
              <Icon name="castle" size={16} />
              <span data-i18n="nav.gauntlet">The Gauntlet</span>
              <span
                class="ml-auto font-mono text-[8px] text-accent uppercase"
                data-i18n="nav.flagship">Flagship</span
              >
            </a>
          </div>

          <!-- Reaction & Reflexes Accordion -->
          <details class="group" open={isReactionOpen}>
            <summary
              class="flex cursor-pointer list-none items-center justify-between rounded-md px-2 py-1.5 font-mono text-[10px] font-semibold tracking-widest text-muted uppercase select-none hover:text-foreground [&::-webkit-details-marker]:hidden"
            >
              <div class="flex items-center gap-1.5">
                <Icon name="zap" size={16} />
                <span data-i18n="nav.reaction">Reaction & Reflexes</span>
              </div>
              <svg
                class="h-3 w-3 text-muted transition-transform duration-250 group-open:rotate-180"
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2.5"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M19 9l-7 7-7-7"></path>
              </svg>
            </summary>
            <div
              class="mt-1 flex flex-col gap-1 border-l border-card-border/60 pl-2"
            >
              <a
                href="/tests/reaction-time"
                class={`flex items-center gap-2 px-3 py-1.5 rounded text-xs transition-standard hover:bg-subtle ${pathname.includes("/tests/reaction-time") ? "text-accent font-semibold bg-accent/5" : "text-muted hover:text-foreground"}`}
              >
                <Icon name="zap" size={16} />
                <span data-i18n="nav.visual_reaction">Visual Reaction</span>
              </a>
              <a
                href="/tests/sound-reaction"
                class={`flex items-center gap-2 px-3 py-1.5 rounded text-xs transition-standard hover:bg-subtle ${pathname.includes("/tests/sound-reaction") ? "text-accent font-semibold bg-accent/5" : "text-muted hover:text-foreground"}`}
              >
                <Icon name="volume" size={16} />
                <span data-i18n="nav.auditory_reflex">Auditory Reflex</span>
              </a>
              <a
                href="/tests/f1-lights"
                class={`flex items-center gap-2 px-3 py-1.5 rounded text-xs transition-standard hover:bg-subtle ${pathname.includes("/tests/f1-lights") ? "text-accent font-semibold bg-accent/5" : "text-muted hover:text-foreground"}`}
              >
                <Icon name="flag" size={16} />
                <span data-i18n="nav.f1_lights">F1 Start Lights</span>
              </a>
              <a
                href="/tests/choice-reaction"
                class={`flex items-center gap-2 px-3 py-1.5 rounded text-xs transition-standard hover:bg-subtle ${pathname.includes("/tests/choice-reaction") ? "text-accent font-semibold bg-accent/5" : "text-muted hover:text-foreground"}`}
              >
                <Icon name="hash" size={16} />
                <span data-i18n="nav.choice_reaction">Choice Reaction</span>
              </a>
              <a
                href="/tests/go-no-go"
                class={`flex items-center gap-2 px-3 py-1.5 rounded text-xs transition-standard hover:bg-subtle ${pathname.includes("/tests/go-no-go") ? "text-accent font-semibold bg-accent/5" : "text-muted hover:text-foreground"}`}
              >
                <Icon name="shield" size={16} />
                <span data-i18n="nav.go_nogo">Color Go/No-Go</span>
              </a>
            </div>
          </details>

          <!-- Memory Accordion -->
          <details class="group" open={isMemoryOpen}>
            <summary
              class="flex cursor-pointer list-none items-center justify-between rounded-md px-2 py-1.5 font-mono text-[10px] font-semibold tracking-widest text-muted uppercase select-none hover:text-foreground [&::-webkit-details-marker]:hidden"
            >
              <div class="flex items-center gap-1.5">
                <Icon name="brain" size={16} />
                <span data-i18n="nav.memory">Memory</span>
              </div>
              <svg
                class="h-3 w-3 text-muted transition-transform duration-250 group-open:rotate-180"
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2.5"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M19 9l-7 7-7-7"></path>
              </svg>
            </summary>
            <div
              class="mt-1 flex flex-col gap-1 border-l border-card-border/60 pl-2"
            >
              <a
                href="/tests/sequence-memory"
                class={`flex items-center gap-2 px-3 py-1.5 rounded text-xs transition-standard hover:bg-subtle ${pathname.includes("/tests/sequence-memory") ? "text-accent font-semibold bg-accent/5" : "text-muted hover:text-foreground"}`}
              >
                <Icon name="layers" size={16} />
                <span data-i18n="nav.sequence_memory">Sequence Memory</span>
              </a>
              <a
                href="/tests/number-memory"
                class={`flex items-center gap-2 px-3 py-1.5 rounded text-xs transition-standard hover:bg-subtle ${pathname.includes("/tests/number-memory") ? "text-accent font-semibold bg-accent/5" : "text-muted hover:text-foreground"}`}
              >
                <Icon name="hash" size={16} />
                <span data-i18n="nav.number_memory">Number Memory</span>
              </a>
              <a
                href="/tests/visual-pattern"
                class={`flex items-center gap-2 px-3 py-1.5 rounded text-xs transition-standard hover:bg-subtle ${pathname.includes("/tests/visual-pattern") ? "text-accent font-semibold bg-accent/5" : "text-muted hover:text-foreground"}`}
              >
                <Icon name="puzzle" size={16} />
                <span data-i18n="nav.visual_pattern">Visual Pattern</span>
              </a>
              <a
                href="/tests/dual-n-back"
                class={`flex items-center gap-2 px-3 py-1.5 rounded text-xs transition-standard hover:bg-subtle ${pathname.includes("/tests/dual-n-back") ? "text-accent font-semibold bg-accent/5" : "text-muted hover:text-foreground"}`}
              >
                <Icon name="brain" size={16} />
                <span data-i18n="nav.dual_nback">Dual N-Back</span>
              </a>
              <a
                href="/tests/verbal-memory"
                class={`flex items-center gap-2 px-3 py-1.5 rounded text-xs transition-standard hover:bg-subtle ${pathname.includes("/tests/verbal-memory") ? "text-accent font-semibold bg-accent/5" : "text-muted hover:text-foreground"}`}
              >
                <Icon name="file-text" size={16} />
                <span data-i18n="nav.verbal_memory">Verbal Memory</span>
              </a>
            </div>
          </details>

          <!-- Reasoning Accordion -->
          <details class="group" open={isReasoningOpen}>
            <summary
              class="flex cursor-pointer list-none items-center justify-between rounded-md px-2 py-1.5 font-mono text-[10px] font-semibold tracking-widest text-muted uppercase select-none hover:text-foreground [&::-webkit-details-marker]:hidden"
            >
              <div class="flex items-center gap-1.5">
                <Icon name="puzzle" size={16} />
                <span data-i18n="nav.reasoning">Reasoning</span>
              </div>
              <svg
                class="h-3 w-3 text-muted transition-transform duration-250 group-open:rotate-180"
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2.5"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M19 9l-7 7-7-7"></path>
              </svg>
            </summary>
            <div
              class="mt-1 flex flex-col gap-1 border-l border-card-border/60 pl-2"
            >
              <a
                href="/tests/pattern-reasoning?format=pattern"
                class="transition-standard flex items-center justify-between rounded px-3 py-1.5 text-xs text-muted hover:bg-subtle hover:text-foreground"
              >
                <span data-i18n="nav.pattern_recognition"
                  >Pattern Recognition</span
                >
                <span
                  class="rounded bg-accent/10 px-1.5 font-mono text-[9px] text-accent"
                  data-i18n="btn.play">Play</span
                >
              </a>
              <a
                href="/tests/pattern-reasoning?format=matrix"
                class="transition-standard flex items-center justify-between rounded px-3 py-1.5 text-xs text-muted hover:bg-subtle hover:text-foreground"
              >
                <span data-i18n="nav.matrix_reasoning">Matrix Reasoning</span>
                <span
                  class="rounded bg-accent/10 px-1.5 font-mono text-[9px] text-accent"
                  data-i18n="btn.play">Play</span
                >
              </a>
              <a
                href="/tests/pattern-reasoning?format=sequence"
                class="transition-standard flex items-center justify-between rounded px-3 py-1.5 text-xs text-muted hover:bg-subtle hover:text-foreground"
              >
                <span data-i18n="nav.sequence_logic">Sequence Logic</span>
                <span
                  class="rounded bg-accent/10 px-1.5 font-mono text-[9px] text-accent"
                  data-i18n="btn.play">Play</span
                >
              </a>
              <a
                href="/tests/pattern-reasoning?format=analogy"
                class="transition-standard flex items-center justify-between rounded px-3 py-1.5 text-xs text-muted hover:bg-subtle hover:text-foreground"
              >
                <span data-i18n="nav.shape_analogies">Shape Analogies</span>
                <span
                  class="rounded bg-accent/10 px-1.5 font-mono text-[9px] text-accent"
                  data-i18n="btn.play">Play</span
                >
              </a>
              <a
                href="/tests/spatial-orientation"
                class={`flex items-center gap-2 px-3 py-1.5 rounded text-xs transition-standard hover:bg-subtle ${pathname.includes("/tests/spatial-orientation") ? "text-accent font-semibold bg-accent/5" : "text-muted hover:text-foreground"}`}
              >
                <Icon name="refresh" size={16} />
                <span data-i18n="nav.spatial_orientation"
                  >Spatial Orientation</span
                >
              </a>
            </div>
          </details>

          <!-- Focus & Attention Accordion -->
          <details class="group" open={isFocusOpen}>
            <summary
              class="flex cursor-pointer list-none items-center justify-between rounded-md px-2 py-1.5 font-mono text-[10px] font-semibold tracking-widest text-muted uppercase select-none hover:text-foreground [&::-webkit-details-marker]:hidden"
            >
              <div class="flex items-center gap-1.5">
                <Icon name="crosshair" size={16} />
                <span data-i18n="nav.focus">Focus & Attention</span>
              </div>
              <svg
                class="h-3 w-3 text-muted transition-transform duration-250 group-open:rotate-180"
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2.5"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M19 9l-7 7-7-7"></path>
              </svg>
            </summary>
            <div
              class="mt-1 flex flex-col gap-1 border-l border-card-border/60 pl-2"
            >
