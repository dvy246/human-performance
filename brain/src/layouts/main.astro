---
import "@/styles/global.css";
import SyncPanel from "@/components/ui/SyncPanel";
import ThemeToggle from "@/components/ui/ThemeToggle";
import CalibrationBanner from "@/components/ui/CalibrationBanner";

interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
  schemaJson?: Record<string, any> | Record<string, any>[];
}

const {
  title = "CogniArena — Discover Your Cognitive Potential",
  description = "Benchmark your reaction time, cognitive endurance, memory, and precision speed. Track improvements and challenge your friends.",
  canonicalUrl = "https://cogniarena.com",
  schemaJson,
} = Astro.props;

// Default structured data for the site
const defaultSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "CogniArena",
  "operatingSystem": "All",
  "applicationCategory": "CognitiveAssessment",
  "browserRequirements": "Requires HTML5, requestAnimationFrame, performance.now",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};

const finalSchemas = Array.isArray(schemaJson) ? schemaJson : [schemaJson || defaultSchema];

const { pathname } = Astro.url;

// Determine active state indicators
const isReactionOpen = pathname.includes('/tests/reaction-time') || pathname.includes('/tests/f1-lights') || pathname.includes('/tests/sound-reaction') || pathname.includes('/tests/choice-reaction') || pathname.includes('/tests/go-no-go');
const isMemoryOpen = pathname.includes('/tests/sequence-memory') || pathname.includes('/tests/number-memory') || pathname.includes('/tests/visual-pattern') || pathname.includes('/tests/dual-n-back') || pathname.includes('/tests/verbal-memory');
const isReasoningOpen = pathname.includes('/tests/pattern-reasoning') || pathname.includes('/tests/spatial-orientation');
const isFocusOpen = pathname.includes('/tests/stroop') || pathname.includes('/tests/trail-making') || pathname.includes('/tests/focus-challenge') || pathname.includes('/gauntlet');
const isMotorOpen = pathname.includes('/tests/click-speed') || pathname.includes('/tests/aim-trainer') || pathname.includes('/tests/mouse-accuracy') || pathname.includes('/tests/flick-trainer') || pathname.includes('/tests/typing-speed');
const isExecutiveOpen = pathname.includes('/tests/trail-making') || pathname.includes('/tests/decision-speed') || pathname.includes('/tests/planning') || pathname.includes('/tests/prioritization'); // Keep default closed unless clicked
const isScienceOpen = pathname.includes('/learn/');
---

<html lang="en">
  <head>
    <script is:inline>
      const stored = localStorage.getItem('theme');
      const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const theme = stored || (systemDark ? 'dark' : 'light');
      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="cogniarena" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="canonical" href={canonicalUrl} />
    <title>{title}</title>
    
    <!-- Meta tags for SEO -->
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    
    <!-- Open Graph tags for Social Sharing -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="CogniArena" />
    <meta property="og:image" content="https://cogniarena.com/og-image.png" />
    
    <!-- Twitter card tags -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://cogniarena.com/og-image.png" />

    <!-- Theme Color -->
    <meta name="theme-color" content="#000000" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#f8fafc" media="(prefers-color-scheme: light)" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(finalSchemas[0])} />
      {finalSchemas.length > 1 && finalSchemas.slice(1).map((s: any) => (
        <script type="application/ld+json" set:html={JSON.stringify(s)} />
      ))}

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-9WHJWEWD5L"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-9WHJWEWD5L');
    </script>

    <!-- Google AdSense script placeholder: Replace ca-pub-XXXXXXXXXXXXXXXX with your AdSense publisher ID before deploying to production -->
    <!-- TODO: Add production AdSense publisher ID -->
    <script is:inline>
      window.addEventListener('load', () => {
        // Only load heavy ads script after page load to preserve initial metrics
        setTimeout(() => {
          const script = document.createElement('script');
          script.async = true;
          script.src = "https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXXXXXXXX"; // TODO: Replace with actual publisher ID
          script.crossOrigin = "anonymous";
          document.head.appendChild(script);
        }, 1500);
      });
    </script>
  </head>
  <body class="bg-background text-foreground min-h-screen flex flex-col antialiased">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[100] focus:px-4 focus:py-2 focus:rounded-md focus:bg-accent focus:text-white focus:text-sm focus:font-semibold">Skip to content</a>
    <div class="flex flex-1 flex-col lg:flex-row min-h-screen">
      <!-- Desktop Sidebar Layout -->
      <aside class="hidden lg:flex flex-col w-64 border-r border-card-border bg-card shrink-0 p-6 gap-8">
        <div class="flex flex-col gap-2">
          <a href="/" class="flex items-center gap-2 hover:opacity-90 transition-opacity">
            <img src="/favicon.svg" alt="CogniArena" width="32" height="32" class="w-8 h-8" />
            <span class="font-bold text-lg tracking-tight text-foreground">CogniArena</span>
          </a>
          <span class="text-[10px] text-muted uppercase tracking-widest px-1">Discover Your Cognitive Potential</span>
        </div>

        <nav class="flex flex-col gap-3.5 flex-1 overflow-y-auto pr-1">
          <!-- Ecosystem -->
          <div class="flex flex-col gap-1">
            <span class="text-[10px] font-semibold text-muted uppercase tracking-widest px-2 mb-1 font-mono">Ecosystem</span>
            <a href="/" class={`flex items-center gap-2.5 px-3 py-2 rounded-md text-xs transition-standard hover:bg-subtle ${pathname === '/' ? 'bg-accent/15 border-l-2 border-accent text-accent font-semibold' : 'text-muted hover:text-foreground'}`}>
              <span aria-hidden="true">🏠</span>
              <span>Home Overview</span>
            </a>
            <a href="/benchmarks" class={`flex items-center gap-2.5 px-3 py-2 rounded-md text-xs transition-standard hover:bg-subtle ${pathname.includes('/benchmarks') ? 'bg-accent/15 border-l-2 border-accent text-accent font-semibold' : 'text-muted hover:text-foreground'}`}>
              <span aria-hidden="true">📊</span>
              <span>Population Benchmarks</span>
            </a>
            <a href="/dashboard" class={`flex items-center gap-2.5 px-3 py-2 rounded-md text-xs transition-standard hover:bg-subtle ${pathname.includes('/dashboard') ? 'bg-accent/15 border-l-2 border-accent text-accent font-semibold' : 'text-muted hover:text-foreground'}`}>
              <span aria-hidden="true">📊</span>
              <span>Performance HQ</span>
            </a>
            <a href="/gauntlet" class={`flex items-center gap-2.5 px-3 py-2 rounded-md text-xs transition-standard hover:bg-subtle ${pathname.includes('/gauntlet') ? 'bg-accent/15 border-l-2 border-accent text-accent font-semibold' : 'text-muted hover:text-foreground'}`}>
              <span aria-hidden="true">🏰</span>
              <span>The Gauntlet</span>
              <span class="text-[8px] font-mono uppercase text-accent ml-auto">Flagship</span>
            </a>
          </div>

          <!-- Reaction & Reflexes Accordion -->
          <details class="group" open={isReactionOpen}>
            <summary class="flex items-center justify-between px-2 py-1.5 rounded-md text-[10px] font-semibold text-muted hover:text-foreground uppercase tracking-widest cursor-pointer select-none list-none [&::-webkit-details-marker]:hidden font-mono">
              <div class="flex items-center gap-1.5">
                <span aria-hidden="true">⚡</span>
                <span>Reaction & Reflexes</span>
              </div>
              <svg class="w-3 h-3 text-muted group-open:rotate-180 transition-transform duration-250" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="mt-1 flex flex-col gap-1 pl-2 border-l border-card-border/60">
              <a href="/tests/reaction-time" class={`flex items-center gap-2 px-3 py-1.5 rounded text-xs transition-standard hover:bg-subtle ${pathname.includes('/tests/reaction-time') ? 'text-accent font-semibold bg-accent/5' : 'text-muted hover:text-foreground'}`}>
                <span aria-hidden="true">⚡</span>
                <span>Visual Reaction</span>
              </a>
              <a href="/tests/sound-reaction" class={`flex items-center gap-2 px-3 py-1.5 rounded text-xs transition-standard hover:bg-subtle ${pathname.includes('/tests/sound-reaction') ? 'text-accent font-semibold bg-accent/5' : 'text-muted hover:text-foreground'}`}>
                <span aria-hidden="true">🔊</span>
                <span>Auditory Reflex</span>
              </a>
              <a href="/tests/f1-lights" class={`flex items-center gap-2 px-3 py-1.5 rounded text-xs transition-standard hover:bg-subtle ${pathname.includes('/tests/f1-lights') ? 'text-accent font-semibold bg-accent/5' : 'text-muted hover:text-foreground'}`}>
                <span aria-hidden="true">🏎️</span>
                <span>F1 Start Lights</span>
              </a>
              <a href="/tests/choice-reaction" class={`flex items-center gap-2 px-3 py-1.5 rounded text-xs transition-standard hover:bg-subtle ${pathname.includes('/tests/choice-reaction') ? 'text-accent font-semibold bg-accent/5' : 'text-muted hover:text-foreground'}`}>
                <span aria-hidden="true">🔢</span>
                <span>Choice Reaction</span>
              </a>
              <a href="/tests/go-no-go" class={`flex items-center gap-2 px-3 py-1.5 rounded text-xs transition-standard hover:bg-subtle ${pathname.includes('/tests/go-no-go') ? 'text-accent font-semibold bg-accent/5' : 'text-muted hover:text-foreground'}`}>
                <span aria-hidden="true">🛡️</span>
                <span>Color Go/No-Go</span>
              </a>
            </div>
          </details>

          <!-- Memory Accordion -->
          <details class="group" open={isMemoryOpen}>
            <summary class="flex items-center justify-between px-2 py-1.5 rounded-md text-[10px] font-semibold text-muted hover:text-foreground uppercase tracking-widest cursor-pointer select-none list-none [&::-webkit-details-marker]:hidden font-mono">
              <div class="flex items-center gap-1.5">
                <span aria-hidden="true">🧠</span>
                <span>Memory</span>
              </div>
              <svg class="w-3 h-3 text-muted group-open:rotate-180 transition-transform duration-250" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="mt-1 flex flex-col gap-1 pl-2 border-l border-card-border/60">
              <a href="/tests/sequence-memory" class={`flex items-center gap-2 px-3 py-1.5 rounded text-xs transition-standard hover:bg-subtle ${pathname.includes('/tests/sequence-memory') ? 'text-accent font-semibold bg-accent/5' : 'text-muted hover:text-foreground'}`}>
                <span aria-hidden="true">🗂️</span>
                <span>Sequence Memory</span>
              </a>
              <a href="/tests/number-memory" class={`flex items-center gap-2 px-3 py-1.5 rounded text-xs transition-standard hover:bg-subtle ${pathname.includes('/tests/number-memory') ? 'text-accent font-semibold bg-accent/5' : 'text-muted hover:text-foreground'}`}>
                <span aria-hidden="true">🔢</span>
                <span>Number Memory</span>
              </a>
              <a href="/tests/visual-pattern" class={`flex items-center gap-2 px-3 py-1.5 rounded text-xs transition-standard hover:bg-subtle ${pathname.includes('/tests/visual-pattern') ? 'text-accent font-semibold bg-accent/5' : 'text-muted hover:text-foreground'}`}>
                <span aria-hidden="true">🧩</span>
                <span>Visual Pattern</span>
              </a>
              <a href="/tests/dual-n-back" class={`flex items-center gap-2 px-3 py-1.5 rounded text-xs transition-standard hover:bg-subtle ${pathname.includes('/tests/dual-n-back') ? 'text-accent font-semibold bg-accent/5' : 'text-muted hover:text-foreground'}`}>
                <span aria-hidden="true">🧠</span>
                <span>Dual N-Back</span>
              </a>
              <a href="/tests/verbal-memory" class={`flex items-center gap-2 px-3 py-1.5 rounded text-xs transition-standard hover:bg-subtle ${pathname.includes('/tests/verbal-memory') ? 'text-accent font-semibold bg-accent/5' : 'text-muted hover:text-foreground'}`}>
                <span aria-hidden="true">📝</span>
                <span>Verbal Memory</span>
              </a>
            </div>
          </details>

          <!-- Reasoning Accordion -->
          <details class="group" open={isReasoningOpen}>
            <summary class="flex items-center justify-between px-2 py-1.5 rounded-md text-[10px] font-semibold text-muted hover:text-foreground uppercase tracking-widest cursor-pointer select-none list-none [&::-webkit-details-marker]:hidden font-mono">
              <div class="flex items-center gap-1.5">
                <span aria-hidden="true">🧩</span>
                <span>Reasoning</span>
              </div>
              <svg class="w-3 h-3 text-muted group-open:rotate-180 transition-transform duration-250" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="mt-1 flex flex-col gap-1 pl-2 border-l border-card-border/60">
              <a href="/tests/pattern-reasoning?format=pattern" class="flex items-center justify-between px-3 py-1.5 rounded text-xs transition-standard hover:bg-subtle text-muted hover:text-foreground">
                <span>Pattern Recognition</span>
                <span class="text-[9px] bg-accent/10 text-accent px-1.5 rounded font-mono">Play</span>
              </a>
              <a href="/tests/pattern-reasoning?format=matrix" class="flex items-center justify-between px-3 py-1.5 rounded text-xs transition-standard hover:bg-subtle text-muted hover:text-foreground">
                <span>Matrix Reasoning</span>
                <span class="text-[9px] bg-accent/10 text-accent px-1.5 rounded font-mono">Play</span>
              </a>
              <a href="/tests/pattern-reasoning?format=sequence" class="flex items-center justify-between px-3 py-1.5 rounded text-xs transition-standard hover:bg-subtle text-muted hover:text-foreground">
                <span>Sequence Logic</span>
                <span class="text-[9px] bg-accent/10 text-accent px-1.5 rounded font-mono">Play</span>
              </a>
              <a href="/tests/pattern-reasoning?format=analogy" class="flex items-center justify-between px-3 py-1.5 rounded text-xs transition-standard hover:bg-subtle text-muted hover:text-foreground">
                <span>Shape Analogies</span>
                <span class="text-[9px] bg-accent/10 text-accent px-1.5 rounded font-mono">Play</span>
              </a>
              <a href="/tests/spatial-orientation" class={`flex items-center gap-2 px-3 py-1.5 rounded text-xs transition-standard hover:bg-subtle ${pathname.includes('/tests/spatial-orientation') ? 'text-accent font-semibold bg-accent/5' : 'text-muted hover:text-foreground'}`}>
                <span aria-hidden="true">🔄</span>
                <span>Spatial Orientation</span>
              </a>
            </div>
          </details>

          <!-- Focus & Attention Accordion -->
          <details class="group" open={isFocusOpen}>
            <summary class="flex items-center justify-between px-2 py-1.5 rounded-md text-[10px] font-semibold text-muted hover:text-foreground uppercase tracking-widest cursor-pointer select-none list-none [&::-webkit-details-marker]:hidden font-mono">
              <div class="flex items-center gap-1.5">
                <span aria-hidden="true">🎯</span>
                <span>Focus & Attention</span>
              </div>
              <svg class="w-3 h-3 text-muted group-open:rotate-180 transition-transform duration-250" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="mt-1 flex flex-col gap-1 pl-2 border-l border-card-border/60">
              <a href="/tests/stroop" class={`flex items-center gap-2 px-3 py-1.5 rounded text-xs transition-standard hover:bg-subtle ${pathname.includes('/tests/stroop') ? 'text-accent font-semibold bg-accent/5' : 'text-muted hover:text-foreground'}`}>
                <span aria-hidden="true">🎨</span>
                <span>Stroop Test</span>
              </a>
              <a href="/tests/trail-making" class={`flex items-center gap-2 px-3 py-1.5 rounded text-xs transition-standard hover:bg-subtle ${pathname.includes('/tests/trail-making') ? 'text-accent font-semibold bg-accent/5' : 'text-muted hover:text-foreground'}`}>
                <span aria-hidden="true">🧭</span>
                <span>Trail Making</span>
              </a>
              <a href="/tests/focus-challenge" class={`flex items-center gap-2 px-3 py-1.5 rounded text-xs transition-standard hover:bg-subtle ${pathname.includes('/tests/focus-challenge') ? 'text-accent font-semibold bg-accent/5' : 'text-muted hover:text-foreground'}`}>
                <span aria-hidden="true">🎯</span>
                <span>Focus Challenge</span>
              </a>
            </div>
          </details>

          <!-- Motor Performance Accordion -->
          <details class="group" open={isMotorOpen}>
            <summary class="flex items-center justify-between px-2 py-1.5 rounded-md text-[10px] font-semibold text-muted hover:text-foreground uppercase tracking-widest cursor-pointer select-none list-none [&::-webkit-details-marker]:hidden font-mono">
              <div class="flex items-center gap-1.5">
                <span>🎮</span>
                <span>Motor Performance</span>
              </div>
              <svg class="w-3 h-3 text-muted group-open:rotate-180 transition-transform duration-250" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="mt-1 flex flex-col gap-1 pl-2 border-l border-card-border/60">
              <a href="/tests/click-speed" class={`flex items-center gap-2 px-3 py-1.5 rounded text-xs transition-standard hover:bg-subtle ${pathname.includes('/tests/click-speed') ? 'text-accent font-semibold bg-accent/5' : 'text-muted hover:text-foreground'}`}>
                <span aria-hidden="true">🖱️</span>
                <span>CPS Test</span>
              </a>
              <a href="/tests/aim-trainer" class={`flex items-center gap-2 px-3 py-1.5 rounded text-xs transition-standard hover:bg-subtle ${pathname.includes('/tests/aim-trainer') ? 'text-accent font-semibold bg-accent/5' : 'text-muted hover:text-foreground'}`}>
                <span aria-hidden="true">🎯</span>
                <span>Aim Precision</span>
              </a>
              <a href="/tests/mouse-accuracy" class={`flex items-center gap-2 px-3 py-1.5 rounded text-xs transition-standard hover:bg-subtle ${pathname.includes('/tests/mouse-accuracy') ? 'text-accent font-semibold bg-accent/5' : 'text-muted hover:text-foreground'}`}>
                <span aria-hidden="true">🎯</span>
                <span>Mouse Accuracy</span>
              </a>
              <a href="/tests/flick-trainer" class={`flex items-center gap-2 px-3 py-1.5 rounded text-xs transition-standard hover:bg-subtle ${pathname.includes('/tests/flick-trainer') ? 'text-accent font-semibold bg-accent/5' : 'text-muted hover:text-foreground'}`}>
                <span aria-hidden="true">⚡</span>
                <span>Flick Trainer</span>
              </a>
              <a href="/tests/typing-speed" class={`flex items-center gap-2 px-3 py-1.5 rounded text-xs transition-standard hover:bg-subtle ${pathname.includes('/tests/typing-speed') ? 'text-accent font-semibold bg-accent/5' : 'text-muted hover:text-foreground'}`}>
                <span aria-hidden="true">⌨️</span>
                <span>Typing Speed</span>
              </a>
            </div>
          </details>

          <!-- Executive Function Accordion -->
          <details class="group" open={isExecutiveOpen}>
            <summary class="flex items-center justify-between px-2 py-1.5 rounded-md text-[10px] font-semibold text-muted hover:text-foreground uppercase tracking-widest cursor-pointer select-none list-none [&::-webkit-details-marker]:hidden font-mono">
              <div class="flex items-center gap-1.5">
                <span aria-hidden="true">🧭</span>
                <span>Executive Function</span>
              </div>
              <svg class="w-3 h-3 text-muted group-open:rotate-180 transition-transform duration-250" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="mt-1 flex flex-col gap-1 pl-2 border-l border-card-border/60">
              <a href="/tests/decision-speed" class={`flex items-center gap-2 px-3 py-1.5 rounded text-xs transition-standard hover:bg-subtle ${pathname.includes('/tests/decision-speed') ? 'text-accent font-semibold bg-accent/5' : 'text-muted hover:text-foreground'}`}>
                <span aria-hidden="true">⚡</span>
                <span>Decision Speed</span>
              </a>
              <a href="/tests/planning" class={`flex items-center gap-2 px-3 py-1.5 rounded text-xs transition-standard hover:bg-subtle ${pathname.includes('/tests/planning') ? 'text-accent font-semibold bg-accent/5' : 'text-muted hover:text-foreground'}`}>
                <span aria-hidden="true">♟️</span>
                <span>Planning</span>
              </a>
              <a href="/tests/prioritization" class={`flex items-center gap-2 px-3 py-1.5 rounded text-xs transition-standard hover:bg-subtle ${pathname.includes('/tests/prioritization') ? 'text-accent font-semibold bg-accent/5' : 'text-muted hover:text-foreground'}`}>
                <span aria-hidden="true">📊</span>
                <span>Prioritization</span>
              </a>
              <a href="/tests/trail-making" class="flex items-center justify-between px-3 py-1.5 rounded text-xs transition-standard hover:bg-subtle text-muted hover:text-foreground">
                <span>Cognitive Flexibility</span>
                <span class="text-[9px] bg-accent/10 text-accent px-1.5 rounded font-mono">Play</span>
              </a>
            </div>
          </details>

