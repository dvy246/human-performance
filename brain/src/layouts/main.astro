            <span>&middot;</span>
            <a href="/terms" class="hover:text-accent transition-colors">Terms</a>
          </div>
        </div>
      </aside>

      <!-- Mobile Sidebar Drawer Overlay (Slide in menu) -->
      <div id="mobile-sidebar" class="fixed inset-0 z-50 lg:hidden pointer-events-none transition-opacity duration-300 opacity-0" aria-modal="true" role="dialog">
