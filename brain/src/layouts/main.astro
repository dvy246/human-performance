---
import "@/styles/global.css";
import SyncPanel from "@/components/ui/SyncPanel";
import ThemeToggle from "@/components/ui/ThemeToggle";

interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
  schemaJson?: Record<string, any>;
}

const {
  title = "BrainBenchmarks — Measure. Understand. Improve.",
  description = "Benchmark your reaction time, cognitive endurance, memory, and precision speed. Track improvements and challenge your friends.",
  canonicalUrl = "https://brainbenchmarks.com",
  schemaJson,
} = Astro.props;

// Default structured data for the site
const defaultSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "BrainBenchmarks",
  "operatingSystem": "All",
  "applicationCategory": "CognitiveAssessment",
  "browserRequirements": "Requires HTML5, requestAnimationFrame, performance.now",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};

const finalSchema = schemaJson || defaultSchema;

const { pathname } = Astro.url;

// Determine active state indicators
const isReactionOpen = pathname.includes('/tests/reaction-time') || pathname.includes('/tests/f1-lights') || pathname.includes('/tests/sound-reaction') || pathname.includes('/tests/choice-reaction') || pathname.includes('/tests/go-no-go');
const isMemoryOpen = pathname.includes('/tests/sequence-memory') || pathname.includes('/tests/number-memory') || pathname.includes('/tests/visual-pattern');
const isPrecisionOpen = pathname.includes('/tests/click-speed') || pathname.includes('/tests/aim-trainer');
const isScienceOpen = pathname.includes('/learn/');
---

<html lang="en">
  <head>
    <script is:inline>
      const theme = localStorage.getItem('theme') || 'dark';
      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    <title>{title}</title>
    
    <!-- Meta tags for SEO -->
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    
    <!-- Open Graph tags for Social Sharing -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="BrainBenchmarks" />
    <meta property="og:image" content="https://brainbenchmarks.com/og-image.png" />
    
    <!-- Twitter card tags -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(finalSchema)} />

    <!-- Google AdSense script placeholder (lazy loaded below fold / CLS-safe) -->
    <script is:inline>
      window.addEventListener('load', () => {
        // Only load heavy ads script after page load to preserve initial metrics
        setTimeout(() => {
          const script = document.createElement('script');
          script.async = true;
          script.src = "https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-placeholder";
          script.crossOrigin = "anonymous";
          document.head.appendChild(script);
        }, 1500);
      });
    </script>
  </head>
  <body class="bg-background text-foreground min-h-screen flex flex-col antialiased">
    <div class="flex flex-1 flex-col lg:flex-row min-h-screen">
      <!-- Desktop Sidebar Layout -->
      <aside class="hidden lg:flex flex-col w-64 border-r border-card-border bg-card shrink-0 p-6 gap-8">
        <div class="flex flex-col gap-2">
          <a href="/" class="flex items-center gap-2 hover:opacity-90 transition-opacity">
            <span class="w-6 h-6 rounded bg-accent flex items-center justify-center text-black font-bold text-sm tracking-tighter">B</span>
            <span class="font-bold text-lg tracking-tight text-foreground">BrainBenchmarks</span>
          </a>
          <span class="text-[10px] text-zinc-500 uppercase tracking-widest px-1">Measure. Understand. Improve.</span>
        </div>

        <nav class="flex flex-col gap-3.5 flex-1 overflow-y-auto pr-1">
          <!-- Ecosystem -->
          <div class="flex flex-col gap-1">
            <span class="text-[10px] font-semibold text-zinc-500 uppercase tracking-widest px-2 mb-1 font-mono">Ecosystem</span>
            <a href="/" class={`flex items-center gap-2.5 px-3 py-2 rounded-md text-xs transition-standard hover:bg-subtle ${pathname === '/' ? 'bg-accent/15 border-l-2 border-accent text-accent font-semibold' : 'text-zinc-650 dark:text-zinc-400 hover:text-foreground'}`}>
              <span>🏠</span>
              <span>Home Overview</span>
            </a>
            <a href="/dashboard" class={`flex items-center gap-2.5 px-3 py-2 rounded-md text-xs transition-standard hover:bg-subtle ${pathname.includes('/dashboard') ? 'bg-accent/15 border-l-2 border-accent text-accent font-semibold' : 'text-zinc-650 dark:text-zinc-400 hover:text-foreground'}`}>
              <span>📊</span>
              <span>Brain Profile</span>
