              </a>
              <a href="/learn/aim-training" class={`flex items-center gap-2 px-3 py-1.5 rounded text-xs transition-standard hover:bg-subtle ${pathname.includes('/learn/aim-training') ? 'text-accent font-semibold bg-accent/5' : 'text-zinc-650 dark:text-zinc-400 hover:text-foreground'}`}>
