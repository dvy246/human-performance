          <!-- Science & Learning Accordion Dropdown -->
          <details class="group" open={isScienceOpen}>
            <summary class="flex items-center justify-between px-2 py-1.5 rounded-md text-[10px] font-semibold text-zinc-500 hover:text-foreground uppercase tracking-widest cursor-pointer select-none list-none [&::-webkit-details-marker]:hidden font-mono">
