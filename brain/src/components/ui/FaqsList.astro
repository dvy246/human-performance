---
import { getFaqsForSlug } from "@/data/faqs"

export interface Props {
  slug: string
}

const { slug } = Astro.props
const faqs = getFaqsForSlug(slug)

if (!faqs || faqs.length === 0) {
  return null
}
---

<section class="mt-12 flex flex-col gap-6 border-t border-card-border/50 pt-10">
  <h2 class="text-xl font-bold tracking-tight text-foreground">
    Frequently Asked Questions
  </h2>
  <div class="flex flex-col gap-3">
    {
      faqs.map((faq) => (
        <details class="group card-interactive rounded-xl border border-card-border bg-card p-4">
          <summary class="flex cursor-pointer items-center justify-between text-sm font-semibold text-foreground">
            {faq.q}
            <svg
              class="h-4 w-4 text-muted transition-transform group-open:rotate-180"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="M6 9l6 6 6-6" />
            </svg>
          </summary>
          <p class="mt-3 text-sm leading-relaxed text-muted">{faq.a}</p>
        </details>
      ))
    }
  </div>
</section>
