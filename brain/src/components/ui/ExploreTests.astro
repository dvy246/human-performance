---
import Icon from "@/components/ui/Icon.astro"
import { allTests, categories, getTestsByCategory } from "@/data/tests"

export interface Props {
  currentSlug?: string
  title?: string
}

const { currentSlug, title = "Explore All Assessments" } = Astro.props
const grouped = getTestsByCategory()
// Build schema.org ItemList for SEO
const itemListElements = allTests.map((t, i) => ({
  "@type": "ListItem",
  position: i + 1,
  name: t.title,
  description: t.shortDesc,
  url: `https://cogniarena.com${t.href}`,
}))
const exploreSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "CogniArena Cognitive Assessments",
  description:
    "All 24+ browser-based cognitive assessments measuring reaction time, memory, reasoning, focus, motor skills, and executive function.",
  numberOfItems: allTests.length,
  itemListElement: itemListElements,
}
---

<section class="flex flex-col gap-10 border-t border-card-border pt-12">
  <script type="application/ld+json" set:html={JSON.stringify(exploreSchema)} />

  <header class="flex flex-col gap-2">
    <h2 class="text-2xl font-bold tracking-tight text-foreground">{title}</h2>
    <p class="text-sm leading-relaxed text-muted">
      Explore all {allTests.length} cognitive assessments across six domains. Each
      test runs locally in your browser with sub-millisecond precision.
    </p>
  </header>

  {
    grouped.map(({ category, tests }) => (
      <article class="flex flex-col gap-6">
        <div class="flex flex-col gap-1">
          <h3 class="text-lg font-semibold tracking-tight text-foreground">
            <Icon name={category.iconName} size={20} /> {category.name}
          </h3>
          <p class="font-mono text-xs tracking-wider text-muted uppercase">
            {category.subtitle}
          </p>
        </div>

        <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
          {tests.map((test) => {
            const isCurrent =
              test.slug === currentSlug ||
              (currentSlug === "gauntlet" && test.slug === "gauntlet")
            return (
              <a
                href={isCurrent ? undefined : test.href}
                class={`card-interactive group flex flex-col justify-between gap-4 rounded-xl border p-5 ${
                  isCurrent
                    ? "cursor-default border-accent/40 bg-accent/5"
                    : "border-card-border bg-card hover:border-accent/40 hover:bg-subtle"
                }`}
                aria-current={isCurrent ? "page" : undefined}
              >
                <div class="flex flex-col gap-2.5">
                  <div class="flex items-center gap-2.5">
                    <Icon name={test.iconName} size={20} />
                    <h4 class="text-sm font-bold text-foreground">
                      {test.title}
                    </h4>
                    {isCurrent && (
                      <span class="rounded bg-accent/10 px-1.5 py-0.5 font-mono text-[9px] tracking-wider text-accent uppercase">
                        Current
                      </span>
                    )}
                  </div>
                  <p class="text-xs leading-relaxed text-muted">
                    {test.shortDesc}
                  </p>
                </div>
                {!isCurrent && (
                  <span class="font-mono text-[10px] tracking-widest text-accent uppercase group-hover:underline">
                    Take Test &rarr;
                  </span>
                )}
              </a>
            )
          })}
        </div>
      </article>
    ))
  }
</section>
