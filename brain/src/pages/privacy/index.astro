---
import Layout from "@/layouts/main.astro";

const title = "Privacy Policy | BrainBenchmarks local-first Privacy";
const description = "BrainBenchmarks Privacy Policy. We use browser local storage (IndexedDB) for local-first tracking without collecting personal identifiers.";
---

<Layout title={title} description={description}>
  <div class="flex flex-col gap-10 w-full max-w-3xl mx-auto py-4">
    <header class="flex flex-col gap-3">
      <span class="text-xs font-mono uppercase tracking-widest text-accent">Legal Documentation</span>
      <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight text-foreground">Privacy Policy</h1>
      <p class="text-zinc-550 dark:text-zinc-400 text-sm md:text-base leading-relaxed">
        Effective date: July 5, 2026. We prioritize local-first data isolation.
      </p>
    </header>

    <section class="flex flex-col gap-8 border-t border-card-border pt-10 text-sm text-zinc-650 dark:text-zinc-400 leading-relaxed">
      <article class="flex flex-col gap-3">
        <h2 class="text-lg font-bold text-foreground">1. Local Storage Ledger</h2>
        <p>
          All completed runs, scores, raw latencies, and percentiles are processed and saved locally in your browser's IndexedDB. We do not transmit or access this ledger unless you explicitly select Cloud Sync.
        </p>
      </article>

      <article class="flex flex-col gap-3">
        <h2 class="text-lg font-bold text-foreground">2. Optional Cloud Sync</h2>
        <p>
          If you opt to backup your dashboard stats, an anonymous hashed recovery key maps your encrypted scores to our database hosted on Cloudflare edge systems. No emails, names, or physical telemetry data are linked to the sync token.
        </p>
      </article>

      <article class="flex flex-col gap-3">
        <h2 class="text-lg font-bold text-foreground">3. Analytics and AdSense Cookies</h2>
        <p>
          To maintain server calibration costs, we partner with premium ad exchanges (such as Google AdSense). These third-party networks may place anonymous tracking cookies on your device to serve relevant advertisements, in compliance with GDPR and CCPA protocols.
        </p>
      </article>
    </section>
  </div>
</Layout>
