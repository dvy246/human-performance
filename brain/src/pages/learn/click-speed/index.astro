---
import Layout from "@/layouts/main.astro";

const title = "Click Speed & Motor Stamina (CPS) Science | CogniArena";
const description = "Scientific guide to clicking frequency cadences, Fitts's Law, mechanical latency, and speed endurance training.";
const canonicalUrl = "https://cogniarena.com/learn/click-speed";

const schemaJson = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Science of Click Speed, Cadence Frequency, and Motor Stamina",
  "description": "Understand clicks-per-second, neuro-muscular fatigue patterns, and mouse polling latency benchmarks.",
  "author": {
    "@type": "Person",
    "name": "Dr. Alan Vanc",
    "jobTitle": "Neuroscience Researcher"
  },
  "publisher": {
    "@type": "Organization",
    "name": "CogniArena"
  }
};
---

<Layout title={title} description={description} canonicalUrl={canonicalUrl} schemaJson={schemaJson}>
  <div class="flex flex-col gap-12 w-full max-w-3xl mx-auto">
    <header class="flex flex-col gap-3">
      <div class="flex items-center gap-2 text-xs font-mono uppercase tracking-widest text-accent">
        <span>Learning Center</span>
        <span>&middot;</span>
        <span>Pillar Page</span>
      </div>
      <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight text-foreground animate-fade-in">
        Click Speed (CPS) Science & Dynamics
      </h1>
      <p class="text-zinc-500 dark:text-zinc-500 dark:text-zinc-400 text-sm md:text-base leading-relaxed">
        Investigating clicks-per-second, finger flexing muscular fatigue curves, and hardware input polling rates.
      </p>
    </header>

    <section class="flex flex-col gap-10 border-t border-card-border pt-10">
      <article class="flex flex-col gap-4">
        <h2 class="text-xl font-bold text-foreground tracking-tight">1. Muscle Activation Jitter and Clicking Techniques</h2>
        <p class="text-zinc-500 dark:text-zinc-500 dark:text-zinc-400 text-sm leading-relaxed">
          High-frequency clicking (above 9 CPS) requires activating either muscular tension oscillation (jitter clicking) or tactile rebound slide movements (drag clicking). During jitter clicking, antagonists and agonist forearm muscles are co-contracted, producing micro-tremors that click the switch.
        </p>
      </article>

      <article class="flex flex-col gap-4">
        <h2 class="text-xl font-bold text-foreground tracking-tight">2. Polling Rates and Mechanical Switch Latency</h2>
        <p class="text-zinc-500 dark:text-zinc-500 dark:text-zinc-400 text-sm leading-relaxed">
          The physical button on a mouse contains metallic leaf springs that vibrate when pressed (bounce). Mechanical switches introduce a debounce delay (typically 2ms to 8ms) to prevent double clicks. Mouse USB polling rates determine how frequently the operating system checks for click packets, with 1000Hz (1ms) being the baseline benchmark.
        </p>
      </article>

      <article class="flex flex-col gap-4">
        <h2 class="text-xl font-bold text-foreground tracking-tight">Frequently Asked Questions</h2>
        <div class="flex flex-col gap-4 text-sm">
          <div>
            <h4 class="text-foreground font-bold mb-1">What is a good CPS score?</h4>
            <p class="text-zinc-500 dark:text-zinc-500 dark:text-zinc-400">An average user records a click speed between 6.0 and 7.2 CPS. Competitive gamers utilizing muscular jittering frequently surpass 12 CPS.</p>
          </div>
          <div>
            <h4 class="text-foreground font-bold mb-1">Are optical switches faster than mechanical ones?</h4>
            <p class="text-zinc-500 dark:text-zinc-500 dark:text-zinc-400">Yes. Optical mouse switches use a light beam interruption to register clicks, eliminating physical contact debounce delays entirely and reducing latency to sub-0.5ms ranges.</p>
          </div>
        </div>
      </article>
    </section>
  </div>
</Layout>
