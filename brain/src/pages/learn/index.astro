---
import Layout from "@/layouts/main.astro";

const title = "Learning Center — Cognitive Science & Training Guides | CogniArena";
const description = "Explore 20 in-depth cognitive science guides covering reaction time, memory, executive function, spatial reasoning, and more. Evidence-based training protocols backed by neuroscience research.";
const canonicalUrl = "https://cogniarena.com/learn";

const schemaJson = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "CogniArena Learning Center",
  "description": "Comprehensive library of cognitive science guides covering reaction time, memory, attention, executive function, spatial reasoning, and motor skill training.",
  "provider": {
    "@type": "Organization",
    "name": "CogniArena",
    "url": "https://cogniarena.com"
  },
  "about": {
    "@type": "Thing",
    "name": "Cognitive Science"
  },
  "hasPart": [
    { "@type": "Article", "name": "Reaction Time Science", "url": "https://cogniarena.com/learn/reaction-time" },
    { "@type": "Article", "name": "Click Speed Science", "url": "https://cogniarena.com/learn/click-speed" },
    { "@type": "Article", "name": "Aim Training Science", "url": "https://cogniarena.com/learn/aim-training" },
    { "@type": "Article", "name": "Memory Science", "url": "https://cogniarena.com/learn/memory-test" },
    { "@type": "Article", "name": "Choice Reaction Time", "url": "https://cogniarena.com/learn/choice-reaction" },
    { "@type": "Article", "name": "Peripheral Vision", "url": "https://cogniarena.com/learn/f1-lights" },
    { "@type": "Article", "name": "Visual Tracking", "url": "https://cogniarena.com/learn/flick-trainer" },
    { "@type": "Article", "name": "Fine Motor Control", "url": "https://cogniarena.com/learn/mouse-accuracy" },
    { "@type": "Article", "name": "Auditory Processing", "url": "https://cogniarena.com/learn/sound-reaction" },
    { "@type": "Article", "name": "Dual N-Back Training", "url": "https://cogniarena.com/learn/dual-n-back" },
    { "@type": "Article", "name": "Number Memory", "url": "https://cogniarena.com/learn/number-memory" },
    { "@type": "Article", "name": "Sequence Memory", "url": "https://cogniarena.com/learn/sequence-memory" },
    { "@type": "Article", "name": "Verbal Recall", "url": "https://cogniarena.com/learn/verbal-memory" },
    { "@type": "Article", "name": "Visual Pattern Recognition", "url": "https://cogniarena.com/learn/visual-pattern" },
    { "@type": "Article", "name": "Executive Planning", "url": "https://cogniarena.com/learn/planning" },
    { "@type": "Article", "name": "Task Prioritization", "url": "https://cogniarena.com/learn/prioritization" },
    { "@type": "Article", "name": "Stroop Effect", "url": "https://cogniarena.com/learn/stroop" },
    { "@type": "Article", "name": "Cognitive Set Shifting", "url": "https://cogniarena.com/learn/trail-making" },
    { "@type": "Article", "name": "Mental Rotation", "url": "https://cogniarena.com/learn/spatial-orientation" },
    { "@type": "Article", "name": "Processing Speed", "url": "https://cogniarena.com/learn/decision-speed" }
  ]
};

const categories = [
  {
    name: "Reflex & Motor Skills",
    icon: "⚡",
    guides: [
      { href: "/learn/reaction-time", icon: "🧠", title: "Reaction Time Science", desc: "Visual and auditory reflex pathways, Hick's Law, and paint-sync calibration protocols." },
      { href: "/learn/click-speed", icon: "🖱️", title: "Click Speed (CPS)", desc: "Muscle activation jitter, polling rate benchmarks, and mechanical switch latency analysis." },
      { href: "/learn/aim-training", icon: "🎯", title: "Aim Training", desc: "Fitts's Law, hand-eye feedback loops, and spatial targeting precision." },
      { href: "/learn/choice-reaction", icon: "🔀", title: "Choice Reaction Time", desc: "Decision complexity, Hick's Law logarithmic scaling, and multi-stimulus discrimination." },
      { href: "/learn/f1-lights", icon: "💡", title: "Peripheral Vision", desc: "Stimulus discrimination across visual field, retinal processing, and peripheral awareness." },
      { href: "/learn/flick-trainer", icon: "🔄", title: "Visual Tracking", desc: "Smooth pursuit eye movements, motion prediction, and gaze stabilization." },
      { href: "/learn/mouse-accuracy", icon: "🖲️", title: "Fine Motor Control", desc: "Sub-pixel targeting, motor unit recruitment, and precision grip optimization." },
      { href: "/learn/sound-reaction", icon: "🔊", title: "Auditory Processing", desc: "Auditory transduction speed, sound localization, and cross-modal integration." },
    ]
  },
  {
    name: "Memory & Pattern Recognition",
    icon: "🧩",
    guides: [
      { href: "/learn/memory-test", icon: "🗂️", title: "Memory Systems", desc: "Miller's Law, visuospatial chunking, and short-term vs working memory." },
      { href: "/learn/dual-n-back", icon: "2️⃣", title: "Dual N-Back", desc: "Working memory updating, dual-task interference, and transfer effects." },
      { href: "/learn/number-memory", icon: "🔢", title: "Number Memory", desc: "Digit span limits, chunking strategies, and the phonological loop." },
      { href: "/learn/sequence-memory", icon: "📋", title: "Sequence Memory", desc: "Serial position effects, pattern encoding, and sequence recall." },
      { href: "/learn/verbal-memory", icon: "💬", title: "Verbal Recall", desc: "Phonological loop capacity, word span, and language-based memory." },
      { href: "/learn/visual-pattern", icon: "👁️", title: "Visual Pattern Recognition", desc: "Gestalt principles, pattern completion, and visual feature extraction." },
    ]
  },
  {
    name: "Executive Function & Processing",
    icon: "🧠",
    guides: [
      { href: "/learn/planning", icon: "♟️", title: "Executive Planning", desc: "Tower of Hanoi, problem-solving strategies, and prefrontal planning." },
      { href: "/learn/prioritization", icon: "📊", title: "Task Prioritization", desc: "Cognitive flexibility, task scheduling, and attentional resource allocation." },
      { href: "/learn/stroop", icon: "🎨", title: "Stroop Effect", desc: "Cognitive inhibition, automaticity, and interference resolution." },
      { href: "/learn/trail-making", icon: "🔗", title: "Cognitive Set Shifting", desc: "Mental flexibility, alternating attention, and task switching costs." },
      { href: "/learn/spatial-orientation", icon: "🧭", title: "Mental Rotation", desc: "Spatial ability, mental transformation, and visuospatial processing." },
      { href: "/learn/decision-speed", icon: "⚡", title: "Processing Speed", desc: "Information processing rate, binary classification, and cognitive throughput." },
    ]
  },
];
---
<Layout title={title} description={description} canonicalUrl={canonicalUrl} schemaJson={schemaJson}>
  <div class="flex flex-col gap-12 w-full max-w-4xl mx-auto">
    <header class="flex flex-col gap-4">
      <div class="flex items-center gap-2 text-xs font-mono uppercase tracking-widest text-accent">
        <span>Learning Center</span>
        <span>&middot;</span>
        <span>Hub</span>
      </div>
      <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight text-foreground animate-fade-in">
        Cognitive Science & Training Guides
      </h1>
      <p class="text-muted text-sm md:text-base leading-relaxed max-w-3xl">
        Evidence-based guides covering the neuroscience behind every CogniArena assessment.
        Each guide explains the biological pathways, scientific principles, and practical training
        protocols for measuring and improving cognitive performance.
      </p>
    </header>

    {categories.map((category) => (
      <section class="flex flex-col gap-6">
        <h2 class="text-xl font-bold text-foreground tracking-tight flex items-center gap-2">
          <span>{category.icon}</span>
          <span>{category.name}</span>
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {category.guides.map((guide) => (
            <a
              href={guide.href}
              class="flex items-start gap-3 p-4 rounded-xl border border-card-border bg-subtle hover:bg-accent/5 hover:border-accent/30 transition-standard group"
            >
              <span class="text-lg mt-0.5 shrink-0">{guide.icon}</span>
              <div class="flex flex-col gap-1 min-w-0">
                <span class="text-sm font-semibold text-foreground group-hover:text-accent transition-colors truncate">{guide.title}</span>
                <span class="text-xs text-muted leading-relaxed line-clamp-2">{guide.desc}</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    ))}

    <section class="flex flex-col gap-4 border-t border-card-border pt-8">
      <h2 class="text-lg font-bold text-foreground tracking-tight">Why Cognitive Training?</h2>
      <p class="text-sm text-muted leading-relaxed max-w-3xl">
        Cognitive training is the structured practice of mental processes to enhance performance in specific domains.
        Research in neuroscience demonstrates that targeted cognitive exercises can improve processing speed, working memory
        capacity, and executive function through mechanisms of neuroplasticity. Each guide on this page links your assessment
        results to the underlying cognitive science, giving you a clear framework for understanding your strengths and
        targeting areas for improvement.
      </p>
    </section>
  </div>
</Layout>
