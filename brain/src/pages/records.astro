---
import Layout from "@/layouts/main.astro";
import PersonalRecords from "@/components/dashboard/PersonalRecords";

const title = "Personal Records - CogniArena";
const description = "View your personal best scores across all tests and track your cognitive performance achievements.";
const canonicalUrl = "https://cogniarena.com/records";

const schemaJson = [
  { "@context": "https://schema.org", "@type": "WebPage", "name": title, "description": description, "url": canonicalUrl },
  { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://cogniarena.com" },
    { "@type": "ListItem", "position": 2, "name": "Personal Records", "item": "https://cogniarena.com/records" }
  ]}
];
---

<Layout title={title} description={description} canonicalUrl={canonicalUrl} schemaJson={schemaJson}>
  <div class="space-y-6">
    <div>
      <h1 class="text-2xl font-bold text-foreground mb-2" data-i18n="records.title">Personal Records</h1>
      <p class="text-sm text-muted" data-i18n="records.desc">Your best scores across all tests. Keep improving to set new records!</p>
    </div>
    
    <PersonalRecords client:load />
  </div>
</Layout>
