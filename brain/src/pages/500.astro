---
import Layout from "@/layouts/main.astro";
import { Button } from "@/components/ui/button";

const title = "500: Internal Server Error | BrainBenchmarks";
const description = "An internal server error occurred on BrainBenchmarks. Please try again or contact support if the issue persists.";
---

<Layout title={title} description={description}>
  <div class="flex flex-col items-center justify-center text-center py-16 px-4 max-w-md mx-auto gap-6">
    <div class="w-20 h-20 rounded-full bg-rose-500/10 border border-rose-500/20 flex items-center justify-center text-4xl">
      🚨
    </div>
    <div class="flex flex-col gap-2">
      <span class="text-xs font-mono uppercase tracking-widest text-rose-500">Error 500</span>
      <h1 class="text-3xl font-extrabold tracking-tight text-foreground">Internal Error</h1>
      <p class="text-zinc-550 dark:text-zinc-400 text-sm leading-relaxed">
        An unexpected telemetry processing exception occurred. Local browser metrics remain safe in IndexedDB.
      </p>
    </div>
    <div class="flex flex-col sm:flex-row gap-3 w-full mt-2">
      <a href="/" class="w-full">
        <Button variant="primary" className="w-full">Return Home</Button>
      </a>
      <a href="/contact" class="w-full">
        <Button variant="secondary" className="w-full">Contact Support</Button>
      </a>
    </div>
  </div>
</Layout>
