---
import Layout from "@/layouts/main.astro";
---
<Layout title="Server Error - CogniArena">
  <div class="max-w-md w-full text-center space-y-6 mx-auto mt-20">
    <div class="text-6xl font-bold text-error">500</div>
    <h1 class="text-2xl font-bold text-foreground">Something Went Wrong</h1>
    <p class="text-muted text-sm">
      We're experiencing technical difficulties. Please try again later.
    </p>
    
    <div class="flex flex-col gap-3 pt-4">
      <button
        onclick="window.location.reload()"
        class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-md bg-accent text-white font-medium hover:opacity-90 transition-opacity"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/><path d="M16 16h5v5"/></svg>
        Try Again
      </button>
      
      <a
        href="/"
        class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-md border border-card-border text-muted hover:text-foreground hover:bg-subtle font-medium transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></polyline></svg>
        Go Home
      </a>
    </div>

    <div class="pt-8 border-t border-card-border/40">
      <p class="text-xs text-muted">
        If the problem persists, please{' '}
        <a href="/contact" class="text-accent hover:underline">contact us</a>
      </p>
    </div>
  </div>
</Layout>
