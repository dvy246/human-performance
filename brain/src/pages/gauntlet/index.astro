---
import Layout from "@/layouts/main.astro"
import GauntletTest from "@/components/tests/GauntletTest"
import ExploreTests from "@/components/ui/ExploreTests.astro"
import HowItWorks from "@/components/ui/HowItWorks.astro"

const title = "The Gauntlet – 5-Stage Cognitive Assessment | CogniArena"
const description =
  "The ultimate 5-minute cognitive gauntlet: reaction speed, sequence memory, Stroop interference, matrix reasoning, and aim precision. Get your CAI score and performance archetype."
const canonicalUrl = "https://cogniarena.com/gauntlet"

const schemaJson = [
  {
    "@context": "https://schema.org",
    "@type": "Quiz",
    name: "The Gauntlet — CogniArena Flagship Assessment",
    description:
      "A five-stage sequential cognitive assessment measuring reaction, memory, focus, reasoning, and precision.",
    about: { "@type": "Thing", name: "Multi-Domain Cognitive Performance" },
    timeRequired: "PT4M",
    assesses: [
      "Reaction Speed",
      "Sequence Memory",
      "Stroop Interference",
      "Matrix Reasoning",
      "Aim Precision",
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: "https://cogniarena.com",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "The Gauntlet",
        item: "https://cogniarena.com/gauntlet",
      },
    ],
  },
]
---

<Layout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  schemaJson={schemaJson}
>
  <div class="mx-auto flex w-full max-w-3xl flex-col gap-12">
    <header class="flex flex-col gap-3">
      <nav
        class="flex items-center gap-2 font-mono text-xs tracking-widest text-accent uppercase"
        aria-label="Breadcrumb"
      >
        <a href="/" class="hover:underline">Home</a>
        <span>/</span>
        <span class="text-muted">The Gauntlet</span>
      </nav>
      <h1
        class="text-3xl font-extrabold tracking-tight text-foreground md:text-4xl"
        data-i18n="gaunt.title"
      >
        The Gauntlet
      </h1>
      <p
        class="max-w-2xl text-sm leading-relaxed text-muted md:text-base"
        data-i18n="gaunt.subtitle"
      >
        A <strong>5-stage cognitive gauntlet</strong>: reaction → memory → focus
        → logic → precision. Takes ~4 minutes and outputs a unified CogniArena
        Index score and performance archetype.
      </p>
    </header>
    <section class="w-full"><GauntletTest client:visible /></section>
    <div
      class="rounded-xl border border-card-border bg-subtle p-4 text-xs leading-relaxed text-muted shadow-sm"
    >
      <strong class="font-semibold text-foreground"
        >Self-Tracking Notice:</strong
      > For self-tracking, educational, and cognitive training purposes only. Not
      a clinical, medical, or diagnostic evaluation.
    </div>

    <HowItWorks
      testName="The Gauntlet"
      learnSlug="brain-training"
      learnTitle="Cognitive Training & Focus Science"
      whatItMeasures="A 5-stage composite cognitive assessment: visual reaction speed, sequence memory, Stroop interference, matrix reasoning, and aim precision. Measures your performance across five core cognitive domains in one continuous session."
      howScoringWorks="Each stage produces a score from 0-100. The overall CogniArena Index (CAI) is the average of all five stages. Your percentile compares your CAI against the full population distribution."
      whatAffectsResults="Your performance in your weakest domain constrains your overall score (the weakest link effect). Mental fatigue across stages, prior experience with each test type, and hardware quality all affect results."
    />

    <section class="flex flex-col gap-10 border-t border-card-border pt-12">
      <article class="flex flex-col gap-4">
        <h2
          class="text-xl font-semibold tracking-tight text-foreground"
          data-i18n="gaunt.what_title"
        >
          What is The Gauntlet?
        </h2>
        <p
          class="text-sm leading-relaxed text-muted"
          data-i18n="gaunt.what_desc"
        >
          The Gauntlet is CogniArena' flagship multi-domain cognitive
          assessment. Unlike single-metric tests, it challenges <strong
            >five different cognitive dimensions</strong
          > in one continuous session, producing a unified CogniArena Index (CAI)
          score and a personalized performance archetype.
        </p>
      </article>
      <article class="flex flex-col gap-4">
        <h2
          class="text-xl font-semibold tracking-tight text-foreground"
          data-i18n="gaunt.stages_title"
        >
          The 5 Stages
        </h2>
        <div class="grid gap-3">
          <div
            class="flex items-center gap-3 rounded-lg border border-card-border bg-card p-3"
          >
            <span class="text-lg">⚡</span><div>
              <h3 class="text-sm font-bold text-foreground">
                1. Visual Reaction
              </h3><p class="text-xs text-secondary">
                Raw sensorimotor reflex speed — 5 trials of click-on-green
              </p>
            </div>
          </div>
          <div
            class="flex items-center gap-3 rounded-lg border border-card-border bg-card p-3"
          >
            <span class="text-lg">🗂️</span><div>
              <h3 class="text-sm font-bold text-foreground">
                2. Sequence Memory
              </h3><p class="text-xs text-secondary">
                Grid pattern recall with increasing length — tests working
                memory capacity
              </p>
            </div>
          </div>
          <div
            class="flex items-center gap-3 rounded-lg border border-card-border bg-card p-3"
          >
            <span class="text-lg">🎨</span><div>
              <h3 class="text-sm font-bold text-foreground">
                3. Stroop Test
              </h3><p class="text-xs text-secondary">
                Color-word interference — measures cognitive inhibition and
                selective attention
              </p>
            </div>
          </div>
          <div
            class="flex items-center gap-3 rounded-lg border border-card-border bg-card p-3"
          >
            <span class="text-lg">🧩</span><div>
              <h3 class="text-sm font-bold text-foreground">
                4. Matrix Reasoning
              </h3><p class="text-xs text-secondary">
                Pattern completion — tests fluid logic and abstract reasoning
              </p>
            </div>
          </div>
          <div
            class="flex items-center gap-3 rounded-lg border border-card-border bg-card p-3"
          >
            <span class="text-lg">🎯</span><div>
              <h3 class="text-sm font-bold text-foreground">
                5. Aim Precision
              </h3><p class="text-xs text-secondary">
                Target clicking accuracy — measures fine motor control and
                hand-eye coordination
              </p>
            </div>
          </div>
        </div>
      </article>
      <article class="flex flex-col gap-6">
        <h2
          class="text-xl font-semibold tracking-tight text-foreground"
          data-i18n="gaunt.faq_title"
        >
          Frequently Asked Questions
        </h2>
        <div class="flex flex-col gap-4">
          <div class="flex flex-col gap-1.5">
            <h3 class="text-sm font-medium text-foreground">
              How is the CAI score calculated?
            </h3>
            <p class="text-sm leading-relaxed text-muted">
              Each stage produces a score from 0-100 based on accuracy and speed
              metrics. The overall CAI is the average of all five. Your
              percentile compares your CAI against all other users.
            </p>
          </div>
          <div class="flex flex-col gap-1.5">
            <h3 class="text-sm font-medium text-foreground">
              Can I take the stages individually?
            </h3>
            <p class="text-sm leading-relaxed text-muted">
              Yes! Each test is available separately in the <a
                href="/tests/reaction-time"
                class="text-accent hover:underline">Reaction</a
              >, <a
                href="/tests/sequence-memory"
                class="text-accent hover:underline">Memory</a
              >, <a href="/tests/stroop" class="text-accent hover:underline"
                >Focus</a
              >, <a
                href="/tests/pattern-reasoning"
                class="text-accent hover:underline">Reasoning</a
              >, and <a
                href="/tests/aim-trainer"
                class="text-accent hover:underline">Precision</a
              > sections.
            </p>
          </div>
        </div>
      </article>
    </section>

    <ExploreTests
      currentSlug="gauntlet"
      title="Explore Individual Assessments"
    />
  </div>
</Layout>
