---
import Layout from "@/layouts/main.astro"
---

<Layout title="Page Not Found - CogniArena" robots="noindex, nofollow">
  <div class="mx-auto mt-20 w-full max-w-md space-y-6 text-center">
    <div class="text-6xl font-bold text-accent">404</div>
    <h1 class="text-2xl font-bold text-foreground">Page Not Found</h1>
    <p class="text-sm text-muted">
      The page you're looking for doesn't exist or has been moved.
    </p>

    <div class="flex flex-col gap-3 pt-4">
      <a
        href="/"
        class="inline-flex items-center justify-center gap-2 rounded-md bg-accent px-6 py-3 font-medium text-white transition-opacity hover:opacity-90"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"
          ></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg
        ></a
      >
      Go Home
    </div>

    <a
      href="/tests/reaction-time"
      class="inline-flex items-center justify-center gap-2 rounded-md border border-card-border px-6 py-3 font-medium text-muted transition-colors hover:bg-subtle hover:text-foreground"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><circle cx="12" cy="12" r="10"></circle><polyline
          points="12 6 12 12 16 14"></polyline></svg
      ></a
    >
    Take a Test
  </div>
</Layout>

<div class="border-t border-card-border/40 pt-8">
  <p class="text-xs text-muted">
    Looking for something specific? Try our{" "}
    <a href="/learn/reaction-time" class="text-accent hover:underline"
      >Learning Center</a
    >{" "}
    or{" "}
    <a href="/benchmarks" class="text-accent hover:underline">Benchmarks</a>
  </p>
</div>
