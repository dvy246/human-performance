---
import Layout from "@/layouts/main.astro";
import { Button } from "@/components/ui/button";

const title = "404: Page Not Found | BrainBenchmarks";
const description = "The requested page was not found on BrainBenchmarks. Return home to benchmark your reaction, memory, and precision.";
---

<Layout title={title} description={description}>
  <div class="flex flex-col items-center justify-center text-center py-16 px-4 max-w-md mx-auto gap-6">
    <div class="w-20 h-20 rounded-full bg-accent/10 border border-accent/20 flex items-center justify-center text-4xl animate-bounce">
      🧩
    </div>
    <div class="flex flex-col gap-2">
      <span class="text-xs font-mono uppercase tracking-widest text-zinc-500">Error 404</span>
      <h1 class="text-3xl font-extrabold tracking-tight text-foreground">Page Not Found</h1>
      <p class="text-zinc-550 dark:text-zinc-400 text-sm leading-relaxed">
        The benchmark route you are trying to access does not exist, has been removed, or is undergoing calibration.
      </p>
    </div>
    <div class="flex flex-col sm:flex-row gap-3 w-full mt-2">
      <a href="/" class="w-full">
        <Button variant="primary" className="w-full">Return Home</Button>
      </a>
      <a href="/dashboard" class="w-full">
        <Button variant="secondary" className="w-full">View Dashboard</Button>
      </a>
    </div>
  </div>
</Layout>
