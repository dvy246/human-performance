---
import Layout from "@/layouts/main.astro"
import TestResultsPage from "@/components/ui/TestResultsPage"

const title = "Test Results — CogniArena"
const description =
  "View your detailed cognitive test results with attempt breakdowns, performance trends, and personalized insights."
const canonicalUrl = "https://cogniarena.com/tests/results"
---

<Layout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  robots="noindex, nofollow"
>
  <div class="mx-auto flex w-full max-w-3xl flex-col gap-8">
    <TestResultsPage client:load />
  </div>
</Layout>
