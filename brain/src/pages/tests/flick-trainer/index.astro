---
import Layout from "@/layouts/main.astro"
import FlickTrainerTest from "@/components/tests/FlickTrainerTest"
import ExploreTests from "@/components/ui/ExploreTests.astro"
import HowItWorks from "@/components/ui/HowItWorks.astro"

const title = "Flick Trainer – Speed & Accuracy | CogniArena"
const description =
  "Test your flick aiming speed and accuracy. Rapidly flick to random targets and click. Track improvement in target acquisition latency and click precision over time."
const canonicalUrl = "https://cogniarena.com/tests/flick-trainer"

const schemaJson = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    applicationCategory: "GameApplication",
    name: "Flick Trainer",
    description:
      "Speed and accuracy flick-aiming assessment measuring rapid target acquisition.",
    about: { "@type": "Thing", name: "Motor Coordination" },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
      {
        "@type": "Question",
        name: "What is flick speed?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Flick speed measures how quickly you can move your cursor from one position to a new target and click. It combines reaction time, mouse control, and click timing into a single metric.",
        },
      },
      {
        "@type": "Question",
        name: "How does this differ from the Aim Trainer?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "The Aim Trainer uses shrinking targets that reward precision over speed. Flick Trainer uses instant-appearing targets that reward fast cursor acceleration and deceleration — the two skills engage different motor control pathways.",
        },
      },
      {
        "@type": "Question",
        name: "Is this a medical diagnostic tool?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "No. This test is designed for self-tracking, performance benchmarking, and entertainment purposes. It is not a clinical cognitive assessment.",
        },
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: "https://cogniarena.com",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Motor",
        item: "https://cogniarena.com/",
      },
      {
        "@type": "ListItem",
        position: 3,
        name: "Flick Trainer",
        item: "https://cogniarena.com/tests/flick-trainer",
      },
    ],
  },
]
---

<Layout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  schemaJson={schemaJson}
>
  <div class="mx-auto flex w-full max-w-3xl flex-col gap-12">
    <header class="flex flex-col gap-3">
      <nav
        class="flex items-center gap-2 font-mono text-xs tracking-widest text-accent uppercase"
        aria-label="Breadcrumb"
      >
        <a href="/" class="hover:underline">Home</a><span>/</span><a
          href="/tests"
          class="hover:underline">Tests</a
        ><span>/</span><span class="text-muted">Flick Trainer</span>
      </nav>
      <h1
        class="text-3xl font-extrabold tracking-tight text-foreground md:text-4xl"
      >
        Flick Trainer
      </h1>
      <p class="max-w-2xl text-sm leading-relaxed text-muted md:text-base">
        Flick your mouse to 15 targets appearing at random positions. Measures
        flick speed and click accuracy — the two components of precise aim.
      </p>
    </header>
    <section class="w-full"><FlickTrainerTest client:visible /></section>

    <HowItWorks
      testName="the Flick Trainer"
      learnSlug="flick-trainer"
      learnTitle="Visual Tracking Science"
      whatItMeasures="Tests flick aiming — rapidly moving the cursor to a random target and clicking. Simulates the fast target acquisition movements used in competitive gaming and rapid-response scenarios."
      howScoringWorks="Score combines movement time (speed of the flick) and click accuracy (offset from target center). A composite flick efficiency score balances speed and precision."
      whatAffectsResults="Mouse sensitivity (DPI), hand-eye coordination, mousepad surface area, and monitor refresh rate all affect your flick performance."
    />

    <!-- What Affects Your Score -->
    <article class="flex flex-col gap-4">
      <h2 class="text-xl font-semibold tracking-tight text-foreground">
        What Affects Your Flick Score
      </h2>
      <ul
        class="flex list-inside list-disc flex-col gap-2 text-sm leading-relaxed text-muted"
      >
        <li>
          <strong class="text-foreground">Mouse sensitivity (DPI)</strong> — higher
          DPI enables faster cursor travel but reduces precision for small targets
        </li>
        <li>
          <strong class="text-foreground">Hand-eye coordination</strong> — the speed
          at which your visual system guides motor corrections to the target
        </li>
        <li>
          <strong class="text-foreground">Mousepad surface area</strong> — more space
          allows larger arm movements instead of wrist-only adjustments
        </li>
        <li>
          <strong class="text-foreground">Monitor refresh rate</strong> — higher Hz
          reduces the delay between target appearance and your perception of it
        </li>
      </ul>
    </article>

    <ExploreTests currentSlug="flick-trainer" />

    <!-- FAQ Section -->
    <article class="flex flex-col gap-6">
      <h2 class="text-xl font-semibold tracking-tight text-foreground">
        Frequently Asked Questions
      </h2>
      <div class="flex flex-col gap-4">
        <div class="flex flex-col gap-1.5">
          <h3 class="text-sm font-medium text-foreground">
            What is flick speed?
          </h3>
          <p class="text-sm leading-relaxed text-muted">
            Flick speed measures how quickly you can move your cursor from one
            position to a new target and click. It combines reaction time, mouse
            control, and click timing into a single metric.
          </p>
        </div>
        <div class="flex flex-col gap-1.5">
          <h3 class="text-sm font-medium text-foreground">
            How does this differ from the Aim Trainer?
          </h3>
          <p class="text-sm leading-relaxed text-muted">
            The Aim Trainer uses shrinking targets that reward precision over
            speed. Flick Trainer uses instant-appearing targets that reward fast
            cursor acceleration and deceleration — the two skills engage
            different motor control pathways.
          </p>
        </div>
        <div class="flex flex-col gap-1.5">
          <h3 class="text-sm font-medium text-foreground">
            Is this a medical diagnostic tool?
          </h3>
          <p class="text-sm leading-relaxed text-muted">
            No. This test is designed for self-tracking, performance
            benchmarking, and entertainment purposes. It is not a clinical
            cognitive assessment.
          </p>
        </div>
      </div>
    </article>

    <div
      class="rounded-xl border border-card-border bg-subtle p-4 text-xs leading-relaxed text-muted shadow-sm"
    >
      <strong class="font-semibold text-foreground"
        >Self-Tracking Notice:</strong
      > For self-tracking and educational purposes only. Not a clinical or diagnostic
      evaluation.
    </div>
  </div>
</Layout>
