---
import Layout from "@/layouts/main.astro"
import PatternReasoningTest from "@/components/tests/PatternReasoningTest"
import ExploreTests from "@/components/ui/ExploreTests.astro"
import HowItWorks from "@/components/ui/HowItWorks.astro"

const title =
  "Pattern Reasoning Test — Fluid Intelligence Assessment | CogniArena"
const description =
  "Evaluate your visual pattern recognition, logical reasoning, and fluid intelligence. Complete geometric progressions and matrix puzzles with millisecond precision."
const canonicalUrl = "https://cogniarena.com/tests/pattern-reasoning"

const schemaJson = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    applicationCategory: "GameApplication",
    name: "Pattern Reasoning Test",
    description:
      "Assess fluid visual reasoning and logical pattern completions.",
    about: {
      "@type": "Thing",
      name: "Fluid Intelligence & Logic",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: "https://cogniarena.com",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Tests",
        item: "https://cogniarena.com/tests",
      },
      {
        "@type": "ListItem",
        position: 3,
        name: "Pattern Reasoning Test",
        item: "https://cogniarena.com/tests/pattern-reasoning",
      },
    ],
  },
]
---

<Layout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  schemaJson={schemaJson}
>
  <div class="mx-auto flex w-full max-w-3xl flex-col gap-12">
    <header class="flex flex-col gap-3">
      <nav
        class="flex items-center gap-2 font-mono text-xs tracking-widest text-accent uppercase"
        aria-label="Breadcrumb"
      >
        <a href="/" class="hover:underline">Home</a>
        <span>/</span>
        <a href="/tests" class="hover:underline">Tests</a>
        <span>/</span>
        <span class="text-muted">Pattern Reasoning Test</span>
      </nav>
      <h1
        class="text-3xl font-extrabold tracking-tight text-foreground md:text-4xl"
      >
        Pattern Reasoning Test
      </h1>
      <p class="max-w-2xl text-sm leading-relaxed text-muted md:text-base">
        Benchmark your fluid intelligence. Identify the logical symbol that
        completes each pattern sequence. Respond quickly and accurately to
        maximize your score.
      </p>
    </header>

    <section class="w-full">
      <PatternReasoningTest client:load />
    </section>

    <!-- Below the fold SEO and Methodology Content -->

    <!-- Medical/Scientific Disclaimer Notice -->
    <div
      class="rounded-xl border border-card-border bg-subtle p-4 text-xs leading-relaxed text-muted shadow-sm"
    >
      <strong class="font-semibold text-foreground"
        >Self-Tracking Notice:</strong
      > This assessment is for self-tracking, educational, and cognitive training
      purposes only. It is not a clinical, medical, diagnostic, or neuropsychological
      evaluation, and may be affected by display latency, input delays, or device
      configuration.
    </div>

    <section class="flex flex-col gap-10 border-t border-card-border pt-12">
      <HowItWorks
        testName="the Pattern Reasoning Test"
        learnSlug="iq-test"
        learnTitle="IQ & Fluid Intelligence Science"
        whatItMeasures="Evaluates fluid intelligence through multiple formats: pattern recognition (linear sequences), matrix reasoning (2x2 grids), sequence logic (numerical/rotational progressions), and shape analogies (morph transformations)."
        howScoringWorks="Score is accuracy across all formats, with faster correct responses weighted higher. This measures your ability to identify rules and apply transformations — the core of fluid reasoning (Gf)."
        whatAffectsResults="Your pattern recognition speed, experience with abstract reasoning puzzles, cognitive flexibility, and current mental fatigue all affect your reasoning score."
      />

      <article class="flex flex-col gap-4">
        <h2 class="text-xl font-bold tracking-tight text-foreground">
          Fluid Reasoning & Visual Pattern Recognition
        </h2>
        <p class="text-sm leading-relaxed text-secondary">
          Fluid intelligence represents your capacity to think logically and
          solve problems in novel situations, independent of acquired knowledge.
          Non-verbal matrix reasoning tests are widely recognized in cognitive
          neuroscience as strong indicators of fluid reasoning efficiency,
          requiring structural pattern matching and rule extraction.
        </p>
      </article>

      <article class="flex flex-col gap-4">
        <h2 class="text-xl font-bold tracking-tight text-foreground">
          Methodology and Scoring
        </h2>
        <p class="text-sm leading-relaxed text-secondary">
          The Pattern Reasoning test consists of 10 progressive sequence
          puzzles. Your score represents a composite of accuracy (number of
          correct completions) and speed (response latency per question).
          Answering quickly with high accuracy yields the highest performance
          index, indicating fast processing and accurate inductive reasoning.
        </p>
      </article>
    </section>

    <!-- What Affects Your Score -->
    <article class="flex flex-col gap-4">
      <h2 class="text-xl font-semibold tracking-tight text-foreground">
        What Affects Your Pattern Reasoning Score
      </h2>
      <ul
        class="flex list-inside list-disc flex-col gap-2 text-sm leading-relaxed text-muted"
      >
        <li>
          <strong class="text-foreground">Inductive reasoning ability</strong> — extracting
          underlying rules from visual sequences and applying them to novel patterns
        </li>
        <li>
          <strong class="text-foreground">Pattern vocabulary</strong> — familiarity
          with common pattern types (rotation, progression, XOR, reflection)
        </li>
        <li>
          <strong class="text-foreground">Processing speed</strong> — how quickly
          you can analyze and compare visual elements
        </li>
        <li>
          <strong class="text-foreground">Display latency</strong> — slower monitors
          add minor overhead to pattern recognition
        </li>
      </ul>
    </article>

    <ExploreTests currentSlug="pattern-reasoning" />

    </div>
</Layout>
