---
import Layout from "@/layouts/main.astro";
import StroopTest from "@/components/tests/StroopTest";

const title = "Stroop Attention Test — Cognitive Interference Assessment | CogniArena";
const description = "Benchmark your selective attention, impulse control, and processing speed with the classic Stroop color-conflict test. Measure response latency and accuracy.";
const canonicalUrl = "https://cogniarena.com/tests/stroop";

const schemaJson = {
  "@context": "https://schema.org",
  "@type": "Quiz",
  "name": "Stroop Attention Test",
  "description": "Assess cognitive interference control and response inhibition speeds.",
  "about": {
    "@type": "Thing",
    "name": "Attention & Executive Control"
  }
};
---

<Layout title={title} description={description} canonicalUrl={canonicalUrl} schemaJson={schemaJson}>
  <div class="flex flex-col gap-12 w-full max-w-3xl mx-auto">
    <header class="flex flex-col gap-3">
      <div class="flex items-center gap-2 text-xs font-mono uppercase tracking-widest text-accent">
        <span>Assessment Suite</span>
        <span>&middot;</span>
        <span>Attention & Executive Control</span>
      </div>
      <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight text-foreground">
        Stroop Attention Test
      </h1>
      <p class="text-zinc-550 dark:text-zinc-400 text-sm md:text-base leading-relaxed max-w-2xl">
        Test your selective attention limits and cognitive processing conflict resolution. Click the button matching the word's ink color, ignoring the text value.
      </p>
    </header>

    <section class="w-full">
      <StroopTest client:load />
    </section>

    <!-- Below the fold SEO and Methodology Content -->

      <!-- Medical/Scientific Disclaimer Notice -->
      <div class="p-4 rounded-xl border border-card-border bg-subtle text-xs text-zinc-550 dark:text-zinc-400 leading-relaxed shadow-sm">
        <strong class="text-foreground font-semibold">Self-Tracking Notice:</strong> This assessment is for self-tracking, educational, and cognitive training purposes only. It is not a clinical, medical, diagnostic, or neuropsychological evaluation, and may be affected by display latency, input delays, or device configuration.
      </div>

    <section class="flex flex-col gap-10 border-t border-card-border pt-12">
      <article class="flex flex-col gap-4">
        <h2 class="text-xl font-bold text-foreground tracking-tight">Understanding the Stroop Effect</h2>
        <p class="text-zinc-450 text-sm leading-relaxed">
          The Stroop effect demonstrates the cognitive friction caused by word-color mismatches. When a word like "RED" is printed in green ink, your brain automatically reads the text before processing the visual color. This creates cognitive conflict that must be resolved by executive control systems in the prefrontal cortex, leading to increased response latencies.
        </p>
      </article>

      <article class="flex flex-col gap-4">
        <h2 class="text-xl font-bold text-foreground tracking-tight">Selective Attention Training</h2>
        <p class="text-zinc-450 text-sm leading-relaxed">
          Regularly practicing interference control tasks helps strengthen selective focus, impulse inhibition, and attention gating. Standardized browser assessments record congruent trials (matching ink/word) and incongruent trials (mismatched ink/word) to isolate the exact cognitive processing overhead in milliseconds.
        </p>
      </article>
    </section>
  </div>
</Layout>
