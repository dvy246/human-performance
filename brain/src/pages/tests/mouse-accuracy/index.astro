---
import Layout from "@/layouts/main.astro"
import MouseAccuracyTest from "@/components/tests/MouseAccuracyTest"
import ExploreTests from "@/components/ui/ExploreTests.astro"
import HowItWorks from "@/components/ui/HowItWorks.astro"

const title = "Mouse Accuracy Test – Precision Clicking | CogniArena"
const description =
  "Test your mouse precision by clicking shrinking targets. Measures fine motor control and hand-eye coordination. Compare your accuracy against population benchmarks."
const canonicalUrl = "https://cogniarena.com/tests/mouse-accuracy"

const schemaJson = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    applicationCategory: "GameApplication",
    name: "Mouse Accuracy Test",
    description:
      "Fine motor precision assessment measuring average pixel offset from target center.",
    about: { "@type": "Thing", name: "Motor Coordination" },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
      {
        "@type": "Question",
        name: "How is offset measured?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Each click records the pixel distance between where you clicked and the exact center of the target. Your final score is the average offset across all targets — lower is better.",
        },
      },
      {
        "@type": "Question",
        name: "What DPI should I use?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Lower DPI (400-800) generally produces better accuracy because it forces you to use arm movements instead of wrist jitter. Higher DPI amplifies small hand tremors, increasing offset errors.",
        },
      },
      {
        "@type": "Question",
        name: "Is this a medical diagnostic tool?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "No. This test is designed for self-tracking, performance benchmarking, and entertainment purposes. It is not a clinical cognitive assessment.",
        },
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: "https://cogniarena.com",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Motor",
        item: "https://cogniarena.com/",
      },
      {
        "@type": "ListItem",
        position: 3,
        name: "Mouse Accuracy Test",
        item: "https://cogniarena.com/tests/mouse-accuracy",
      },
    ],
  },
]
---

<Layout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  schemaJson={schemaJson}
>
  <div class="mx-auto flex w-full max-w-3xl flex-col gap-12">
    <header class="flex flex-col gap-3">
      <nav
        class="flex items-center gap-2 font-mono text-xs tracking-widest text-accent uppercase"
        aria-label="Breadcrumb"
      >
        <a href="/" class="hover:underline">Home</a><span>/</span><a
          href="/tests"
          class="hover:underline">Tests</a
        ><span>/</span><span class="text-muted">Mouse Accuracy Test</span>
      </nav>
      <h1
        class="text-3xl font-extrabold tracking-tight text-foreground md:text-4xl"
      >
        Mouse Accuracy Test
      </h1>
      <p class="max-w-2xl text-sm leading-relaxed text-muted md:text-base">
        Click the center of each target as they shrink from 80px to 16px. Your
        average offset in pixels measures your fine motor precision.
      </p>
    </header>
    <section class="w-full"><MouseAccuracyTest client:visible /></section>

    <HowItWorks
      testName="the Mouse Accuracy Test"
      learnSlug="mouse-accuracy"
      learnTitle="Fine Motor Control Science"
      whatItMeasures="Measures fine motor precision by presenting targets that shrink from 80px to 16px. You must click the center of each target. Smaller targets require greater precision and steadier mouse control."
      howScoringWorks="Score tracks click offset error (pixels from center). Smaller average offset indicates better fine motor control. Performance is governed by Fitts's Law — smaller targets naturally produce larger offset errors."
      whatAffectsResults="Mouse DPI settings, hand steadiness, visual acuity, and mouse surface consistency all affect your accuracy score. A consistent low-friction mousepad improves control repeatability."
    />

    <!-- What Affects Your Score -->
    <article class="flex flex-col gap-4">
      <h2 class="text-xl font-semibold tracking-tight text-foreground">
        What Affects Your Accuracy Score
      </h2>
      <ul
        class="flex list-inside list-disc flex-col gap-2 text-sm leading-relaxed text-muted"
      >
        <li>
          <strong class="text-foreground">Mouse DPI settings</strong> — lower DPI
          (400-800) reduces hand tremor amplification for tighter clicks
        </li>
        <li>
          <strong class="text-foreground">Hand steadiness</strong> — caffeine, fatigue,
          and temperature affect fine motor tremor
        </li>
        <li>
          <strong class="text-foreground">Visual acuity</strong> — sharper displays
          make target centers easier to identify precisely
        </li>
        <li>
          <strong class="text-foreground">Mouse surface</strong> — a consistent, low-friction
          mousepad improves control repeatability
        </li>
      </ul>
    </article>

    <ExploreTests currentSlug="mouse-accuracy" />

    <!-- FAQ Section -->
    <article class="flex flex-col gap-6">
      <h2 class="text-xl font-semibold tracking-tight text-foreground">
        Frequently Asked Questions
      </h2>
      <div class="flex flex-col gap-4">
        <div class="flex flex-col gap-1.5">
          <h3 class="text-sm font-medium text-foreground">
            How is offset measured?
          </h3>
          <p class="text-sm leading-relaxed text-muted">
            Each click records the pixel distance between where you clicked and
            the exact center of the target. Your final score is the average
            offset across all targets — lower is better.
          </p>
        </div>
        <div class="flex flex-col gap-1.5">
          <h3 class="text-sm font-medium text-foreground">
            What DPI should I use?
          </h3>
          <p class="text-sm leading-relaxed text-muted">
            Lower DPI (400-800) generally produces better accuracy because it
            forces you to use arm movements instead of wrist jitter. Higher DPI
            amplifies small hand tremors, increasing offset errors.
          </p>
        </div>
        <div class="flex flex-col gap-1.5">
          <h3 class="text-sm font-medium text-foreground">
            Is this a medical diagnostic tool?
          </h3>
          <p class="text-sm leading-relaxed text-muted">
            No. This test is designed for self-tracking, performance
            benchmarking, and entertainment purposes. It is not a clinical
            cognitive assessment.
          </p>
        </div>
      </div>
    </article>

    <div
      class="rounded-xl border border-card-border bg-subtle p-4 text-xs leading-relaxed text-muted shadow-sm"
    >
      <strong class="font-semibold text-foreground"
        >Self-Tracking Notice:</strong
      > For self-tracking and educational purposes only. Not a clinical or diagnostic
      evaluation.
    </div>
  </div>
</Layout>
