---
import Layout from "@/layouts/main.astro";
import MouseAccuracyTest from "@/components/tests/MouseAccuracyTest";

const title = "Mouse Accuracy Test – Precision Clicking | CogniArena";
const description = "Test your mouse precision by clicking shrinking targets. Measures fine motor control and hand-eye coordination. Free online cognitive assessment.";
const canonicalUrl = "https://cogniarena.com/tests/mouse-accuracy";
---
<Layout title={title} description={description} canonicalUrl={canonicalUrl}>
  <div class="flex flex-col gap-12 w-full max-w-3xl mx-auto">
    <header class="flex flex-col gap-3">
      <div class="flex items-center gap-2 text-xs font-mono uppercase tracking-widest text-accent"><span>Assessment Suite</span><span>&middot;</span><span>Motor</span></div>
      <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight text-foreground">Mouse Accuracy Test</h1>
      <p class="text-zinc-500 dark:text-zinc-400 text-sm md:text-base leading-relaxed max-w-2xl">Click the center of each target as they shrink from 80px to 16px. Your average offset in pixels measures your fine motor precision.</p>
    </header>
    <section class="w-full"><MouseAccuracyTest client:visible /></section>
    <div class="p-4 rounded-xl border border-card-border bg-subtle text-xs text-zinc-500 dark:text-zinc-400 leading-relaxed shadow-sm">
      <strong class="text-foreground font-semibold">Self-Tracking Notice:</strong> For self-tracking and educational purposes only. Not a clinical or diagnostic evaluation.
    </div>
  </div>
</Layout>
