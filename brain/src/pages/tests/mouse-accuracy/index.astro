---
import Layout from "@/layouts/main.astro";
import MouseAccuracyTest from "@/components/tests/MouseAccuracyTest";

const title = "Mouse Accuracy Test – Precision Clicking | CogniArena";
const description = "Test your mouse precision by clicking shrinking targets. Measures fine motor control and hand-eye coordination. Compare your accuracy against population benchmarks.";
const canonicalUrl = "https://cogniarena.com/tests/mouse-accuracy";

const schemaJson = [
  { "@context": "https://schema.org", "@type": "SoftwareApplication", "applicationCategory": "GameApplication", "name": "Mouse Accuracy Test", "description": "Fine motor precision assessment measuring average pixel offset from target center.", "about": { "@type": "Thing", "name": "Motor Coordination" } },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [
    { "@type": "Question", "name": "How is offset measured?", "acceptedAnswer": { "@type": "Answer", "text": "Each click records the pixel distance between where you clicked and the exact center of the target. Your final score is the average offset across all targets — lower is better." } },
    { "@type": "Question", "name": "What DPI should I use?", "acceptedAnswer": { "@type": "Answer", "text": "Lower DPI (400-800) generally produces better accuracy because it forces you to use arm movements instead of wrist jitter. Higher DPI amplifies small hand tremors, increasing offset errors." } },
    { "@type": "Question", "name": "Is this a medical diagnostic tool?", "acceptedAnswer": { "@type": "Answer", "text": "No. This test is designed for self-tracking, performance benchmarking, and entertainment purposes. It is not a clinical cognitive assessment." } }
  ] },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://cogniarena.com" },
      { "@type": "ListItem", "position": 2, "name": "Motor", "item": "https://cogniarena.com/#suite" },
      { "@type": "ListItem", "position": 3, "name": "Mouse Accuracy Test", "item": "https://cogniarena.com/tests/mouse-accuracy" }
    ]
  }
];
---
<Layout title={title} description={description} canonicalUrl={canonicalUrl} schemaJson={schemaJson}>
  <div class="flex flex-col gap-12 w-full max-w-3xl mx-auto">
    <header class="flex flex-col gap-3">
      <nav class="flex items-center gap-2 text-xs font-mono uppercase tracking-widest text-accent" aria-label="Breadcrumb"><a href="/" class="hover:underline">Home</a><span>/</span><a href="/#suite" class="hover:underline">Tests</a><span>/</span><span class="text-muted">Mouse Accuracy Test</span></nav>
      <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight text-foreground">Mouse Accuracy Test</h1>
      <p class="text-muted text-sm md:text-base leading-relaxed max-w-2xl">Click the center of each target as they shrink from 80px to 16px. Your average offset in pixels measures your fine motor precision.</p>
    </header>
    <section class="w-full"><MouseAccuracyTest client:visible /></section>

    <!-- What Affects Your Score -->
    <article class="flex flex-col gap-4">
      <h2 class="text-xl font-semibold text-foreground tracking-tight">What Affects Your Accuracy Score</h2>
      <ul class="flex flex-col gap-2 text-muted text-sm leading-relaxed list-disc list-inside">
        <li><strong class="text-foreground">Mouse DPI settings</strong> — lower DPI (400-800) reduces hand tremor amplification for tighter clicks</li>
        <li><strong class="text-foreground">Hand steadiness</strong> — caffeine, fatigue, and temperature affect fine motor tremor</li>
        <li><strong class="text-foreground">Visual acuity</strong> — sharper displays make target centers easier to identify precisely</li>
        <li><strong class="text-foreground">Mouse surface</strong> — a consistent, low-friction mousepad improves control repeatability</li>
      </ul>
    </article>

    <!-- Related Tests -->
    <article class="flex flex-col gap-3">
      <h2 class="text-lg font-semibold text-foreground tracking-tight">Related Tests</h2>
      <div class="flex flex-wrap gap-2">
        <a href="/tests/aim-trainer" class="px-3 py-1.5 rounded-lg border border-card-border bg-subtle text-xs text-muted hover:border-accent hover:text-foreground transition-colors">Aim Trainer →</a>
        <a href="/tests/flick-trainer" class="px-3 py-1.5 rounded-lg border border-card-border bg-subtle text-xs text-muted hover:border-accent hover:text-foreground transition-colors">Flick Trainer →</a>
        <a href="/tests/click-speed" class="px-3 py-1.5 rounded-lg border border-card-border bg-subtle text-xs text-muted hover:border-accent hover:text-foreground transition-colors">Click Speed →</a>
      </div>
    </article>

    <!-- FAQ Section -->
    <article class="flex flex-col gap-6">
      <h2 class="text-xl font-semibold text-foreground tracking-tight">Frequently Asked Questions</h2>
      <div class="flex flex-col gap-4">
        <div class="flex flex-col gap-1.5">
          <h3 class="text-sm font-medium text-foreground">How is offset measured?</h3>
          <p class="text-muted text-sm leading-relaxed">Each click records the pixel distance between where you clicked and the exact center of the target. Your final score is the average offset across all targets — lower is better.</p>
        </div>
        <div class="flex flex-col gap-1.5">
          <h3 class="text-sm font-medium text-foreground">What DPI should I use?</h3>
          <p class="text-muted text-sm leading-relaxed">Lower DPI (400-800) generally produces better accuracy because it forces you to use arm movements instead of wrist jitter. Higher DPI amplifies small hand tremors, increasing offset errors.</p>
        </div>
        <div class="flex flex-col gap-1.5">
          <h3 class="text-sm font-medium text-foreground">Is this a medical diagnostic tool?</h3>
          <p class="text-muted text-sm leading-relaxed">No. This test is designed for self-tracking, performance benchmarking, and entertainment purposes. It is not a clinical cognitive assessment.</p>
        </div>
      </div>
    </article>

    <div class="p-4 rounded-xl border border-card-border bg-subtle text-xs text-muted leading-relaxed shadow-sm">
      <strong class="text-foreground font-semibold">Self-Tracking Notice:</strong> For self-tracking and educational purposes only. Not a clinical or diagnostic evaluation.
    </div>
  </div>
</Layout>
