---
import Layout from "@/layouts/main.astro";
import VisualPatternTest from "@/components/tests/VisualPatternTest";

const title = "Visual Pattern Memory Test — Spatial Assessment | CogniArena";
const description = "Benchmark your visuospatial working memory. Recall grid patterns under millisecond-accurate display intervals.";
const canonicalUrl = "https://cogniarena.com/tests/visual-pattern";

const schemaJson = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "applicationCategory": "GameApplication",
    "name": "Visual Pattern Memory Test",
    "description": "Assess visual pattern recognition and visuospatial chunking abilities.",
    "about": {
      "@type": "Thing",
      "name": "Spatial Memory"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is a good visual pattern memory score?",
        "acceptedAnswer": { "@type": "Answer", "text": "Most people can recall 4-6 grid cells accurately. Scoring 7-9 cells is above average, 10-12 is advanced, and 13+ is exceptional. Performance depends on your ability to chunk adjacent cells into meaningful shapes." }
      },
      {
        "@type": "Question",
        "name": "How does visual chunking improve pattern memory?",
        "acceptedAnswer": { "@type": "Answer", "text": "Instead of remembering individual cells, expert performers group adjacent tiles into larger shapes (L-shapes, lines, corners). This reduces cognitive load from 12 individual items to 3-4 chunks, leveraging the brain's pattern recognition strengths." }
      },
      {
        "@type": "Question",
        "name": "Is this a medical diagnostic tool?",
        "acceptedAnswer": { "@type": "Answer", "text": "No. This test is designed for self-tracking, performance benchmarking, and entertainment purposes. It is not a clinical cognitive assessment." }
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://cogniarena.com" },
      { "@type": "ListItem", "position": 2, "name": "Memory Suite", "item": "https://cogniarena.com/#suite" },
      { "@type": "ListItem", "position": 3, "name": "Visual Pattern Test", "item": "https://cogniarena.com/tests/visual-pattern" }
    ]
  }
];
---

<Layout title={title} description={description} canonicalUrl={canonicalUrl} schemaJson={schemaJson}>
  <div class="flex flex-col gap-12 w-full max-w-3xl mx-auto">
    <header class="flex flex-col gap-3">
      <nav class="flex items-center gap-2 text-xs font-mono uppercase tracking-widest text-accent" aria-label="Breadcrumb">
        <a href="/" class="hover:underline">Home</a>
        <span>/</span>
        <a href="/#suite" class="hover:underline">Tests</a>
        <span>/</span>
        <span class="text-muted">Visual Pattern Test</span>
      </nav>
      <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight text-foreground">
        Visual Pattern Memory Test
      </h1>
      <p class="text-muted text-sm md:text-base leading-relaxed max-w-2xl">
        Test your visual pattern memory boundaries. Memorize the illuminated grid locations and recall them correctly.
      </p>
    </header>

    <section class="w-full">
      <VisualPatternTest client:load />
    </section>

    <!-- Below the fold SEO and Methodology Content -->

      <!-- Medical/Scientific Disclaimer Notice -->
      <div class="p-4 rounded-xl border border-card-border bg-subtle text-xs text-muted leading-relaxed shadow-sm">
        <strong class="text-foreground font-semibold">Self-Tracking Notice:</strong> This assessment is for self-tracking, educational, and cognitive training purposes only. It is not a clinical, medical, diagnostic, or neuropsychological evaluation, and may be affected by display latency, input delays, or device configuration.
      </div>

    <section class="flex flex-col gap-10 border-t border-card-border pt-12">
      <article class="flex flex-col gap-4">
        <h2 class="text-xl font-bold text-foreground tracking-tight">How the Visual Pattern Memory Test Works</h2>
        <p class="text-secondary text-sm leading-relaxed">
          At the start of each level, a grid displays a pattern of highlighted tiles. Memorize their coordinates. When they disappear, click all cells that were part of the pattern, then submit.
        </p>
      </article>

      <article class="flex flex-col gap-4">
        <h2 class="text-xl font-bold text-foreground tracking-tight">Visuospatial Processing Efficiency</h2>
        <p class="text-secondary text-sm leading-relaxed">
          The parietal lobe and prefrontal cortex play central roles in processing spatial positions. Visual chunking strategies allow high-level performers to group adjacent tiles into single vector shapes, optimizing visual cache recall.
        </p>
      </article>
    </section>

    <!-- What Affects Your Score -->
    <article class="flex flex-col gap-4">
      <h2 class="text-xl font-semibold text-foreground tracking-tight">What Affects Your Visual Pattern Score</h2>
      <ul class="flex flex-col gap-2 text-muted text-sm leading-relaxed list-disc list-inside">
        <li><strong class="text-foreground">Chunking strategy</strong> — grouping adjacent cells into shapes (lines, corners, L-shapes) to reduce cognitive load</li>
        <li><strong class="text-foreground">Visuospatial working memory</strong> — the number of spatial locations you can actively maintain in short-term storage</li>
        <li><strong class="text-foreground">Pattern complexity</strong> — symmetric patterns are easier to recall than random distributions</li>
        <li><strong class="text-foreground">Display latency</strong> — slower monitors add minor overhead to pattern encoding</li>
      </ul>
    </article>

    <!-- Related Tests -->
    <article class="flex flex-col gap-3">
      <h2 class="text-lg font-semibold text-foreground tracking-tight">Related Tests</h2>
      <div class="flex flex-wrap gap-2">
        <a href="/tests/number-memory" class="px-3 py-1.5 rounded-lg border border-card-border bg-subtle text-xs text-muted hover:border-accent hover:text-foreground transition-colors">Number Memory →</a>
        <a href="/tests/dual-n-back" class="px-3 py-1.5 rounded-lg border border-card-border bg-subtle text-xs text-muted hover:border-accent hover:text-foreground transition-colors">Dual N-Back →</a>
        <a href="/tests/spatial-orientation" class="px-3 py-1.5 rounded-lg border border-card-border bg-subtle text-xs text-muted hover:border-accent hover:text-foreground transition-colors">Spatial Orientation →</a>
      </div>
    </article>

    <!-- FAQ Section -->
    <article class="flex flex-col gap-6">
      <h2 class="text-xl font-semibold text-foreground tracking-tight">Frequently Asked Questions</h2>
      <div class="flex flex-col gap-4">
        <div class="flex flex-col gap-1.5">
          <h3 class="text-sm font-medium text-foreground">What is a good visual pattern memory score?</h3>
          <p class="text-muted text-sm leading-relaxed">Most people can recall 4-6 grid cells accurately. Scoring 7-9 cells is above average, 10-12 is advanced, and 13+ is exceptional. Performance depends on your ability to chunk adjacent cells into meaningful shapes.</p>
        </div>
        <div class="flex flex-col gap-1.5">
          <h3 class="text-sm font-medium text-foreground">How does visual chunking improve pattern memory?</h3>
          <p class="text-muted text-sm leading-relaxed">Instead of remembering individual cells, expert performers group adjacent tiles into larger shapes (L-shapes, lines, corners). This reduces cognitive load from 12 individual items to 3-4 chunks, leveraging the brain's pattern recognition strengths.</p>
        </div>
        <div class="flex flex-col gap-1.5">
          <h3 class="text-sm font-medium text-foreground">Is this a medical diagnostic tool?</h3>
          <p class="text-muted text-sm leading-relaxed">No. This test is designed for self-tracking, performance benchmarking, and entertainment purposes. It is not a clinical cognitive assessment.</p>
        </div>
      </div>
    </article>
  </div>
</Layout>
