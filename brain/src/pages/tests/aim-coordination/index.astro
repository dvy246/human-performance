---
import Layout from "@/layouts/main.astro"
import AimCoordinationTest from "@/components/tests/AimCoordinationTest"
import ExploreTests from "@/components/ui/ExploreTests.astro"
import HowItWorks from "@/components/ui/HowItWorks.astro"

const title =
  "Aim Coordination Test — Hand-Eye Coordination Benchmark | CogniArena"
const description =
  "Test your hand-eye coordination speed. Click targets as fast as they appear and measure your visual-motor response latency. Free online coordination assessment."
const canonicalUrl = "https://cogniarena.com/tests/aim-coordination"

const schemaJson = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    applicationCategory: "GameApplication",
    name: "Aim Coordination Test",
    description:
      "A hand-eye coordination speed assessment measuring visual-motor response latency to random target stimuli.",
    about: {
      "@type": "Thing",
      name: "Hand-Eye Coordination",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: "https://cogniarena.com",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Reaction & Reflexes",
        item: "https://cogniarena.com/tests",
      },
      {
        "@type": "ListItem",
        position: 3,
        name: "Aim Coordination Test",
        item: "https://cogniarena.com/tests/aim-coordination",
      },
    ],
  },
]
---

<Layout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  schemaJson={schemaJson}
>
  <div class="mx-auto flex w-full max-w-3xl flex-col gap-12">
    <!-- Header Section -->
    <header class="flex flex-col gap-3">
      <nav
        class="flex items-center gap-2 font-mono text-xs tracking-widest text-accent uppercase"
        aria-label="Breadcrumb"
      >
        <a href="/" class="hover:underline">Home</a>
        <span>/</span>
        <a href="/tests" class="hover:underline">Tests</a>
        <span>/</span>
        <span class="text-muted">Aim Coordination Test</span>
      </nav>
      <h1
        class="text-3xl font-extrabold tracking-tight text-foreground md:text-4xl"
      >
        Aim Coordination Test
      </h1>
      <p class="max-w-2xl text-sm leading-relaxed text-muted md:text-base">
        Test your hand-eye coordination speed. Click targets as fast as they
        appear and measure your visual-motor response latency. This assessment
        isolates the raw speed of your sensory-motor loop.
      </p>
    </header>

    <!-- Interactive Game Island Container -->
    <section class="w-full">
      <AimCoordinationTest client:visible />
    </section>

    <!-- Below the fold SEO and Methodology Content -->

    <!-- Medical/Scientific Disclaimer Notice -->
    <div
      class="rounded-xl border border-card-border bg-subtle p-4 text-xs leading-relaxed text-muted shadow-sm"
    >
      <strong class="font-semibold text-foreground"
        >Self-Tracking Notice:</strong
      > This assessment is for self-tracking, educational, and cognitive training
      purposes only. It is not a clinical, medical, diagnostic, or neuropsychological
      evaluation, and may be affected by display latency, input delays, or device
      configuration.
    </div>

    <section class="flex flex-col gap-10 border-t border-card-border pt-12">
      <HowItWorks
        testName="the Aim Coordination Test"
        learnSlug="aim-training"
        learnTitle="Aim Training Science"
        whatItMeasures="Tests hand-eye coordination by presenting clickable targets at random positions. Measures the full visual-motor response cycle: target detection, spatial localization, and motor execution."
        howScoringWorks="Score combines reaction time (how fast you click each target) and accuracy (distance from target center). A composite score reflects your overall coordination efficiency."
        whatAffectsResults="Your mouse DPI and sensitivity settings, display refresh rate, practice with aim-based tasks, and current focus level all affect your coordination score."
      />

      {/* Scientific Methodology link */}
      <div class="flex items-center gap-3 text-xs text-muted">
        <div
          class="flex h-6 w-6 items-center justify-center rounded-full border border-accent/20 bg-accent/10 font-mono text-[10px] font-bold text-accent"
        >
          BB
        </div>
        <span
          >Learn about calibration protocols and scientific formulas on our <a
            href="/methodology"
            class="font-medium text-accent hover:underline">Methodology Page</a
          >.</span
        >
      </div>

      <!-- What is it -->
      <article class="flex flex-col gap-4">
        <h2 class="text-xl font-semibold tracking-tight text-foreground">
          What is the Aim Coordination Test?
        </h2>
        <p class="text-sm leading-relaxed text-muted">
          The Aim Coordination Test measures how quickly your brain can process
          a visual stimulus and execute a precise motor response. When a green
          target appears at a random position on the canvas, your visual cortex
          detects it, your brain computes the spatial coordinates, and your
          motor cortex sends signals to your hand to move the cursor and click —
          all in a fraction of a second.
        </p>
        <p class="text-sm leading-relaxed text-muted">
          Unlike simple reaction time tests that measure response to a single
          predictable stimulus, this test adds a spatial coordination component
          — your brain must not only react quickly but also compute target
          position and guide your hand to the correct location. This makes it a
          more comprehensive measure of hand-eye coordination ability.
        </p>
      </article>

      <!-- What it measures -->
      <article class="flex flex-col gap-4">
        <h2 class="text-xl font-semibold tracking-tight text-foreground">
          What Does Hand-Eye Coordination Measure?
        </h2>
        <p class="text-sm leading-relaxed text-muted">
          Hand-eye coordination is the ability of the visual system to
          coordinate movements of the hands with processing of visual
          information. The test measures several components of this ability:
        </p>
        <ul
          class="flex list-inside list-disc flex-col gap-2 text-sm leading-relaxed text-muted"
        >
          <li>
            <strong class="text-foreground">Visual Processing Speed:</strong> How
            quickly your eyes detect and transmit the target stimulus to the brain
            via the optic nerve.
          </li>
          <li>
            <strong class="text-foreground">Spatial Computation:</strong> How efficiently
            your parietal lobe computes the target's position relative to your cursor
            and plans the movement trajectory.
          </li>
          <li>
            <strong class="text-foreground">Motor Execution Speed:</strong> How fast
            your motor cortex sends signals through the corticospinal tract to execute
            the physical click.
          </li>
        </ul>
        <p class="text-sm leading-relaxed text-muted">
          The total latency from target appearance to successful click captures
          the entire sensorimotor pipeline — typically ranging from 300ms to
          600ms for most people.
        </p>
      </article>

      <!-- How to improve -->
      <article class="flex flex-col gap-4">
        <h2 class="text-xl font-semibold tracking-tight text-foreground">
          How to Improve Your Coordination Speed
        </h2>
        <ul
          class="flex list-inside list-disc flex-col gap-2 text-sm leading-relaxed text-muted"
        >
          <li>
            <strong class="text-foreground"
              >Practice Aim Trainers Regularly:</strong
            > Repeated exposure to target-acquisition tasks strengthens the neural
            pathways between your visual and motor cortices, reducing signal transmission
            time.
          </li>
          <li>
            <strong class="text-foreground"
              >Play Fast-Paced Action Games:</strong
            > FPS and action games demand rapid target tracking and clicking, which
            has been shown to improve visual attention and spatial coordination.
          </li>
          <li>
            <strong class="text-foreground">Optimize Your Hardware:</strong> A high-refresh-rate
            monitor (144Hz+) and a low-latency mouse reduce hardware-induced delays,
            letting you see and respond to targets faster.
          </li>
          <li>
            <strong class="text-foreground">Maintain Focus and Rest:</strong> Coordination
            speed degrades significantly with fatigue. Ensure adequate sleep and take
            regular breaks to maintain peak performance.
          </li>
        </ul>
      </article>

      <ExploreTests currentSlug="aim-coordination" />

      </section>
  </div>
</Layout>
