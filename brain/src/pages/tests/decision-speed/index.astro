---
import Layout from "@/layouts/main.astro"
import DecisionSpeedTest from "@/components/tests/DecisionSpeedTest"
import ExploreTests from "@/components/ui/ExploreTests.astro"
import HowItWorks from "@/components/ui/HowItWorks.astro"

const title = "Decision Speed Test – Binary Choice | CogniArena"
const description =
  "Measure your decision-making speed. Rapidly classify numbers as ≥50 or <50 in this cognitive processing speed test."
const canonicalUrl = "https://cogniarena.com/tests/decision-speed"

const schemaJson = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    applicationCategory: "GameApplication",
    name: "Decision Speed Test | CogniArena",
    description:
      "Binary choice cognitive assessment measuring information processing speed by classifying numbers as high or low.",
    about: { "@type": "Thing", name: "Processing Speed / Decision Making" },
    educationalAlignment: {
      "@type": "AlignmentObject",
      alignmentType: "educationalRequirement",
      educationalFramework: "Cognitive Science",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: "https://cogniarena.com",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Cognition",
        item: "https://cogniarena.com/",
      },
      {
        "@type": "ListItem",
        position: 3,
        name: "Decision Speed Test",
        item: "https://cogniarena.com/tests/decision-speed",
      },
    ],
  },
]
---

<Layout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  schemaJson={schemaJson}
>
  <div class="mx-auto flex w-full max-w-3xl flex-col gap-12">
    <header class="flex flex-col gap-3">
      <nav
        class="flex items-center gap-2 font-mono text-xs tracking-widest text-accent uppercase"
        aria-label="Breadcrumb"
      >
        <a href="/" class="hover:underline">Home</a><span>/</span><a
          href="/tests"
          class="hover:underline">Tests</a
        ><span>/</span><span class="text-muted">Decision Speed Test</span>
      </nav>
      <h1
        class="text-3xl font-extrabold tracking-tight text-foreground md:text-4xl"
      >
        Decision Speed Test
      </h1>
      <p class="max-w-2xl text-sm leading-relaxed text-muted md:text-base">
        How fast can you decide? Classify 20 numbers as ≥50 or &lt;50 against a
        2-second timeout. Measures raw information processing speed.
      </p>
    </header>
    <section class="w-full"><DecisionSpeedTest client:visible /></section>

    <HowItWorks
      testName="the Decision Speed Test"
      learnSlug="decision-speed"
      learnTitle="Processing Speed Science"
      whatItMeasures="Measures raw information processing speed. Numbers appear one at a time and you must classify each as ≥50 or <50 as fast as possible. Unlike simple reaction tests, this requires a cognitive classification step."
      howScoringWorks="Score is the average response time for correct classifications across 20 trials. A 2-second timeout prevents guessing. Faster response times with high accuracy indicate efficient neural processing."
      whatAffectsResults="Your processing speed, attention and arousal level, practice effects (familiarity with the threshold builds faster mental shortcuts), and display refresh rate all affect your decision speed."
    />

    <!-- What Affects Your Score -->
    <article class="flex flex-col gap-4">
      <h2 class="text-xl font-semibold tracking-tight text-foreground">
        What Affects Your Decision Speed
      </h2>
      <ul
        class="flex list-inside list-disc flex-col gap-2 text-sm leading-relaxed text-muted"
      >
        <li>
          <strong class="text-foreground">Processing speed</strong> — how quickly
          your brain evaluates a stimulus and commits to a classification
        </li>
        <li>
          <strong class="text-foreground">Attention and arousal</strong> — optimal
          alertness improves classification accuracy under time pressure
        </li>
        <li>
          <strong class="text-foreground">Practice effects</strong> — repeated exposure
          to the ≥50/&lt;50 threshold builds faster mental shortcuts
        </li>
        <li>
          <strong class="text-foreground">Monitor refresh rate</strong> — higher Hz
          displays reduce the gap between stimulus onset and your perception of it
        </li>
      </ul>
    </article>

    <ExploreTests currentSlug="decision-speed" />

    <div
      class="rounded-xl border border-card-border bg-subtle p-4 text-xs leading-relaxed text-muted shadow-sm"
    >
      <strong class="font-semibold text-foreground"
        >Self-Tracking Notice:</strong
      > For self-tracking and educational purposes only. Not a clinical or diagnostic
      evaluation.
    </div>
  </div>
</Layout>
