---
import Layout from "@/layouts/main.astro";
import DecisionSpeedTest from "@/components/tests/DecisionSpeedTest";

const title = "Decision Speed Test – Binary Choice | CogniArena";
const description = "Measure your decision-making speed. Rapidly classify numbers as ≥50 or <50 in this cognitive processing speed test.";
const canonicalUrl = "https://cogniarena.com/tests/decision-speed";

const schemaJson = [
  {
    "@context": "https://schema.org",
    "@type": "Quiz",
    "name": "Decision Speed Test | CogniArena",
    "description": "Binary choice cognitive assessment measuring information processing speed by classifying numbers as high or low.",
    "about": { "@type": "Thing", "name": "Processing Speed / Decision Making" },
    "educationalAlignment": { "@type": "AlignmentObject", "alignmentType": "educationalRequirement", "educationalFramework": "Cognitive Science" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is Hick's Law?",
        "acceptedAnswer": { "@type": "Answer", "text": "Hick's Law states that reaction time increases logarithmically with the number of possible choices. This test uses a binary decision (high or low) to isolate processing speed from complex choice overhead." }
      },
      {
        "@type": "Question",
        "name": "How does this differ from simple reaction time?",
        "acceptedAnswer": { "@type": "Answer", "text": "Simple reaction time measures a single stimulus-response pair (see a light, click). Decision speed adds a cognitive classification step — you must evaluate the number and choose a response, which engages additional processing pathways." }
      },
      {
        "@type": "Question",
        "name": "Is this a medical diagnostic tool?",
        "acceptedAnswer": { "@type": "Answer", "text": "No. This test is designed for self-tracking, performance benchmarking, and entertainment purposes. It is not a clinical cognitive assessment." }
      }
    ]
  }
];
---
<Layout title={title} description={description} canonicalUrl={canonicalUrl} schemaJson={schemaJson}>
  <div class="flex flex-col gap-12 w-full max-w-3xl mx-auto">
    <header class="flex flex-col gap-3">
      <div class="flex items-center gap-2 text-xs font-mono uppercase tracking-widest text-accent"><span>Assessment Suite</span><span>&middot;</span><span>Cognition</span></div>
      <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight text-foreground">Decision Speed Test</h1>
      <p class="text-muted text-sm md:text-base leading-relaxed max-w-2xl">How fast can you decide? Classify 20 numbers as ≥50 or &lt;50 against a 2-second timeout. Measures raw information processing speed.</p>
    </header>
    <section class="w-full"><DecisionSpeedTest client:visible /></section>

    <!-- What Affects Your Score -->
    <article class="flex flex-col gap-4">
      <h2 class="text-xl font-semibold text-foreground tracking-tight">What Affects Your Decision Speed</h2>
      <ul class="flex flex-col gap-2 text-muted text-sm leading-relaxed list-disc list-inside">
        <li><strong class="text-foreground">Processing speed</strong> — how quickly your brain evaluates a stimulus and commits to a classification</li>
        <li><strong class="text-foreground">Attention and arousal</strong> — optimal alertness improves classification accuracy under time pressure</li>
        <li><strong class="text-foreground">Practice effects</strong> — repeated exposure to the ≥50/&lt;50 threshold builds faster mental shortcuts</li>
        <li><strong class="text-foreground">Monitor refresh rate</strong> — higher Hz displays reduce the gap between stimulus onset and your perception of it</li>
      </ul>
    </article>

    <!-- Related Tests -->
    <article class="flex flex-col gap-3">
      <h2 class="text-lg font-semibold text-foreground tracking-tight">Related Tests</h2>
      <div class="flex flex-wrap gap-2">
        <a href="/tests/reaction-time" class="px-3 py-1.5 rounded-lg border border-card-border bg-subtle text-xs text-muted hover:border-accent hover:text-foreground transition-colors">Reaction Time →</a>
        <a href="/tests/choice-reaction" class="px-3 py-1.5 rounded-lg border border-card-border bg-subtle text-xs text-muted hover:border-accent hover:text-foreground transition-colors">Choice Reaction →</a>
        <a href="/tests/stroop" class="px-3 py-1.5 rounded-lg border border-card-border bg-subtle text-xs text-muted hover:border-accent hover:text-foreground transition-colors">Stroop Test →</a>
      </div>
    </article>

    <!-- FAQ Section -->
    <article class="flex flex-col gap-6">
      <h2 class="text-xl font-semibold text-foreground tracking-tight">Frequently Asked Questions</h2>
      <div class="flex flex-col gap-4">
        <div class="flex flex-col gap-1.5">
          <h3 class="text-sm font-medium text-foreground">What is Hick's Law?</h3>
          <p class="text-muted text-sm leading-relaxed">Hick's Law states that reaction time increases logarithmically with the number of possible choices. This test uses a binary decision (high or low) to isolate processing speed from complex choice overhead.</p>
        </div>
        <div class="flex flex-col gap-1.5">
          <h3 class="text-sm font-medium text-foreground">How does this differ from simple reaction time?</h3>
          <p class="text-muted text-sm leading-relaxed">Simple reaction time measures a single stimulus-response pair (see a light, click). Decision speed adds a cognitive classification step — you must evaluate the number and choose a response, which engages additional processing pathways.</p>
        </div>
        <div class="flex flex-col gap-1.5">
          <h3 class="text-sm font-medium text-foreground">Is this a medical diagnostic tool?</h3>
          <p class="text-muted text-sm leading-relaxed">No. This test is designed for self-tracking, performance benchmarking, and entertainment purposes. It is not a clinical cognitive assessment.</p>
        </div>
      </div>
    </article>

    <div class="p-4 rounded-xl border border-card-border bg-subtle text-xs text-muted leading-relaxed shadow-sm">
      <strong class="text-foreground font-semibold">Self-Tracking Notice:</strong> For self-tracking and educational purposes only. Not a clinical or diagnostic evaluation.
    </div>
  </div>
</Layout>
