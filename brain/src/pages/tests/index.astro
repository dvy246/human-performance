---
import Layout from "@/layouts/main.astro"
import ExploreTests from "@/components/ui/ExploreTests.astro"

const title = "Free Cognitive Test Hub & Online Brain Games | CogniArena"
const description =
  "Explore our complete library of 24+ free brain tests, cognitive assessments, and online mind power games. Test your memory, logic, and reaction time."
const canonicalUrl = "https://cogniarena.com/tests"

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: "https://cogniarena.com",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Tests",
      item: "https://cogniarena.com/tests",
    },
  ],
}

const collectionPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Cognitive Assessments Collection",
  description:
    "Collection of all cognitive testing and performance benchmarking tasks running in the browser.",
  url: "https://cogniarena.com/tests",
}

const schemaJson = [breadcrumbSchema, collectionPageSchema]
---

<Layout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  schemaJson={schemaJson}
>
  <div class="mx-auto flex w-full max-w-5xl flex-col gap-10 py-4">
    <!-- Header Section -->
    <header class="flex flex-col gap-3">
      <div
        class="flex items-center gap-2 font-mono text-xs tracking-widest text-accent uppercase"
      >
        <span data-i18n="tests_index.badge1">CogniArena</span>
        <span>&middot;</span>
        <span data-i18n="tests_index.badge2">Assessments</span>
      </div>
      <h1
        class="text-3xl font-extrabold tracking-tight text-foreground md:text-4xl"
        data-i18n="tests_index.title"
      >
        Free Cognitive Test &amp; Brain Training Hub
      </h1>
      <p
        class="max-w-2xl text-sm leading-relaxed text-muted md:text-base"
        data-i18n="tests_index.subtitle"
      >
        Measure your mind power and brain power with our 24+ free brain tests
        and online games. Benchmark your reaction time, memory, logic, and
        precision with millisecond accuracy.
      </p>
    </header>

    <!-- Collection Grid -->
    <ExploreTests title="All Available Assessments" />
  </div>
</Layout>
