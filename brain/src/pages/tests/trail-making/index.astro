---
import Layout from "@/layouts/main.astro";
import TrailMakingTest from "@/components/tests/TrailMakingTest";

const title = "Trail Making Test (TMT) — Cognitive Flexibility Assessment | CogniArena";
const description = "Test your visual attention scanning, search rate, and task-switching speed with the online Trail Making Test (TMT-A & B). Millisecond-accurate browser performance logging.";
const canonicalUrl = "https://cogniarena.com/tests/trail-making";

const schemaJson = [
  {
    "@context": "https://schema.org",
    "@type": "Quiz",
    "name": "Trail Making Test",
    "description": "Assess visual scanning speed, task switching, and cognitive flexibility.",
    "about": {
      "@type": "Thing",
      "name": "Executive Function & Attention"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the difference between Trail Making Part A and Part B?",
        "acceptedAnswer": { "@type": "Answer", "text": "Part A tests visual scanning speed and motor execution by connecting numbered nodes in sequence (1→2→3). Part B adds cognitive load by requiring task switching — alternating between numbers and letters (1→A→2→B→3→C). The difference between Part A and Part B scores measures cognitive flexibility." }
      },
      {
        "@type": "Question",
        "name": "What is a good Trail Making Test score?",
        "acceptedAnswer": { "@type": "Answer", "text": "For Part A, adults under 35 typically complete in 20-30 seconds. For Part B, 60-90 seconds is average. The key metric is the A/B ratio — a ratio under 2.5 indicates good cognitive flexibility, while ratios above 3.0 suggest significant task-switching overhead." }
      },
      {
        "@type": "Question",
        "name": "Is this a medical diagnostic tool?",
        "acceptedAnswer": { "@type": "Answer", "text": "No. This test is designed for self-tracking, performance benchmarking, and entertainment purposes. It is not a clinical cognitive assessment." }
      }
    ]
  }
];
---

<Layout title={title} description={description} canonicalUrl={canonicalUrl} schemaJson={schemaJson}>
  <div class="flex flex-col gap-12 w-full max-w-3xl mx-auto">
    <header class="flex flex-col gap-3">
      <div class="flex items-center gap-2 text-xs font-mono uppercase tracking-widest text-accent">
        <span>Assessment Suite</span>
        <span>&middot;</span>
        <span>Executive Function</span>
      </div>
      <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight text-foreground">
        Trail Making Test (TMT)
      </h1>
      <p class="text-zinc-500 dark:text-zinc-400 text-sm md:text-base leading-relaxed max-w-2xl">
        Benchmark your scanning rate and task-switching flexibility. Connect the numbered nodes in Part A, and alternate between numbers and letters in Part B.
      </p>
    </header>

    <section class="w-full">
      <TrailMakingTest client:load />
    </section>

    <!-- Below the fold SEO and Methodology Content -->

      <!-- Medical/Scientific Disclaimer Notice -->
      <div class="p-4 rounded-xl border border-card-border bg-subtle text-xs text-zinc-500 dark:text-zinc-400 leading-relaxed shadow-sm">
        <strong class="text-foreground font-semibold">Self-Tracking Notice:</strong> This assessment is for self-tracking, educational, and cognitive training purposes only. It is not a clinical, medical, diagnostic, or neuropsychological evaluation, and may be affected by display latency, input delays, or device configuration.
      </div>

    <section class="flex flex-col gap-10 border-t border-card-border pt-12">
      <article class="flex flex-col gap-4">
        <h2 class="text-xl font-bold text-foreground tracking-tight">Understanding the Trail Making Test</h2>
        <p class="text-zinc-400 text-sm leading-relaxed">
          The Trail Making Test (TMT) is a widely recognized cognitive assessment developed in 1944. Part A evaluates visual scanning speed, motor execution, and sequence recognition. Part B introduces cognitive load by forcing users to switch attention between two different sequences: numeric (1, 2, 3...) and alphabetic (A, B, C...).
        </p>
      </article>

      <article class="flex flex-col gap-4">
        <h2 class="text-xl font-bold text-foreground tracking-tight">How Cognitive Flexibility Matures</h2>
        <p class="text-zinc-400 text-sm leading-relaxed">
          The ratio or delay difference between Part A and Part B scores is a strong indicator of cognitive flexibility. A larger discrepancy represents greater task-switching overhead, which is managed by the frontoparietal networks and prefrontal cortex. Working to minimize your TMT-B delay improves spatial search efficiency under stress.
        </p>
      </article>
    </section>

    <!-- What Affects Your Score -->
    <article class="flex flex-col gap-4">
      <h2 class="text-xl font-semibold text-foreground tracking-tight">What Affects Your Trail Making Score</h2>
      <ul class="flex flex-col gap-2 text-zinc-500 dark:text-zinc-400 text-sm leading-relaxed list-disc list-inside">
        <li><strong class="text-foreground">Visual scanning speed</strong> — how quickly your eyes can locate the next target in the field</li>
        <li><strong class="text-foreground">Cognitive flexibility</strong> — the efficiency of switching between different rule sets (numbers vs. letters)</li>
        <li><strong class="text-foreground">Motor execution</strong> — click precision and movement speed between targets</li>
        <li><strong class="text-foreground">Display latency</strong> — slower monitors add minor overhead to target recognition</li>
      </ul>
    </article>

    <!-- Related Tests -->
    <article class="flex flex-col gap-3">
      <h2 class="text-lg font-semibold text-foreground tracking-tight">Related Tests</h2>
      <div class="flex flex-wrap gap-2">
        <a href="/tests/decision-speed" class="px-3 py-1.5 rounded-lg border border-card-border bg-subtle text-xs text-zinc-500 dark:text-zinc-400 hover:border-accent hover:text-foreground transition-colors">Decision Speed →</a>
        <a href="/tests/stroop" class="px-3 py-1.5 rounded-lg border border-card-border bg-subtle text-xs text-zinc-500 dark:text-zinc-400 hover:border-accent hover:text-foreground transition-colors">Stroop Test →</a>
        <a href="/tests/planning" class="px-3 py-1.5 rounded-lg border border-card-border bg-subtle text-xs text-zinc-500 dark:text-zinc-400 hover:border-accent hover:text-foreground transition-colors">Planning →</a>
      </div>
    </article>

    <!-- FAQ Section -->
    <article class="flex flex-col gap-6">
      <h2 class="text-xl font-semibold text-foreground tracking-tight">Frequently Asked Questions</h2>
      <div class="flex flex-col gap-4">
        <div class="flex flex-col gap-1.5">
          <h3 class="text-sm font-medium text-foreground">What is the difference between Trail Making Part A and Part B?</h3>
          <p class="text-zinc-500 dark:text-zinc-400 text-sm leading-relaxed">Part A tests visual scanning speed and motor execution by connecting numbered nodes in sequence (1→2→3). Part B adds cognitive load by requiring task switching — alternating between numbers and letters (1→A→2→B→3→C). The difference between Part A and Part B scores measures cognitive flexibility.</p>
        </div>
        <div class="flex flex-col gap-1.5">
          <h3 class="text-sm font-medium text-foreground">What is a good Trail Making Test score?</h3>
          <p class="text-zinc-500 dark:text-zinc-400 text-sm leading-relaxed">For Part A, adults under 35 typically complete in 20-30 seconds. For Part B, 60-90 seconds is average. The key metric is the A/B ratio — a ratio under 2.5 indicates good cognitive flexibility, while ratios above 3.0 suggest significant task-switching overhead.</p>
        </div>
        <div class="flex flex-col gap-1.5">
          <h3 class="text-sm font-medium text-foreground">Is this a medical diagnostic tool?</h3>
          <p class="text-zinc-500 dark:text-zinc-400 text-sm leading-relaxed">No. This test is designed for self-tracking, performance benchmarking, and entertainment purposes. It is not a clinical cognitive assessment.</p>
        </div>
      </div>
    </article>
  </div>
</Layout>
