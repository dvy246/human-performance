---
import Layout from "@/layouts/main.astro"
import TrailMakingTest from "@/components/tests/TrailMakingTest"
import ExploreTests from "@/components/ui/ExploreTests.astro"
import HowItWorks from "@/components/ui/HowItWorks.astro"

const title =
  "Trail Making Test (TMT) — Cognitive Flexibility Assessment | CogniArena"
const description =
  "Test your visual attention scanning, search rate, and task-switching speed with the online Trail Making Test (TMT-A & B). Millisecond-accurate browser performance logging."
const canonicalUrl = "https://cogniarena.com/tests/trail-making"

const schemaJson = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    applicationCategory: "GameApplication",
    name: "Trail Making Test",
    description:
      "Assess visual scanning speed, task switching, and cognitive flexibility.",
    about: {
      "@type": "Thing",
      name: "Executive Function & Attention",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: "https://cogniarena.com",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Tests",
        item: "https://cogniarena.com/tests",
      },
      {
        "@type": "ListItem",
        position: 3,
        name: "Trail Making Test",
        item: "https://cogniarena.com/tests/trail-making",
      },
    ],
  },
]
---

<Layout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  schemaJson={schemaJson}
>
  <div class="mx-auto flex w-full max-w-3xl flex-col gap-12">
    <header class="flex flex-col gap-3">
      <nav
        class="flex items-center gap-2 font-mono text-xs tracking-widest text-accent uppercase"
        aria-label="Breadcrumb"
      >
        <a href="/" class="hover:underline">Home</a>
        <span>/</span>
        <a href="/tests" class="hover:underline">Tests</a>
        <span>/</span>
        <span class="text-muted">Trail Making Test</span>
      </nav>
      <h1
        class="text-3xl font-extrabold tracking-tight text-foreground md:text-4xl"
      >
        Trail Making Test (TMT)
      </h1>
      <p class="max-w-2xl text-sm leading-relaxed text-muted md:text-base">
        Benchmark your scanning rate and task-switching flexibility. Connect the
        numbered nodes in Part A, and alternate between numbers and letters in
        Part B.
      </p>
    </header>

    <section class="w-full">
      <TrailMakingTest client:load />
    </section>

    <!-- Below the fold SEO and Methodology Content -->

    <!-- Medical/Scientific Disclaimer Notice -->
    <div
      class="rounded-xl border border-card-border bg-subtle p-4 text-xs leading-relaxed text-muted shadow-sm"
    >
      <strong class="font-semibold text-foreground"
        >Self-Tracking Notice:</strong
      > This assessment is for self-tracking, educational, and cognitive training
      purposes only. It is not a clinical, medical, diagnostic, or neuropsychological
      evaluation, and may be affected by display latency, input delays, or device
      configuration.
    </div>

    <section class="flex flex-col gap-10 border-t border-card-border pt-12">
      <HowItWorks
        testName="the Trail Making Test"
        learnSlug="trail-making"
        learnTitle="Cognitive Set Shifting Science"
        whatItMeasures="Tests visual search speed, scanning, and cognitive flexibility. Part A connects numbered circles sequentially. Part B alternates between numbers and letters (1-A-2-B-...), requiring task-switching between two cognitive sets."
        howScoringWorks="Score is the time to complete each part. Part B typically takes 1.5-2x longer due to cognitive switching cost. Your TMT ratio (B/A) indicates cognitive flexibility — lower ratios are better."
        whatAffectsResults="Your visual scanning speed, ability to alternate between cognitive sets, working memory, and focus under time pressure all affect your trail-making performance."
      />

      <article class="flex flex-col gap-4">
        <h2 class="text-xl font-bold tracking-tight text-foreground">
          Understanding the Trail Making Test
        </h2>
        <p class="text-sm leading-relaxed text-secondary">
          The Trail Making Test (TMT) is a widely recognized cognitive
          assessment developed in 1944. Part A evaluates visual scanning speed,
          motor execution, and sequence recognition. Part B introduces cognitive
          load by forcing users to switch attention between two different
          sequences: numeric (1, 2, 3...) and alphabetic (A, B, C...).
        </p>
      </article>

      <article class="flex flex-col gap-4">
        <h2 class="text-xl font-bold tracking-tight text-foreground">
          How Cognitive Flexibility Matures
        </h2>
        <p class="text-sm leading-relaxed text-secondary">
          The ratio or delay difference between Part A and Part B scores is a
          strong indicator of cognitive flexibility. A larger discrepancy
          represents greater task-switching overhead, which is managed by the
          frontoparietal networks and prefrontal cortex. Working to minimize
          your TMT-B delay improves spatial search efficiency under stress.
        </p>
      </article>
    </section>

    <!-- What Affects Your Score -->
    <article class="flex flex-col gap-4">
      <h2 class="text-xl font-semibold tracking-tight text-foreground">
        What Affects Your Trail Making Score
      </h2>
      <ul
        class="flex list-inside list-disc flex-col gap-2 text-sm leading-relaxed text-muted"
      >
        <li>
          <strong class="text-foreground">Visual scanning speed</strong> — how quickly
          your eyes can locate the next target in the field
        </li>
        <li>
          <strong class="text-foreground">Cognitive flexibility</strong> — the efficiency
          of switching between different rule sets (numbers vs. letters)
        </li>
        <li>
          <strong class="text-foreground">Motor execution</strong> — click precision
          and movement speed between targets
        </li>
        <li>
          <strong class="text-foreground">Display latency</strong> — slower monitors
          add minor overhead to target recognition
        </li>
      </ul>
    </article>

    <ExploreTests currentSlug="trail-making" />

    </div>
</Layout>
