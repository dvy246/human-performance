---
import Layout from "@/layouts/main.astro"
import ErgonomicArchitect from "@/components/tests/ErgonomicArchitect"
import ExploreTests from "@/components/ui/ExploreTests.astro"
import HowItWorks from "@/components/ui/HowItWorks.astro"

const title = "Ergonomic Workspace Architect — Free Workstation Height Calculator | CogniArena"
const description =
  "Design a customized ergonomic desk layout. Calculate your ideal seating, desk, and display height using your body dimensions and reach tests."
const canonicalUrl = "https://cogniarena.com/tests/ergonomic-architect"

const schemaJson = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    applicationCategory: "GameApplication",
    name: "Ergonomic Workspace Architect",
    description:
      "An interactive workspace design tool to calculate custom ergonomic dimensions for desks, chairs, and monitors based on body size.",
    about: {
      "@type": "Thing",
      name: "Ergonomics",
    },
    educationalAlignment: {
      "@type": "AlignmentObject",
      alignmentType: "educationalRequirement",
      educationalFramework: "Workplace Ergonomics & Physical Safety Standards",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: "https://cogniarena.com",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Cognitive Tests",
        item: "https://cogniarena.com/tests",
      },
      {
        "@type": "ListItem",
        position: 3,
        name: "Ergonomic Workspace Architect",
        item: "https://cogniarena.com/tests/ergonomic-architect",
      },
    ],
  },
]
---

<Layout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  schemaJson={schemaJson}
>
  <div class="mx-auto flex w-full max-w-3xl flex-col gap-12">
    <!-- Header Section -->
    <header class="flex flex-col gap-3">
      <nav
        class="flex items-center gap-2 font-mono text-xs tracking-widest text-accent uppercase"
        aria-label="Breadcrumb"
      >
        <a href="/" class="hover:underline">Home</a>
        <span>/</span>
        <a href="/tests" class="hover:underline">Tests</a>
        <span>/</span>
        <span class="text-muted">Ergonomic Architect</span>
      </nav>
      <h1
        class="text-3xl font-extrabold tracking-tight text-foreground md:text-4xl"
      >
        Ergonomic Workspace Architect
      </h1>
      <p class="max-w-2xl text-sm leading-relaxed text-muted md:text-base">
        Design your optimal workspace layout in real-time. Input your body parameters and run visual reaching tests to calculate exact heights for your chair, desk, and screens.
      </p>
    </header>

    <!-- Interactive Workspace Panel -->
    <section class="w-full">
      <ErgonomicArchitect client:load />
    </section>

    <!-- Medical/Scientific Disclaimer Notice -->
    <div
      class="rounded-xl border border-card-border bg-subtle p-4 text-xs leading-relaxed text-muted shadow-sm"
    >
      <strong class="font-semibold text-foreground"
        >Self-Tracking Notice:</strong
      > This workspace planning utility is designed for self-tracking, educational, and ergonomics planning purposes only. It is not a medical, clinical, diagnostic, or physical therapy evaluation. Consult a licensed physical therapist or occupational health specialist for diagnostic support.
    </div>

    <!-- Below the fold SEO and Methodology Content -->
    <section class="flex flex-col gap-10 border-t border-card-border pt-12">
      <HowItWorks
        testName="the Ergonomic Workspace Architect"
        learnSlug="typing-speed"
        learnTitle="Motor Ergonomics"
        whatItMeasures="This workspace calculator measures motor reaching speeds at different areas of the display, correlating visual fatigue with height dimensions, and computes precise physical workstation requirements."
        howScoringWorks="Formulas are derived from human physical dimensions (anthropometric percentiles) to recommend a desk layout ensuring joint angles stay within comfortable limits."
        whatAffectsResults="Correct seating posture, screen distance, footrest positioning, and keyboard tilting all affect workspace comfort."
      />

      <!-- Deep SEO explanation article -->
      <article class="flex flex-col gap-4">
        <h2 class="text-xl font-semibold tracking-tight text-foreground">
          How to Setup an Ergonomic Workspace and Desk Layout
        </h2>
        <p class="text-sm leading-relaxed text-muted">
          Correct workspace setup is vital to prevent musculoskeletal strain, repetitive strain injuries (RSI), and fatigue. A standard <strong class="text-foreground">desk height calculator</strong> provides base values, but does not adjust for forearm lengths or monitor sizes. The key is maintaining natural elbow angles (90 to 100 degrees) and placing your feet flat on the ground.
        </p>
        <p class="text-sm leading-relaxed text-muted">
          Using our interactive <strong class="text-foreground">workspace blueprint planner</strong>, you get personalized height metrics. Exporting these physical dimensions to your corporate health officer or HR team can help you secure ergonomic upgrades, enhancing focus and long-term joint health.
        </p>
      </article>

      <ExploreTests currentSlug="ergonomic-architect" />
    </section>
  </div>
</Layout>
