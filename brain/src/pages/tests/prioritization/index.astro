---
import Layout from "@/layouts/main.astro"
import PrioritizationTest from "@/components/tests/PrioritizationTest"
import ExploreTests from "@/components/ui/ExploreTests.astro"
import HowItWorks from "@/components/ui/HowItWorks.astro"

const title = "Prioritization Test – Task Scheduling | CogniArena"
const description =
  "Test your task prioritization and scheduling skills. Maximize points by completing high-value tasks before deadlines across 5 rounds."
const canonicalUrl = "https://cogniarena.com/tests/prioritization"

const schemaJson = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    applicationCategory: "GameApplication",
    name: "Prioritization Test",
    description:
      "Task scheduling assessment measuring ability to maximize value under time pressure.",
    about: { "@type": "Thing", name: "Executive Function" },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: "https://cogniarena.com",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Executive",
        item: "https://cogniarena.com/",
      },
      {
        "@type": "ListItem",
        position: 3,
        name: "Prioritization Test",
        item: "https://cogniarena.com/tests/prioritization",
      },
    ],
  },
]
---

<Layout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  schemaJson={schemaJson}
>
  <div class="mx-auto flex w-full max-w-3xl flex-col gap-12">
    <header class="flex flex-col gap-3">
      <nav
        class="flex items-center gap-2 font-mono text-xs tracking-widest text-accent uppercase"
        aria-label="Breadcrumb"
      >
        <a href="/" class="hover:underline">Home</a><span>/</span><a
          href="/tests"
          class="hover:underline">Tests</a
        ><span>/</span><span class="text-muted">Prioritization Test</span>
      </nav>
      <h1
        class="text-3xl font-extrabold tracking-tight text-foreground md:text-4xl"
      >
        Prioritization Test
      </h1>
      <p class="max-w-2xl text-sm leading-relaxed text-muted md:text-base">
        5 rounds of simulated task scheduling. Each round gives you 10 seconds
        and 5 tasks — choose wisely to maximize points before deadlines expire.
      </p>
    </header>
    <section class="w-full"><PrioritizationTest client:visible /></section>

    <HowItWorks
      testName="the Prioritization Test"
      learnSlug="prioritization"
      learnTitle="Task Prioritization Science"
      whatItMeasures="Tests task scheduling and prioritization skills across 5 rounds. Each round presents multiple tasks with different point values and deadlines. You must decide which tasks to complete and in what order."
      howScoringWorks="Score is total points accumulated across all 5 rounds. Optimal strategies prioritize high-value tasks with approaching deadlines (Eisenhower Matrix thinking)."
      whatAffectsResults="Your value assessment speed, impulse control (resisting the first visible task), working memory (tracking completed tasks), and attention under time pressure all affect your prioritization score."
    />

    <!-- What Affects Your Score -->
    <article class="flex flex-col gap-4">
      <h2 class="text-xl font-semibold tracking-tight text-foreground">
        What Affects Your Prioritization Score
      </h2>
      <ul
        class="flex list-inside list-disc flex-col gap-2 text-sm leading-relaxed text-muted"
      >
        <li>
          <strong class="text-foreground">Value assessment speed</strong> — how quickly
          you can compare task effort against point reward
        </li>
        <li>
          <strong class="text-foreground">Impulse control</strong> — resisting the
          urge to click the first task you see rather than scanning for the best value
        </li>
        <li>
          <strong class="text-foreground">Working memory</strong> — tracking which
          tasks you have already completed across rounds
        </li>
        <li>
          <strong class="text-foreground">Attention under time pressure</strong> —
          maintaining accuracy when the 10-second clock is ticking
        </li>
      </ul>
    </article>

    <ExploreTests currentSlug="prioritization" />

    <div
      class="rounded-xl border border-card-border bg-subtle p-4 text-xs leading-relaxed text-muted shadow-sm"
    >
      <strong class="font-semibold text-foreground"
        >Self-Tracking Notice:</strong
      > For self-tracking and educational purposes only. Not a clinical or diagnostic
      evaluation.
    </div>
  </div>
</Layout>
