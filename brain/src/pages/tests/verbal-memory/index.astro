---
import Layout from "@/layouts/main.astro"
import VerbalMemoryTest from "@/components/tests/VerbalMemoryTest"
import ExploreTests from "@/components/ui/ExploreTests.astro"
import HowItWorks from "@/components/ui/HowItWorks.astro"

const title = "Verbal Memory Test – Word Recall | CogniArena"
const description =
  "Test your verbal working memory capacity. Memorize growing word lists and recall them from a set of distractors. Track your recall span and compare against population benchmarks."
const canonicalUrl = "https://cogniarena.com/tests/verbal-memory"

const schemaJson = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    applicationCategory: "GameApplication",
    name: "Verbal Memory Test",
    description:
      "Verbal working memory assessment measuring word recall from growing lists with distractors.",
    about: { "@type": "Thing", name: "Working Memory" },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: "https://cogniarena.com",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Memory Suite",
        item: "https://cogniarena.com/tests",
      },
      {
        "@type": "ListItem",
        position: 3,
        name: "Verbal Memory Test",
        item: "https://cogniarena.com/tests/verbal-memory",
      },
    ],
  },
]
---

<Layout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  schemaJson={schemaJson}
>
  <div class="mx-auto flex w-full max-w-3xl flex-col gap-12">
    <header class="flex flex-col gap-3">
      <nav
        class="flex items-center gap-2 font-mono text-xs tracking-widest text-accent uppercase"
        aria-label="Breadcrumb"
      >
        <a href="/" class="hover:underline">Home</a><span>/</span><a
          href="/tests"
          class="hover:underline">Tests</a
        ><span>/</span><span class="text-muted">Verbal Memory Test</span>
      </nav>
      <h1
        class="text-3xl font-extrabold tracking-tight text-foreground md:text-4xl"
      >
        Verbal Memory Test
      </h1>
      <p class="max-w-2xl text-sm leading-relaxed text-muted md:text-base">
        Measure your verbal working memory capacity by memorizing lists of words
        and recalling them from a larger set. Difficulty increases with each
        round.
      </p>
    </header>
    <section class="w-full"><VerbalMemoryTest client:visible /></section>

    <HowItWorks
      testName="the Verbal Memory Test"
      learnSlug="verbal-memory"
      learnTitle="Verbal Recall Science"
      whatItMeasures="This test evaluates your verbal working memory by presenting a growing list of words to memorize. After each list, you must identify the correct words from a larger set of distractors, testing your phonological loop capacity."
      howScoringWorks="Each round adds one more word to remember. A correct recall advances you to the next level. Your score is the maximum number of words you can reliably recall. The average score is 8-10 words."
      whatAffectsResults="Your working memory capacity, chunking ability (grouping words into phrases), vocabulary familiarity, and focus during the presentation phase all affect your recall accuracy."
    />

    <!-- What Affects Your Score -->
    <article class="flex flex-col gap-4">
      <h2 class="text-xl font-semibold tracking-tight text-foreground">
        What Affects Your Verbal Memory Score
      </h2>
      <ul
        class="flex list-inside list-disc flex-col gap-2 text-sm leading-relaxed text-muted"
      >
        <li>
          <strong class="text-foreground">Working memory capacity</strong> — the number
          of items you can actively hold and manipulate
        </li>
        <li>
          <strong class="text-foreground">Chunking ability</strong> — grouping words
          into meaningful phrases extends effective memory span
        </li>
        <li>
          <strong class="text-foreground">Vocabulary familiarity</strong> — common
          words are easier to retain than unusual or abstract terms
        </li>
        <li>
          <strong class="text-foreground">Focus and attention</strong> — distraction
          during the presentation phase directly reduces recall accuracy
        </li>
      </ul>
    </article>

    <ExploreTests currentSlug="verbal-memory" />

    <div
      class="rounded-xl border border-card-border bg-subtle p-4 text-xs leading-relaxed text-muted shadow-sm"
    >
      <strong class="font-semibold text-foreground"
        >Self-Tracking Notice:</strong
      > For self-tracking and educational purposes only. Not a clinical or diagnostic
      evaluation.
    </div>
  </div>
</Layout>
