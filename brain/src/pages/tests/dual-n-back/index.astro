---
import Layout from "@/layouts/main.astro";
import DualNBackTest from "@/components/tests/DualNBackTest";

const title = "Dual N-Back Memory Test — Working Memory Trainer | CogniArena";
const description = "Test and train your visual and auditory working memory with the online Dual N-Back memory test. Scientifically referenced cognitive performance logging.";
const canonicalUrl = "https://cogniarena.com/tests/dual-n-back";

const schemaJson = {
  "@context": "https://schema.org",
  "@type": "Quiz",
  "name": "Dual N-Back Memory Test",
  "description": "Assess active working memory updates, spatial retention, and auditory tracking.",
  "about": {
    "@type": "Thing",
    "name": "Working Memory & Executive Control"
  }
};
---

<Layout title={title} description={description} canonicalUrl={canonicalUrl} schemaJson={schemaJson}>
  <div class="flex flex-col gap-12 w-full max-w-3xl mx-auto">
    <header class="flex flex-col gap-3">
      <div class="flex items-center gap-2 text-xs font-mono uppercase tracking-widest text-accent">
        <span>Assessment Suite</span>
        <span>&middot;</span>
        <span>Working Memory</span>
      </div>
      <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight text-foreground">
        Dual N-Back Memory Test
      </h1>
      <p class="text-zinc-500 dark:text-zinc-400 text-sm md:text-base leading-relaxed max-w-2xl">
        Improve visual-auditory working memory updates and active focus gates. Compare current stimuli to those shown N steps back.
      </p>
    </header>

    <section class="w-full">
      <DualNBackTest client:load />
    </section>

    <!-- Below the fold SEO and Methodology Content -->

      <!-- Medical/Scientific Disclaimer Notice -->
      <div class="p-4 rounded-xl border border-card-border bg-subtle text-xs text-zinc-500 dark:text-zinc-400 leading-relaxed shadow-sm">
        <strong class="text-foreground font-semibold">Self-Tracking Notice:</strong> This assessment is for self-tracking, educational, and cognitive training purposes only. It is not a clinical, medical, diagnostic, or neuropsychological evaluation, and may be affected by display latency, input delays, or device configuration.
      </div>

    <section class="flex flex-col gap-10 border-t border-card-border pt-12">
      <article class="flex flex-col gap-4">
        <h2 class="text-xl font-bold text-foreground tracking-tight">The Science of Dual N-Back Training</h2>
        <p class="text-zinc-400 text-sm leading-relaxed">
          The Dual N-Back task requires users to track two independent streams of sensory information: visual (grid positions) and auditory (spoken letters). In each trial, you must determine if the current items match the ones presented exactly N steps earlier. Research in cognitive psychology suggests N-back exercises increase working memory capacity and fluid reasoning.
        </p>
      </article>

      <article class="flex flex-col gap-4">
        <h2 class="text-xl font-bold text-foreground tracking-tight">Working Memory Gating & Cognitive Control</h2>
        <p class="text-zinc-400 text-sm leading-relaxed">
          Working memory serves as the active cache of the brain, managed by the dorsolateral prefrontal cortex. As N increases, the cognitive load grows exponentially, requiring active gating mechanisms to prune outdated items and latch onto new sequences. Regular N-back exercises help build concentration and prevent mental fatigue.
        </p>
      </article>
    </section>
  </div>
</Layout>
