---
import Layout from "@/layouts/main.astro";
import DualNBackTest from "@/components/tests/DualNBackTest";

const title = "Dual N-Back Memory Test — Working Memory Trainer | CogniArena";
const description = "Test and train your visual and auditory working memory with the online Dual N-Back memory test. Track cognitive performance with millisecond-accurate browser timers.";
const canonicalUrl = "https://cogniarena.com/tests/dual-n-back";

const schemaJson = [
  {
    "@context": "https://schema.org",
    "@type": "Quiz",
    "name": "Dual N-Back Memory Test",
    "description": "Assess active working memory updates, spatial retention, and auditory tracking.",
    "about": {
      "@type": "Thing",
      "name": "Working Memory & Executive Control"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is a good Dual N-Back score?",
        "acceptedAnswer": { "@type": "Answer", "text": "Most beginners start at 1-back or 2-back. Reaching 3-back consistently is above average, 4-back is advanced, and 5+ back is elite. Research suggests regular training can increase your working memory capacity over time." }
      },
      {
        "@type": "Question",
        "name": "Does Dual N-Back training improve fluid intelligence?",
        "acceptedAnswer": { "@type": "Answer", "text": "Some studies suggest that Dual N-Back training can improve working memory capacity and fluid reasoning, though results are mixed. Consistent practice over several weeks tends to show the most benefit for attention and memory tasks." }
      },
      {
        "@type": "Question",
        "name": "Is this a medical diagnostic tool?",
        "acceptedAnswer": { "@type": "Answer", "text": "No. This test is designed for self-tracking, performance benchmarking, and entertainment purposes. It is not a clinical cognitive assessment." }
      }
    ]
  }
];
---

<Layout title={title} description={description} canonicalUrl={canonicalUrl} schemaJson={schemaJson}>
  <div class="flex flex-col gap-12 w-full max-w-3xl mx-auto">
    <header class="flex flex-col gap-3">
      <div class="flex items-center gap-2 text-xs font-mono uppercase tracking-widest text-accent">
        <span>Assessment Suite</span>
        <span>&middot;</span>
        <span>Working Memory</span>
      </div>
      <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight text-foreground">
        Dual N-Back Memory Test
      </h1>
      <p class="text-muted text-sm md:text-base leading-relaxed max-w-2xl">
        Improve visual-auditory working memory updates and active focus gates. Compare current stimuli to those shown N steps back.
      </p>
    </header>

    <section class="w-full">
      <DualNBackTest client:load />
    </section>

    <!-- Below the fold SEO and Methodology Content -->

      <!-- Medical/Scientific Disclaimer Notice -->
      <div class="p-4 rounded-xl border border-card-border bg-subtle text-xs text-muted leading-relaxed shadow-sm">
        <strong class="text-foreground font-semibold">Self-Tracking Notice:</strong> This assessment is for self-tracking, educational, and cognitive training purposes only. It is not a clinical, medical, diagnostic, or neuropsychological evaluation, and may be affected by display latency, input delays, or device configuration.
      </div>

    <section class="flex flex-col gap-10 border-t border-card-border pt-12">
      <article class="flex flex-col gap-4">
        <h2 class="text-xl font-bold text-foreground tracking-tight">The Science of Dual N-Back Training</h2>
        <p class="text-secondary text-sm leading-relaxed">
          The Dual N-Back task requires users to track two independent streams of sensory information: visual (grid positions) and auditory (spoken letters). In each trial, you must determine if the current items match the ones presented exactly N steps earlier. Research in cognitive psychology suggests N-back exercises increase working memory capacity and fluid reasoning.
        </p>
      </article>

      <article class="flex flex-col gap-4">
        <h2 class="text-xl font-bold text-foreground tracking-tight">Working Memory Gating & Cognitive Control</h2>
        <p class="text-secondary text-sm leading-relaxed">
          Working memory serves as the active cache of the brain, managed by the dorsolateral prefrontal cortex. As N increases, the cognitive load grows exponentially, requiring active gating mechanisms to prune outdated items and latch onto new sequences. Regular N-back exercises help build concentration and prevent mental fatigue.
        </p>
      </article>
    </section>

    <!-- What Affects Your Score -->
    <article class="flex flex-col gap-4">
      <h2 class="text-xl font-semibold text-foreground tracking-tight">What Affects Your Dual N-Back Score</h2>
      <ul class="flex flex-col gap-2 text-muted text-sm leading-relaxed list-disc list-inside">
        <li><strong class="text-foreground">Working memory capacity</strong> — the number of items you can actively maintain and update simultaneously</li>
        <li><strong class="text-foreground">Attention gating</strong> — your ability to filter out irrelevant stimuli and focus on target updates</li>
        <li><strong class="text-foreground">Processing speed</strong> — faster encoding and retrieval of visual and auditory information</li>
        <li><strong class="text-foreground">Display latency</strong> — slower monitors add minor overhead to stimulus recognition</li>
      </ul>
    </article>

    <!-- Related Tests -->
    <article class="flex flex-col gap-3">
      <h2 class="text-lg font-semibold text-foreground tracking-tight">Related Tests</h2>
      <div class="flex flex-wrap gap-2">
        <a href="/tests/number-memory" class="px-3 py-1.5 rounded-lg border border-card-border bg-subtle text-xs text-muted hover:border-accent hover:text-foreground transition-colors">Number Memory →</a>
        <a href="/tests/visual-pattern" class="px-3 py-1.5 rounded-lg border border-card-border bg-subtle text-xs text-muted hover:border-accent hover:text-foreground transition-colors">Visual Pattern →</a>
        <a href="/tests/stroop" class="px-3 py-1.5 rounded-lg border border-card-border bg-subtle text-xs text-muted hover:border-accent hover:text-foreground transition-colors">Stroop Test →</a>
      </div>
    </article>

    <!-- FAQ Section -->
    <article class="flex flex-col gap-6">
      <h2 class="text-xl font-semibold text-foreground tracking-tight">Frequently Asked Questions</h2>
      <div class="flex flex-col gap-4">
        <div class="flex flex-col gap-1.5">
          <h3 class="text-sm font-medium text-foreground">What is a good Dual N-Back score?</h3>
          <p class="text-muted text-sm leading-relaxed">Most beginners start at 1-back or 2-back. Reaching 3-back consistently is above average, 4-back is advanced, and 5+ back is elite. Research suggests regular training can increase your working memory capacity over time.</p>
        </div>
        <div class="flex flex-col gap-1.5">
          <h3 class="text-sm font-medium text-foreground">Does Dual N-Back training improve fluid intelligence?</h3>
          <p class="text-muted text-sm leading-relaxed">Some studies suggest that Dual N-Back training can improve working memory capacity and fluid reasoning, though results are mixed. Consistent practice over several weeks tends to show the most benefit for attention and memory tasks.</p>
        </div>
        <div class="flex flex-col gap-1.5">
          <h3 class="text-sm font-medium text-foreground">Is this a medical diagnostic tool?</h3>
          <p class="text-muted text-sm leading-relaxed">No. This test is designed for self-tracking, performance benchmarking, and entertainment purposes. It is not a clinical cognitive assessment.</p>
        </div>
      </div>
    </article>
  </div>
</Layout>
