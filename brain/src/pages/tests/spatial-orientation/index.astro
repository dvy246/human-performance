---
import Layout from "@/layouts/main.astro"
import SpatialOrientationTest from "@/components/tests/SpatialOrientationTest"
import ExploreTests from "@/components/ui/ExploreTests.astro"
import HowItWorks from "@/components/ui/HowItWorks.astro"

const title = "Spatial Orientation Test – Mental Rotation | CogniArena"
const description =
  "Test your spatial reasoning ability with mental rotation challenges. Identify rotated patterns in this free online cognitive assessment."
const canonicalUrl = "https://cogniarena.com/tests/spatial-orientation"

const schemaJson = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    applicationCategory: "GameApplication",
    name: "Spatial Orientation Test | CogniArena",
    description:
      "Mental rotation cognitive assessment. Identify rotated patterns to measure spatial reasoning ability.",
    about: { "@type": "Thing", name: "Spatial Reasoning / Mental Rotation" },
    educationalAlignment: {
      "@type": "AlignmentObject",
      alignmentType: "educationalRequirement",
      educationalFramework: "Cognitive Science",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: "https://cogniarena.com",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Spatial",
        item: "https://cogniarena.com/",
      },
      {
        "@type": "ListItem",
        position: 3,
        name: "Spatial Orientation Test",
        item: "https://cogniarena.com/tests/spatial-orientation",
      },
    ],
  },
]
---

<Layout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  schemaJson={schemaJson}
>
  <div class="mx-auto flex w-full max-w-3xl flex-col gap-12">
    <header class="flex flex-col gap-3">
      <nav
        class="flex items-center gap-2 font-mono text-xs tracking-widest text-accent uppercase"
        aria-label="Breadcrumb"
      >
        <a href="/" class="hover:underline">Home</a><span>/</span><a
          href="/tests"
          class="hover:underline">Tests</a
        ><span>/</span><span class="text-muted">Spatial Orientation Test</span>
      </nav>
      <h1
        class="text-3xl font-extrabold tracking-tight text-foreground md:text-4xl"
      >
        Spatial Orientation Test
      </h1>
      <p class="max-w-2xl text-sm leading-relaxed text-muted md:text-base">
        Mentally rotate patterns and identify the matching orientation. 12
        trials with increasing rotation angles to measure your spatial
        reasoning.
      </p>
    </header>
    <section class="w-full"><SpatialOrientationTest client:visible /></section>

    <HowItWorks
      testName="the Spatial Orientation Test"
      learnSlug="spatial-orientation"
      learnTitle="Mental Rotation Science"
      whatItMeasures="Measures mental rotation ability — a core component of spatial intelligence. A grid pattern is shown, then rotated. You must identify the correct rotated orientation from multiple choices."
      howScoringWorks="Score is the number of correct rotations identified out of 12 trials, with response time tracked. Faster correct responses indicate stronger spatial visualization ability."
      whatAffectsResults="Your mental rotation speed (Shepard & Metzler showed ~50ms per degree of rotation), visual working memory, practice with spatial tasks, and display quality all affect your score."
    />

    <!-- What Affects Your Score -->
    <article class="flex flex-col gap-4">
      <h2 class="text-xl font-semibold tracking-tight text-foreground">
        What Affects Your Spatial Score
      </h2>
      <ul
        class="flex list-inside list-disc flex-col gap-2 text-sm leading-relaxed text-muted"
      >
        <li>
          <strong class="text-foreground">Visual working memory</strong> — holding
          the reference pattern in mind while comparing rotated versions
        </li>
        <li>
          <strong class="text-foreground">Mental rotation speed</strong> — how quickly
          your brain can simulate the pattern at different angles
        </li>
        <li>
          <strong class="text-foreground">Practice with spatial tasks</strong> — regular
          engagement with puzzles, maps, or 3D software builds stronger spatial schemas
        </li>
        <li>
          <strong class="text-foreground">Display quality</strong> — higher resolution
          and refresh rates make subtle pattern differences easier to detect
        </li>
      </ul>
    </article>

    <ExploreTests currentSlug="spatial-orientation" />

    <div
      class="rounded-xl border border-card-border bg-subtle p-4 text-xs leading-relaxed text-muted shadow-sm"
    >
      <strong class="font-semibold text-foreground"
        >Self-Tracking Notice:</strong
      > For self-tracking and educational purposes only. Not a clinical or diagnostic
      evaluation.
    </div>
  </div>
</Layout>
