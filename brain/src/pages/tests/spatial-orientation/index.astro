---
import Layout from "@/layouts/main.astro";
import SpatialOrientationTest from "@/components/tests/SpatialOrientationTest";
import ExploreTests from "@/components/ui/ExploreTests.astro";
import HowItWorks from "@/components/ui/HowItWorks.astro";

const title = "Spatial Orientation Test – Mental Rotation | CogniArena";
const description = "Test your spatial reasoning ability with mental rotation challenges. Identify rotated patterns in this free online cognitive assessment.";
const canonicalUrl = "https://cogniarena.com/tests/spatial-orientation";

const schemaJson = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "applicationCategory": "GameApplication",
    "name": "Spatial Orientation Test | CogniArena",
    "description": "Mental rotation cognitive assessment. Identify rotated patterns to measure spatial reasoning ability.",
    "about": { "@type": "Thing", "name": "Spatial Reasoning / Mental Rotation" },
    "educationalAlignment": { "@type": "AlignmentObject", "alignmentType": "educationalRequirement", "educationalFramework": "Cognitive Science" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is mental rotation?",
        "acceptedAnswer": { "@type": "Answer", "text": "Mental rotation is the ability to mentally manipulate a 2D or 3D representation of an object to determine how it would look from different angles. It engages the same spatial processing pathways used in navigation, engineering, and sports." }
      },
      {
        "@type": "Question",
        "name": "Can spatial reasoning be improved?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. Research shows that regular practice with spatial tasks — including mental rotation, block design, and map reading — can improve spatial working memory capacity and reduce rotation response times over weeks of training." }
      },
      {
        "@type": "Question",
        "name": "Is this a medical diagnostic tool?",
        "acceptedAnswer": { "@type": "Answer", "text": "No. This test is designed for self-tracking, performance benchmarking, and entertainment purposes. It is not a clinical cognitive assessment." }
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://cogniarena.com" },
      { "@type": "ListItem", "position": 2, "name": "Spatial", "item": "https://cogniarena.com/#suite" },
      { "@type": "ListItem", "position": 3, "name": "Spatial Orientation Test", "item": "https://cogniarena.com/tests/spatial-orientation" }
    ]
  }
];
---
<Layout title={title} description={description} canonicalUrl={canonicalUrl} schemaJson={schemaJson}>
  <div class="flex flex-col gap-12 w-full max-w-3xl mx-auto">
    <header class="flex flex-col gap-3">
      <nav class="flex items-center gap-2 text-xs font-mono uppercase tracking-widest text-accent" aria-label="Breadcrumb"><a href="/" class="hover:underline">Home</a><span>/</span><a href="/#suite" class="hover:underline">Tests</a><span>/</span><span class="text-muted">Spatial Orientation Test</span></nav>
      <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight text-foreground">Spatial Orientation Test</h1>
      <p class="text-muted text-sm md:text-base leading-relaxed max-w-2xl">Mentally rotate patterns and identify the matching orientation. 12 trials with increasing rotation angles to measure your spatial reasoning.</p>
    </header>
    <section class="w-full"><SpatialOrientationTest client:visible /></section>

    <HowItWorks
      testName="the Spatial Orientation Test"
      whatItMeasures="Measures mental rotation ability — a core component of spatial intelligence. A grid pattern is shown, then rotated. You must identify the correct rotated orientation from multiple choices."
      howScoringWorks="Score is the number of correct rotations identified out of 12 trials, with response time tracked. Faster correct responses indicate stronger spatial visualization ability."
      whatAffectsResults="Your mental rotation speed (Shepard & Metzler showed ~50ms per degree of rotation), visual working memory, practice with spatial tasks, and display quality all affect your score."
    />

    <!-- What Affects Your Score -->
    <article class="flex flex-col gap-4">
      <h2 class="text-xl font-semibold text-foreground tracking-tight">What Affects Your Spatial Score</h2>
      <ul class="flex flex-col gap-2 text-muted text-sm leading-relaxed list-disc list-inside">
        <li><strong class="text-foreground">Visual working memory</strong> — holding the reference pattern in mind while comparing rotated versions</li>
        <li><strong class="text-foreground">Mental rotation speed</strong> — how quickly your brain can simulate the pattern at different angles</li>
        <li><strong class="text-foreground">Practice with spatial tasks</strong> — regular engagement with puzzles, maps, or 3D software builds stronger spatial schemas</li>
        <li><strong class="text-foreground">Display quality</strong> — higher resolution and refresh rates make subtle pattern differences easier to detect</li>
      </ul>
    </article>

    <ExploreTests currentSlug="spatial-orientation" />

    <!-- FAQ Section -->
    <article class="flex flex-col gap-6">
      <h2 class="text-xl font-semibold text-foreground tracking-tight">Frequently Asked Questions</h2>
      <div class="flex flex-col gap-4">
        <div class="flex flex-col gap-1.5">
          <h3 class="text-sm font-medium text-foreground">What is mental rotation?</h3>
          <p class="text-muted text-sm leading-relaxed">Mental rotation is the ability to mentally manipulate a 2D or 3D representation of an object to determine how it would look from different angles. It engages the same spatial processing pathways used in navigation, engineering, and sports.</p>
        </div>
        <div class="flex flex-col gap-1.5">
          <h3 class="text-sm font-medium text-foreground">Can spatial reasoning be improved?</h3>
          <p class="text-muted text-sm leading-relaxed">Yes. Research shows that regular practice with spatial tasks — including mental rotation, block design, and map reading — can improve spatial working memory capacity and reduce rotation response times over weeks of training.</p>
        </div>
        <div class="flex flex-col gap-1.5">
          <h3 class="text-sm font-medium text-foreground">Is this a medical diagnostic tool?</h3>
          <p class="text-muted text-sm leading-relaxed">No. This test is designed for self-tracking, performance benchmarking, and entertainment purposes. It is not a clinical cognitive assessment.</p>
        </div>
      </div>
    </article>

    <div class="p-4 rounded-xl border border-card-border bg-subtle text-xs text-muted leading-relaxed shadow-sm">
      <strong class="text-foreground font-semibold">Self-Tracking Notice:</strong> For self-tracking and educational purposes only. Not a clinical or diagnostic evaluation.
    </div>
  </div>
</Layout>
