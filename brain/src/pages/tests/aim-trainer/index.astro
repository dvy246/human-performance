---
import Layout from "@/layouts/main.astro"
import AimTrainer from "@/components/tests/AimTrainer"
import ExploreTests from "@/components/ui/ExploreTests.astro"
import HowItWorks from "@/components/ui/HowItWorks.astro"

const title = "Aim Trainer Online — Reflex & Hand-Eye Coordination | CogniArena"
const description =
  "Benchmark your target acquisition latency and mouse coordinate precision. Learn about Fitts's Law and optimize your mouse DPI and sensitivity."
const canonicalUrl = "https://cogniarena.com/tests/aim-trainer"

const schemaJson = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    applicationCategory: "GameApplication",
    name: "Aim Precision Trainer",
    description:
      "An online 2D canvas assessment targeting hand-eye coordination speed, pinpoint accuracy rates, and distance offsets.",
    about: {
      "@type": "Thing",
      name: "Motor Coordination",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: "https://cogniarena.com",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Precision Suite",
        item: "https://cogniarena.com/tests",
      },
      {
        "@type": "ListItem",
        position: 3,
        name: "Aim Trainer",
        item: "https://cogniarena.com/tests/aim-trainer",
      },
    ],
  },
]
---

<Layout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  schemaJson={schemaJson}
>
  <div class="mx-auto flex w-full max-w-3xl flex-col gap-12">
    <!-- Header Section -->
    <header class="flex flex-col gap-3">
      <nav
        class="flex items-center gap-2 font-mono text-xs tracking-widest text-accent uppercase"
        aria-label="Breadcrumb"
      >
        <a href="/" class="hover:underline">Home</a>
        <span>/</span>
        <a href="/tests" class="hover:underline">Tests</a>
        <span>/</span>
        <span class="text-muted">Aim Trainer</span>
      </nav>
      <h1
        class="text-3xl font-extrabold tracking-tight text-foreground md:text-4xl"
      >
        Aim Precision Trainer
      </h1>
      <p class="max-w-2xl text-sm leading-relaxed text-muted md:text-base">
        Benchmark your target acquisition latency and mouse coordinate
        precision. Learn about Fitts's Law and optimize your mouse DPI and
        sensitivity.
      </p>
    </header>

    <!-- Interactive Game Island Container -->
    <section class="w-full">
      <AimTrainer client:visible />
    </section>

    <!-- Below the fold SEO and Methodology Content -->

    <!-- Medical/Scientific Disclaimer Notice -->
    <div
      class="rounded-xl border border-card-border bg-subtle p-4 text-xs leading-relaxed text-muted shadow-sm"
    >
      <strong class="font-semibold text-foreground"
        >Self-Tracking Notice:</strong
      > This assessment is for self-tracking, educational, and cognitive training
      purposes only. It is not a clinical, medical, diagnostic, or neuropsychological
      evaluation, and may be affected by display latency, input delays, or device
      configuration.
    </div>

    <section class="flex flex-col gap-10 border-t border-card-border pt-12">
      <HowItWorks
        testName="the Aim Precision Trainer"
        learnSlug="aim-training"
        learnTitle="Aim Training Science"
        whatItMeasures="This test measures your hand-eye coordination speed, pinpoint clicking accuracy, and distance offset from the absolute center of moving and static targets."
        howScoringWorks="Acquire 30 targets. Your final score is the average acquisition latency (in ms) combined with accuracy and pixel offset metrics."
        whatAffectsResults="DPI settings, screen refresh rates, mouse weight, fatigue, and posture all impact your motor performance."
      />

      {/* Scientific Methodology link */}
      <div class="flex items-center gap-3 text-xs text-muted">
        <div
          class="flex h-6 w-6 items-center justify-center rounded-full border border-accent/20 bg-accent/10 font-mono text-[10px] font-bold text-accent"
        >
          BB
        </div>
        <span
          >Learn about calibration protocols and scientific formulas on our <a
            href="/methodology"
            class="font-medium text-accent hover:underline">Methodology Page</a
          >.</span
        >
      </div>

      <!-- What is it -->
      <article class="flex flex-col gap-4">
        <h3 class="text-lg font-semibold tracking-tight text-foreground">
          Understanding Your Aim Performance
        </h3>
        <p class="text-sm leading-relaxed text-muted">
          The Aim Precision test is designed to measure your hand-eye motor
          pathways. Unlike simple click challenges, this assessment tests target
          acquisition—demanding that your eyes track a target, your brain maps
          its spatial coordinates, and your motor cortex commands your arm and
          hand to glide the mouse pointer to the exact sub-pixel boundary before
          clicking.
        </p>
        <p class="text-sm leading-relaxed text-muted">
          This test is heavily used in esports training, where spatial
          coordinate speed and clicking accuracy directly dictate match outcomes
          in FPS games.
        </p>
      </article>

      <!-- Fitts's Law -->
      <article class="flex flex-col gap-4">
        <h2 class="text-xl font-semibold tracking-tight text-foreground">
          Fitts's Law: The Physics of Aim
        </h2>
        <p class="text-sm leading-relaxed text-muted">
          Human movement acquisition is governed by **Fitts's Law**, a
          scientific model predicting that the time required to rapidly move to
          a target is a function of the ratio between the distance to the target
          ($D$) and the width of the target ($W$). The model is formulated as:
        </p>
        <div
          class="my-2 flex items-center justify-center rounded-lg border border-card-border bg-subtle p-4"
        >
          <code class="font-mono text-sm text-foreground"
            >MT = a + b &middot; log₂(2D / W)</code
          >
        </div>
        <p class="text-sm leading-relaxed text-muted">
          Where **MT** is the movement time. Fitts's Law demonstrates that as
          targets shrink or travel further across the canvas, target acquisition
          speed decays logarithmically. In competitive training, improving your
          coefficient **b** (motor skill efficiency) is what allows you to snap
          to small targets without slowing down.
        </p>
      </article>

      <!-- Pinpoint Error Offset -->
      <article class="flex flex-col gap-4">
        <h2 class="text-xl font-semibold tracking-tight text-foreground">
          Understanding Pinpoint Error (Offset)
        </h2>
        <p class="text-sm leading-relaxed text-muted">
          Typical aim games only track hits and misses. CogniArena goes deeper
          by tracking **Pinpoint Error (Offset)**—measuring the exact Euclidean
          distance (in pixels) between your click coordinate and the absolute
          center of the target.
        </p>
        <p class="text-sm leading-relaxed text-muted">
          Analyzing your offset average tells you whether your mouse sensitivity
          is properly configured. If your average offset is high but you are
          hitting targets, you are likely clicking the margins of targets,
          indicating minor overshoot or undershoot. This is a clear indicator
          that you should adjust your mouse DPI or physical seat alignment.
        </p>
      </article>

      <ExploreTests currentSlug="aim-trainer" />

      </section>
  </div>
</Layout>
