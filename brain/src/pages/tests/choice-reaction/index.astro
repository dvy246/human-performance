---
import Layout from "@/layouts/main.astro"
import ChoiceReactionTest from "@/components/tests/ChoiceReactionTest"
import ExploreTests from "@/components/ui/ExploreTests.astro"
import HowItWorks from "@/components/ui/HowItWorks.astro"

const title = "Choice Reaction Time Test — Hick's Law Grid | CogniArena"
const description =
  "Test your cognitive processing latency with our choice reaction grid. Map visual colors to keyboard hotkeys, manage decision accuracy, and beat Hick's Law."
const canonicalUrl = "https://cogniarena.com/tests/choice-reaction"

const schemaJson = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    applicationCategory: "GameApplication",
    name: "Choice Reaction Test",
    description:
      "A choice reaction cognitive assessment mapping multiple color stimuli to keyboard inputs, measuring the accuracy-speed trade-off.",
    about: {
      "@type": "Thing",
      name: "Hick's Law",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
      {
        "@type": "Question",
        name: "How does this test apply to real-world tasks?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Choice reaction is the baseline for almost all real-world activities. In driving, a simple reaction is slamming the brakes when a red light appears. A choice reaction is deciding whether to swerve left, swerve right, or brake when an obstacle appears in your lane.",
        },
      },
      {
        "@type": "Question",
        name: "Why are keys mapped to R, G, B, Y?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "We map inputs to the first letter of each color: Red, Green, Blue, and Yellow. This semantic mapping creates a minor cognitive association pathway that you must master to achieve elite reaction scores.",
        },
      },
      {
        "@type": "Question",
        name: "Is this a medical diagnostic tool?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "No. The Choice Reaction Test is designed for cognitive training, self-tracking, and entertainment purposes. It is not a clinical, medical, or diagnostic evaluation.",
        },
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: "https://cogniarena.com",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Reaction & Reflexes",
        item: "https://cogniarena.com/tests",
      },
      {
        "@type": "ListItem",
        position: 3,
        name: "Choice Reaction Test",
        item: "https://cogniarena.com/tests/choice-reaction",
      },
    ],
  },
]
---

<Layout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  schemaJson={schemaJson}
>
  <div class="mx-auto flex w-full max-w-3xl flex-col gap-12">
    <!-- Header Section -->
    <header class="flex flex-col gap-3">
      <nav
        class="flex items-center gap-2 font-mono text-xs tracking-widest text-accent uppercase"
        aria-label="Breadcrumb"
      >
        <a href="/" class="hover:underline">Home</a>
        <span>/</span>
        <a href="/tests" class="hover:underline">Tests</a>
        <span>/</span>
        <span class="text-muted">Choice Reaction Test</span>
      </nav>
      <h1
        class="text-3xl font-extrabold tracking-tight text-foreground md:text-4xl"
      >
        Choice Reaction Test
      </h1>
      <p class="max-w-2xl text-sm leading-relaxed text-muted md:text-base">
        Assess your visual recognition latency and cognitive choice selection.
        Press keyboard hotkeys **R**, **G**, **B**, or **Y** as colors appear.
        Precision is critical: incorrect selections add a **+150ms penalty**.
      </p>
    </header>

    <!-- Interactive Game Island Container -->
    <section class="w-full">
      <ChoiceReactionTest client:visible />
    </section>

    <!-- Below the fold SEO and Methodology Content -->

    <!-- Medical/Scientific Disclaimer Notice -->
    <div
      class="rounded-xl border border-card-border bg-subtle p-4 text-xs leading-relaxed text-muted shadow-sm"
    >
      <strong class="font-semibold text-foreground"
        >Self-Tracking Notice:</strong
      > This assessment is for self-tracking, educational, and cognitive training
      purposes only. It is not a clinical, medical, diagnostic, or neuropsychological
      evaluation, and may be affected by display latency, input delays, or device
      configuration.
    </div>

    <section class="flex flex-col gap-10 border-t border-card-border pt-12">
      <HowItWorks
        testName="the Choice Reaction Test"
        learnSlug="choice-reaction"
        learnTitle="Choice Reaction Time Science"
        whatItMeasures="Presents colored stimuli (Red, Green, Blue, Yellow) requiring you to press the matching keyboard key as fast as possible. Unlike simple reaction tests, you must first identify the color, then select the correct response — testing decision-making under cognitive load."
        howScoringWorks="Score combines response speed and accuracy. Incorrect responses incur a time penalty. Your effective score reflects both processing speed (governed by Hick's Law) and cognitive decision efficiency."
        whatAffectsResults="The number of choices (Hick's Law — each additional option adds ~50-70ms), your familiarity with keyboard mappings, and current cognitive processing speed all affect results."
      />

      {/* Scientific Methodology link */}
      <div class="flex items-center gap-3 text-xs text-muted">
        <div
          class="flex h-6 w-6 items-center justify-center rounded-full border border-accent/20 bg-accent/10 font-mono text-[10px] font-bold text-accent"
        >
          BB
        </div>
        <span
          >Learn about calibration protocols and scientific formulas on our <a
            href="/methodology"
            class="font-medium text-accent hover:underline">Methodology Page</a
          >.</span
        >
      </div>

      <!-- What is it -->
      <article class="flex flex-col gap-4">
        <h2 class="text-xl font-semibold tracking-tight text-foreground">
          What is the Choice Reaction Test?
        </h2>
        <p class="text-sm leading-relaxed text-muted">
          Unlike simple reaction tests where you react to any stimulus change, a
          **choice reaction test** introduces multiple distinct stimuli, each
          requiring a unique response. This test introduces four colored targets
          (Red, Green, Blue, Yellow), demanding that you identify the color,
          select the appropriate response key or pad, and execute the motor
          trigger.
        </p>
      </article>

      <!-- Hick's Law -->
      <article class="flex flex-col gap-4">
        <h2 class="text-xl font-semibold tracking-tight text-foreground">
          Hick's Law: How Choice Retards Reflex Speed
        </h2>
        <p class="text-sm leading-relaxed text-muted">
          In cognitive psychology, **Hick's Law** states that the time it takes
          to make a decision increases logarithmically with the number of
          options ($n$) available. The mathematical model is expressed as:
        </p>
        <div
          class="my-2 flex items-center justify-center rounded-lg border border-card-border bg-subtle p-4"
        >
          <code class="font-mono text-sm text-foreground"
            >RT = a + b &middot; log₂(n)</code
          >
        </div>
        <p class="text-sm leading-relaxed text-muted">
          Where **RT** is the reaction time, **a** is the total non-decision
          latency (such as optical transmission speed), **b** is an empirical
          constant, and **n** is the number of options.
        </p>
        <p class="text-sm leading-relaxed text-muted">
          By expanding the test from a single stimulus (simple reaction) to four
          choices ($n = 4$), your brain must engage executive sorting centers in
          the prefrontal cortex. This decision processing loop typically adds
          **150 to 220 milliseconds** of cognitive lag, pushing normal averages
          up to **380ms to 480ms**.
        </p>
      </article>

      <!-- Speed-Accuracy Tradeoff -->
      <article class="flex flex-col gap-4">
        <h2 class="text-xl font-semibold tracking-tight text-foreground">
          Measuring the Speed-Accuracy Trade-off
        </h2>
        <p class="text-sm leading-relaxed text-muted">
          When people try to react as fast as possible, their error rates
          naturally spike. This is known as the **speed-accuracy trade-off**.
        </p>
        <p class="text-sm leading-relaxed text-muted">
          To prevent users from gaming the test by randomly spamming keys, our
          assessment implements a **+150ms penalty** for every incorrect choice.
          This forces your brain to balance rapid motor release with visual
          verification, providing a much truer assessment of executive function
          than speed alone.
        </p>
      </article>

      <ExploreTests currentSlug="choice-reaction" />

      <!-- FAQ Section -->
      <article class="flex flex-col gap-6">
        <h2 class="text-xl font-semibold tracking-tight text-foreground">
          Frequently Asked Questions
        </h2>

        <div class="flex flex-col gap-4">
          <div class="flex flex-col gap-1.5">
            <h3 class="text-sm font-medium text-foreground">
              How does this test apply to real-world tasks?
            </h3>
            <p class="text-sm leading-relaxed text-muted">
              Choice reaction is the baseline for almost all real-world
              activities. In driving, a simple reaction is slamming the brakes
              when a red light appears. A choice reaction is deciding whether to
              swerve left, swerve right, or brake when an obstacle appears in
              your lane.
            </p>
          </div>
          <div class="flex flex-col gap-1.5">
            <h3 class="text-sm font-medium text-foreground">
              Why are keys mapped to R, G, B, Y?
            </h3>
            <p class="text-sm leading-relaxed text-muted">
              We map inputs to the first letter of each color: **R**ed,
              **G**reen, **B**lue, and **Y**ellow. This semantic mapping creates
              a minor cognitive association pathway that you must master to
              achieve elite reaction scores.
            </p>
          </div>
          <div class="flex flex-col gap-1.5">
            <h3 class="text-sm font-medium text-foreground">
              Is this a medical diagnostic tool?
            </h3>
            <p class="text-sm leading-relaxed text-muted">
              No. The Choice Reaction Test is designed for cognitive training,
              self-tracking, and entertainment purposes. It is not a clinical,
              medical, or diagnostic evaluation.
            </p>
          </div>
        </div>
      </article>
    </section>
  </div>
</Layout>
