---
import Layout from "@/layouts/main.astro";
import PlanningTest from "@/components/tests/PlanningTest";
import ExploreTests from "@/components/ui/ExploreTests.astro";
import HowItWorks from "@/components/ui/HowItWorks.astro";

const title = "Planning Test – Tower of Hanoi | CogniArena";
const description = "Test your planning and problem-solving skills with the Tower of Hanoi puzzle. Move all disks to the target peg in minimal moves.";
const canonicalUrl = "https://cogniarena.com/tests/planning";

const schemaJson = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "applicationCategory": "GameApplication",
    "name": "Planning Test – Tower of Hanoi | CogniArena",
    "description": "Classic Tower of Hanoi puzzle with 4 disks. Solve in minimal moves to measure planning ability.",
    "about": { "@type": "Thing", "name": "Executive Function / Planning" },
    "educationalAlignment": { "@type": "AlignmentObject", "alignmentType": "educationalRequirement", "educationalFramework": "Cognitive Science" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the minimum number of moves for 4 disks?",
        "acceptedAnswer": { "@type": "Answer", "text": "The optimal solution for 4 disks is 15 moves. The formula is 2^n - 1, where n is the number of disks. Each additional disk doubles the minimum moves plus one." }
      },
      {
        "@type": "Question",
        "name": "What cognitive skill does the Tower of Hanoi measure?",
        "acceptedAnswer": { "@type": "Answer", "text": "It measures planning ability, working memory, and the capacity to hold multiple future states in mind simultaneously. Strong performers think several moves ahead and recognize recursive sub-goals." }
      },
      {
        "@type": "Question",
        "name": "Is this a medical diagnostic tool?",
        "acceptedAnswer": { "@type": "Answer", "text": "No. This test is designed for self-tracking, performance benchmarking, and entertainment purposes. It is not a clinical cognitive assessment." }
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://cogniarena.com" },
      { "@type": "ListItem", "position": 2, "name": "Executive", "item": "https://cogniarena.com/#suite" },
      { "@type": "ListItem", "position": 3, "name": "Planning Test", "item": "https://cogniarena.com/tests/planning" }
    ]
  }
];
---
<Layout title={title} description={description} canonicalUrl={canonicalUrl} schemaJson={schemaJson}>
  <div class="flex flex-col gap-12 w-full max-w-3xl mx-auto">
    <header class="flex flex-col gap-3">
      <nav class="flex items-center gap-2 text-xs font-mono uppercase tracking-widest text-accent" aria-label="Breadcrumb"><a href="/" class="hover:underline">Home</a><span>/</span><a href="/#suite" class="hover:underline">Tests</a><span>/</span><span class="text-muted">Planning Test</span></nav>
      <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight text-foreground">Planning Test</h1>
      <p class="text-muted text-sm md:text-base leading-relaxed max-w-2xl">Classic Tower of Hanoi puzzle with 4 disks. Move the entire stack to the right peg in as few moves as possible — the optimal solution is 15 moves.</p>
    </header>
    <section class="w-full"><PlanningTest client:visible /></section>

    <HowItWorks
      testName="the Planning Test"
      whatItMeasures="Tests executive planning ability using the Tower of Hanoi puzzle. Move a stack of 4 disks from one peg to another following two rules: only one disk at a time, and a larger disk cannot rest on a smaller one."
      howScoringWorks="Score optimizes for minimum moves (the optimal solution is 15) and completion time. Fewer moves and faster completion indicate stronger forward-planning ability and working memory capacity."
      whatAffectsResults="Your working memory capacity, recursive pattern recognition ability, impulse control (resisting suboptimal first moves), and display input latency all affect your planning score."
    />

    <!-- What Affects Your Score -->
    <article class="flex flex-col gap-4">
      <h2 class="text-xl font-semibold text-foreground tracking-tight">What Affects Your Planning Score</h2>
      <ul class="flex flex-col gap-2 text-muted text-sm leading-relaxed list-disc list-inside">
        <li><strong class="text-foreground">Working memory capacity</strong> — holding multiple future board states in mind simultaneously</li>
        <li><strong class="text-foreground">Recursive pattern recognition</strong> — recognizing that large goals decompose into repeated sub-goals</li>
        <li><strong class="text-foreground">Impulse control</strong> — resisting the urge to make an obvious but suboptimal first move</li>
        <li><strong class="text-foreground">Display input latency</strong> — slower monitors add minor overhead to each move decision</li>
      </ul>
    </article>

    <ExploreTests currentSlug="planning" />

    <!-- FAQ Section -->
    <article class="flex flex-col gap-6">
      <h2 class="text-xl font-semibold text-foreground tracking-tight">Frequently Asked Questions</h2>
      <div class="flex flex-col gap-4">
        <div class="flex flex-col gap-1.5">
          <h3 class="text-sm font-medium text-foreground">What is the minimum number of moves for 4 disks?</h3>
          <p class="text-muted text-sm leading-relaxed">The optimal solution for 4 disks is 15 moves. The formula is 2^n - 1, where n is the number of disks. Each additional disk doubles the minimum moves plus one.</p>
        </div>
        <div class="flex flex-col gap-1.5">
          <h3 class="text-sm font-medium text-foreground">What cognitive skill does the Tower of Hanoi measure?</h3>
          <p class="text-muted text-sm leading-relaxed">It measures planning ability, working memory, and the capacity to hold multiple future states in mind simultaneously. Strong performers think several moves ahead and recognize recursive sub-goals.</p>
        </div>
        <div class="flex flex-col gap-1.5">
          <h3 class="text-sm font-medium text-foreground">Is this a medical diagnostic tool?</h3>
          <p class="text-muted text-sm leading-relaxed">No. This test is designed for self-tracking, performance benchmarking, and entertainment purposes. It is not a clinical cognitive assessment.</p>
        </div>
      </div>
    </article>

    <div class="p-4 rounded-xl border border-card-border bg-subtle text-xs text-muted leading-relaxed shadow-sm">
      <strong class="text-foreground font-semibold">Self-Tracking Notice:</strong> For self-tracking and educational purposes only. Not a clinical or diagnostic evaluation.
    </div>
  </div>
</Layout>
