---
import Layout from "@/layouts/main.astro";
import Icon from "@/components/ui/Icon.astro";
import BrainScoreDashboard from "@/components/dashboard/BrainScoreDashboard";

const title = "CogniArena — Free Online Cognitive Tests & Brain Training";
const description = "Take the free reaction time test and measure your reflexes in milliseconds. 23+ cognitive assessments including IQ test, typing test, memory games. 100% anonymous, runs in your browser.";
const canonicalUrl = "https://cogniarena.com";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is a reaction time test?",
      "acceptedAnswer": { "@type": "Answer", "text": "A reaction time test measures how quickly you respond to a visual, auditory, or physical stimulus. It records the interval between stimulus presentation and your motor response in milliseconds (ms). The average human visual reaction time is approximately 250ms." }
    },
    {
      "@type": "Question",
      "name": "What is the average human reaction time?",
      "acceptedAnswer": { "@type": "Answer", "text": "The average visual reaction time for adults aged 20-35 is approximately 240-260ms. Auditory reaction times are faster, averaging around 160-180ms. Reaction time peaks in the early 20s and gradually declines with age." }
    },
    {
      "@type": "Question",
      "name": "How can I improve my reaction time?",
      "acceptedAnswer": { "@type": "Answer", "text": "You can improve reaction time through regular practice with reaction time tests, adequate sleep (7-9 hours), physical exercise, hand-eye coordination drills, and maintaining focus during tasks. Gaming and sports also help train faster responses." }
    },
    {
      "@type": "Question",
      "name": "What is CogniArena?",
      "acceptedAnswer": { "@type": "Answer", "text": "CogniArena is a free cognitive performance platform with 23+ browser-based assessments measuring reaction speed, memory, reasoning, focus, motor control, and executive function. All tests run locally with sub-millisecond precision. No sign-up required." }
    },
    {
      "@type": "Question",
      "name": "Is my data stored or sent anywhere?",
      "acceptedAnswer": { "@type": "Answer", "text": "No. Everything runs 100% in your browser. No accounts, no cookies, no data collection. Your results stay on your device using local-first IndexedDB storage." }
    },
    {
      "@type": "Question",
      "name": "What is the Brain Challenge (Gauntlet)?",
      "acceptedAnswer": { "@type": "Answer", "text": "The Gauntlet is a flagship 5-stage cognitive assessment covering reaction, memory, focus, reasoning, and precision. You receive a unified CogniArena Index (CAI) score and cognitive archetype showing your strengths across all dimensions." }
    }
  ]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://cogniarena.com" }
  ]
};

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Reaction Time Test — Free Online Reflex & Cognitive Assessment",
  "description": "Take the free reaction time test and measure your reflexes in milliseconds. 23+ cognitive assessments including IQ test, typing test, and memory games.",
  "url": "https://cogniarena.com",
  "publisher": {
    "@type": "Organization",
    "name": "CogniArena",
    "url": "https://cogniarena.com"
  }
};

const schemaJson = [faqSchema, breadcrumbSchema, webPageSchema];
---

<Layout title={title} description={description} canonicalUrl={canonicalUrl} schemaJson={schemaJson}>
