---
import Layout from "@/layouts/main.astro";
import BrainScoreDashboard from "@/components/dashboard/BrainScoreDashboard";

const title = "CogniArena — Measure Your Cognitive Performance | 13 Brain Assessments";
const description = "Discover how your brain performs under pressure. 13 cognitive assessments measuring reaction, memory, reasoning, and focus. 100% anonymous, runs in your browser.";
---

<Layout title={title} description={description}>
  <div class="flex flex-col gap-16 py-4">
    <!-- ===== HERO: The Challenge ===== -->
    <section class="relative w-full max-w-5xl mx-auto flex flex-col items-center text-center px-4 py-12 md:py-20 animate-fade-in-up hero-glow">
      <!-- Trust badge -->
      <div class="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-accent/10 border border-accent/30 text-xs font-mono uppercase tracking-wider mb-8 backdrop-blur-sm" style="color: var(--accent);">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        <span class="font-semibold" data-i18n="hero.badge">13 Cognitive Benchmarks</span>
        <span class="w-px h-3 bg-accent/40" />
        <span class="opacity-80" data-i18n="hero.anonymous">100% Anonymous</span>
      </div>

      <!-- Main headline with gradient -->
      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-black tracking-tight leading-[1.05] mb-6 hero-gradient-text">
        <span data-i18n="hero.title_1">How powerful</span><br class="hidden sm:block" /><span data-i18n="hero.title_2"> is your mind?</span>
      </h1>

      <!-- Subtitle -->
      <p class="text-secondary text-base sm:text-lg md:text-xl leading-relaxed max-w-2xl mb-12" data-i18n-html="hero.subtitle">
        13 precision assessments measuring <strong class="text-foreground font-semibold">reaction speed</strong>, <strong class="text-foreground font-semibold">working memory</strong>, <strong class="text-foreground font-semibold">fluid reasoning</strong>, and <strong class="text-foreground font-semibold">cognitive flexibility</strong>. No sign-up. Sub-millisecond accuracy. Runs entirely in your browser.
      </p>

      <!-- Stat cards row -->
      <div class="flex flex-wrap items-center justify-center gap-4 sm:gap-6 mb-12 w-full max-w-2xl">
        <div class="hero-stat-card flex flex-col items-center px-6 py-4 rounded-xl bg-card/60 border border-card-border backdrop-blur-sm">
          <span class="text-3xl sm:text-4xl font-black text-accent font-mono tabular-nums leading-none">250ms</span>
          <span class="text-[10px] font-mono text-muted uppercase tracking-widest mt-2" data-i18n="hero.stat_reaction">Avg Reaction</span>
        </div>
        <div class="hero-stat-card flex flex-col items-center px-6 py-4 rounded-xl bg-card/60 border border-card-border backdrop-blur-sm">
          <span class="text-3xl sm:text-4xl font-black text-foreground/80 font-mono tabular-nums leading-none">7&plusmn;2</span>
          <span class="text-[10px] font-mono text-muted uppercase tracking-widest mt-2" data-i18n="hero.stat_memory">Memory Span</span>
        </div>
        <div class="hero-stat-card flex flex-col items-center px-6 py-4 rounded-xl bg-card/60 border border-card-border backdrop-blur-sm">
          <span class="text-3xl sm:text-4xl font-black text-accent/80 font-mono tabular-nums leading-none">60s</span>
          <span class="text-[10px] font-mono text-muted uppercase tracking-widest mt-2" data-i18n="hero.stat_focus">Focus Challenge</span>
        </div>
      </div>

      <!-- CTA buttons -->
      <div class="flex flex-col sm:flex-row items-center gap-4 w-full sm:w-auto">
        <a href="/gauntlet" class="hero-cta-primary w-full sm:w-auto inline-flex items-center justify-center gap-2.5 rounded-xl bg-accent hover:bg-accent-hover text-white font-bold h-14 px-10 text-base transition-standard active:scale-[0.97] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 cursor-pointer animate-pulse-glow shadow-lg shadow-accent/20">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" />
          </svg>
          <span data-i18n="hero.cta_primary">Take the Brain Challenge</span>
        </a>
        <a href="#suite" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 rounded-xl bg-subtle border border-card-border text-secondary hover:text-foreground hover:border-accent/30 font-medium h-14 px-8 text-base transition-standard active:scale-[0.97] cursor-pointer">
          <span data-i18n="hero.cta_secondary">Explore 13 Assessments</span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>

      <!-- Social proof -->
      <div class="flex items-center gap-3 mt-10 text-[11px] text-muted font-mono">
        <div class="flex -space-x-1.5">
          <span class="w-5 h-5 rounded-full bg-accent/20 border border-card flex items-center justify-center text-[8px]">⚡</span>
          <span class="w-5 h-5 rounded-full bg-purple-500/20 border border-card flex items-center justify-center text-[8px]">🧠</span>
          <span class="w-5 h-5 rounded-full bg-cyan-500/20 border border-card flex items-center justify-center text-[8px]">🎯</span>
        </div>
        <span data-i18n="hero.trust">Trusted by researchers &amp; cognitive enthusiasts</span>
      </div>
    </section>

    <!-- ===== BRAIN ROT CHALLENGE ===== -->
    <section class="w-full max-w-4xl mx-auto p-6 md:p-8 rounded-xl bg-gradient-to-br from-amber-950/20 via-card to-rose-950/20 border border-accent/20 flex flex-col md:flex-row gap-8 items-center relative overflow-hidden card-interactive animate-fade-in-up stagger-1 group">
      <div class="absolute -right-16 -top-16 w-64 h-64 rounded-full bg-amber-500/5 blur-3xl pointer-events-none" />
      <div class="absolute -left-16 -bottom-16 w-64 h-64 rounded-full bg-rose-500/5 blur-3xl pointer-events-none" />
      <div class="w-full md:w-1/3 flex justify-center shrink-0">
        <div class="relative">
          <div class="w-28 h-28 rounded-2xl bg-gradient-to-br from-amber-500/20 to-rose-500/20 border border-accent/30 flex items-center justify-center text-5xl group-hover:scale-110 transition-transform duration-500">
            🧠
          </div>
          <span class="absolute -top-1 -right-1 text-xs animate-pulse">🔥</span>
        </div>
      </div>
      <div class="flex flex-col gap-4 flex-1">
        <div class="flex items-center gap-2">
          <span class="text-[10px] font-mono uppercase text-warning tracking-widest">New Challenge</span>
          <span class="text-[9px] px-1.5 py-0.5 rounded bg-[var(--error-bg)] text-error font-mono uppercase tracking-wider">Brain Rot Edition</span>
        </div>
        <h2 class="text-xl font-bold text-foreground tracking-tight">Can You Survive the Brain Rot Challenge?</h2>
        <p class="text-secondary text-sm leading-relaxed">
          A <strong class="text-accent">5-stage attention gauntlet</strong> — selective focus, impulse control, task switching, sustained vigilance, and working memory under distraction. Most people score below 60 on their first attempt.
        </p>
        <div class="flex items-center gap-6 text-xs text-muted font-mono">
          <span>🎯 5 stages</span>
          <span>⏱️ ~4 minutes</span>
          <span>📊 Composite score + percentile</span>
        </div>
        <div class="flex gap-3 mt-1">
          <a href="/tests/focus-challenge">
            <button class="px-5 h-9 rounded-lg bg-accent hover:bg-accent-hover text-white font-semibold text-xs transition-standard active:scale-95 cursor-pointer">
              Accept Challenge
            </button>
          </a>
          <a href="/tests/focus-challenge#learn">
            <button class="px-5 h-9 rounded-lg bg-subtle border border-card-border text-secondary hover:text-foreground text-xs transition-standard active:scale-95 cursor-pointer">
              Learn More
            </button>
          </a>
        </div>
      </div>
    </section>

    <!-- ===== STATS BAR ===== -->
    <section class="w-full max-w-2xl mx-auto animate-fade-in-up stagger-2">
      <div class="flex items-center justify-center gap-6 sm:gap-10 text-center">
        <div>
          <span class="block text-xl font-bold text-foreground tabular-nums">13</span>
          <span class="text-[10px] font-mono text-muted uppercase tracking-widest">Assessments</span>
        </div>
        <span class="w-px h-8 bg-card-border" />
        <div>
          <span class="block text-xl font-bold text-foreground tabular-nums">100%</span>
          <span class="text-[10px] font-mono text-muted uppercase tracking-widest">Anonymous</span>
        </div>
        <span class="w-px h-8 bg-card-border" />
        <div>
          <span class="block text-xl font-bold text-foreground tabular-nums">&lt;1ms</span>
          <span class="text-[10px] font-mono text-muted uppercase tracking-widest">Timer Precision</span>
        </div>
      </div>
    </section>

    <!-- ===== BRAIN SCORE DASHBOARD ===== -->
    <section class="w-full max-w-4xl mx-auto flex flex-col items-center gap-4 animate-fade-in-up stagger-5">
      <BrainScoreDashboard client:visible />
    </section>

    <!-- ===== ASSESSMENT SUITE ===== -->
    <section id="suite" class="flex flex-col gap-8">
    <!-- Category 1: Reaction & Reflexes -->
    <section class="flex flex-col gap-8">
      <div class="flex flex-col gap-2">
        <h2 class="text-2xl font-bold text-foreground tracking-tight">⚡ Reaction & Reflexes</h2>
        <p class="text-muted text-xs font-mono uppercase tracking-wider">Raw speed & sensory pathways</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Visual Reaction -->
        <div class="p-6 rounded-xl bg-card border border-card-border card-interactive flex flex-col justify-between gap-6 glow-yellow">
          <div class="flex flex-col gap-3">
            <span class="text-xs font-mono text-muted">RT-001</span>
            <h3 class="text-lg font-bold text-foreground">Visual Reaction</h3>
            <p class="text-muted text-sm leading-relaxed">
              Test your physical reflexes against visual triggers. Calibrate input delay, monitor refresh rate, and view population distributions.
            </p>
          </div>
          <a href="/tests/reaction-time" class="w-full inline-flex items-center justify-between rounded-md text-sm font-medium transition-standard h-10 px-4 py-2 cursor-pointer active:scale-[0.98] bg-[var(--btn-secondary-bg)] border border-[var(--btn-secondary-border)] text-[var(--btn-secondary-text)] hover:bg-[var(--btn-secondary-hover-bg)] group">
              <span>Start Visual Test</span>
              <span>⚡</span>
          </a>
        </div>

        <!-- Auditory Reflex -->
        <div class="p-6 rounded-xl bg-card border border-card-border card-interactive flex flex-col justify-between gap-6 glow-yellow">
          <div class="flex flex-col gap-3">
            <span class="text-xs font-mono text-muted">RT-002</span>
            <h3 class="text-lg font-bold text-foreground">Auditory Reflex</h3>
            <p class="text-muted text-sm leading-relaxed">
              Measure your auditory response speeds to low-latency synthesized sound waves. Contrast hearing triggers against visual pathways.
            </p>
          </div>
          <a href="/tests/sound-reaction" class="w-full inline-flex items-center justify-between rounded-md text-sm font-medium transition-standard h-10 px-4 py-2 cursor-pointer active:scale-[0.98] bg-[var(--btn-secondary-bg)] border border-[var(--btn-secondary-border)] text-[var(--btn-secondary-text)] hover:bg-[var(--btn-secondary-hover-bg)] group">
              <span>Start Sound Test</span>
              <span>🔊</span>
          </a>
        </div>

        <!-- F1 Start Lights -->
        <div class="p-6 rounded-xl bg-card border border-card-border card-interactive flex flex-col justify-between gap-6 glow-yellow">
          <div class="flex flex-col gap-3">
            <span class="text-xs font-mono text-muted">RT-003</span>
            <h3 class="text-lg font-bold text-foreground">F1 Start Lights</h3>
            <p class="text-muted text-sm leading-relaxed">
              Simulate a Grand Prix start gantry. Suppress anticipatory impulse and release motor actions at the exact millisecond lights extinguish.
            </p>
          </div>
          <a href="/tests/f1-lights" class="w-full inline-flex items-center justify-between rounded-md text-sm font-medium transition-standard h-10 px-4 py-2 cursor-pointer active:scale-[0.98] bg-[var(--btn-secondary-bg)] border border-[var(--btn-secondary-border)] text-[var(--btn-secondary-text)] hover:bg-[var(--btn-secondary-hover-bg)] group">
              <span>Launch Telemetry</span>
              <span>🏎️</span>
          </a>
        </div>

        <!-- Choice Reaction -->
        <div class="p-6 rounded-xl bg-card border border-card-border card-interactive flex flex-col justify-between gap-6 glow-yellow">
          <div class="flex flex-col gap-3">
            <span class="text-xs font-mono text-muted">RT-004</span>
            <h3 class="text-lg font-bold text-foreground">Choice Reaction</h3>
            <p class="text-muted text-sm leading-relaxed">
              Map color changes to keys R, G, B, Y. Manage accuracy-speed trade-offs under cognitive decision load with built-in mismatch penalties.
            </p>
          </div>
          <a href="/tests/choice-reaction" class="w-full inline-flex items-center justify-between rounded-md text-sm font-medium transition-standard h-10 px-4 py-2 cursor-pointer active:scale-[0.98] bg-[var(--btn-secondary-bg)] border border-[var(--btn-secondary-border)] text-[var(--btn-secondary-text)] hover:bg-[var(--btn-secondary-hover-bg)] group">
              <span>Start Choice Grid</span>
              <span>🔢</span>
          </a>
        </div>

        <!-- Color Go/No-Go -->
        <div class="p-6 rounded-xl bg-card border border-card-border card-interactive flex flex-col justify-between gap-6 glow-yellow">
          <div class="flex flex-col gap-3">
            <span class="text-xs font-mono text-muted">RT-005</span>
            <h3 class="text-lg font-bold text-foreground">Color Go/No-Go</h3>
            <p class="text-muted text-sm leading-relaxed">
              Inhibitory motor control. Click only when green flashes; suppress actions for distractors (Red, Blue, Purple).
            </p>
          </div>
          <a href="/tests/go-no-go" class="w-full inline-flex items-center justify-between rounded-md text-sm font-medium transition-standard h-10 px-4 py-2 cursor-pointer active:scale-[0.98] bg-[var(--btn-secondary-bg)] border border-[var(--btn-secondary-border)] text-[var(--btn-secondary-text)] hover:bg-[var(--btn-secondary-hover-bg)] group">
              <span>Start Go/No-Go Test</span>
              <span>🛡️</span>
          </a>
        </div>
      </div>
    </section>

    <!-- Category 2: Memory -->
    <section class="flex flex-col gap-8 pt-8">
      <div class="flex flex-col gap-2">
        <h2 class="text-2xl font-bold text-foreground tracking-tight">🧠 Memory</h2>
        <p class="text-muted text-xs font-mono uppercase tracking-wider">Active working capacity & retention</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Sequence Memory -->
        <div class="p-6 rounded-xl bg-card border border-card-border card-interactive flex flex-col justify-between gap-6 glow-purple">
          <div class="flex flex-col gap-3">
            <span class="text-xs font-mono text-muted">MEM-001</span>
            <h3 class="text-lg font-bold text-foreground">Sequence Memory</h3>
            <p class="text-muted text-sm leading-relaxed">
              Remember an expanding grid flash sequence, evaluating Miller's Law bounds.
            </p>
          </div>
          <a href="/tests/sequence-memory" class="w-full inline-flex items-center justify-between rounded-md text-sm font-medium transition-standard h-10 px-4 py-2 cursor-pointer active:scale-[0.98] bg-[var(--btn-secondary-bg)] border border-[var(--btn-secondary-border)] text-[var(--btn-secondary-text)] hover:bg-[var(--btn-secondary-hover-bg)] group">
              <span>Play Sequence</span>
              <span>🗂️</span>
          </a>
        </div>

        <!-- Number Memory -->
        <div class="p-6 rounded-xl bg-card border border-card-border card-interactive flex flex-col justify-between gap-6 glow-purple">
          <div class="flex flex-col gap-3">
            <span class="text-xs font-mono text-muted">MEM-002</span>
            <h3 class="text-lg font-bold text-foreground">Number Memory</h3>
            <p class="text-muted text-sm leading-relaxed">
              Recall numeric strings of growing length to evaluate active visual digit spans.
            </p>
          </div>
          <a href="/tests/number-memory" class="w-full inline-flex items-center justify-between rounded-md text-sm font-medium transition-standard h-10 px-4 py-2 cursor-pointer active:scale-[0.98] bg-[var(--btn-secondary-bg)] border border-[var(--btn-secondary-border)] text-[var(--btn-secondary-text)] hover:bg-[var(--btn-secondary-hover-bg)] group">
              <span>Play Number Test</span>
              <span>🔢</span>
          </a>
        </div>

        <!-- Visual Pattern -->
        <div class="p-6 rounded-xl bg-card border border-card-border card-interactive flex flex-col justify-between gap-6 glow-purple">
          <div class="flex flex-col gap-3">
            <span class="text-xs font-mono text-muted">MEM-003</span>
            <h3 class="text-lg font-bold text-foreground">Visual Pattern</h3>
            <p class="text-muted text-sm leading-relaxed">
              Memorize illuminated pattern positions inside dynamic scale matrices.
            </p>
          </div>
          <a href="/tests/visual-pattern" class="w-full inline-flex items-center justify-between rounded-md text-sm font-medium transition-standard h-10 px-4 py-2 cursor-pointer active:scale-[0.98] bg-[var(--btn-secondary-bg)] border border-[var(--btn-secondary-border)] text-[var(--btn-secondary-text)] hover:bg-[var(--btn-secondary-hover-bg)] group">
              <span>Play Pattern Grid</span>
              <span>🧩</span>
          </a>
        </div>

        <!-- Dual N-Back -->
        <div class="p-6 rounded-xl bg-card border border-card-border card-interactive flex flex-col justify-between gap-6 glow-purple">
          <div class="flex flex-col gap-3">
            <span class="text-xs font-mono text-muted">MEM-004</span>
            <h3 class="text-lg font-bold text-foreground">Dual N-Back</h3>
            <p class="text-muted text-sm leading-relaxed">
              Track independent auditory tone and visual positions shown N steps back.
            </p>
          </div>
          <a href="/tests/dual-n-back" class="w-full inline-flex items-center justify-between rounded-md text-sm font-medium transition-standard h-10 px-4 py-2 cursor-pointer active:scale-[0.98] bg-[var(--btn-secondary-bg)] border border-[var(--btn-secondary-border)] text-[var(--btn-secondary-text)] hover:bg-[var(--btn-secondary-hover-bg)] group">
              <span>Play Dual N-Back</span>
              <span>🧠</span>
          </a>
        </div>

        <!-- Verbal Memory -->
        <div class="p-6 rounded-xl bg-card border border-card-border card-interactive flex flex-col justify-between gap-6 glow-purple">
          <div class="flex flex-col gap-3">
            <span class="text-xs font-mono text-muted">MEM-005</span>
            <h3 class="text-lg font-bold text-foreground">Verbal Memory</h3>
            <p class="text-muted text-sm leading-relaxed">
              Memorize growing word lists and recall them from distractor sets.
            </p>
          </div>
          <a href="/tests/verbal-memory" class="w-full inline-flex items-center justify-between rounded-md text-sm font-medium transition-standard h-10 px-4 py-2 cursor-pointer active:scale-[0.98] bg-[var(--btn-secondary-bg)] border border-[var(--btn-secondary-border)] text-[var(--btn-secondary-text)] hover:bg-[var(--btn-secondary-hover-bg)] group">
              <span>Play Verbal Memory</span>
              <span>📝</span>
          </a>
        </div>
      </div>
    </section>

    <!-- Category 3: Reasoning -->
    <section class="flex flex-col gap-8 pt-8">
      <div class="flex flex-col gap-2">
        <h2 class="text-2xl font-bold text-foreground tracking-tight">🧩 Reasoning</h2>
        <p class="text-muted text-xs font-mono uppercase tracking-wider">Fluid logic & non-verbal matrices</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Pattern Recognition -->
        <div class="p-6 rounded-xl bg-card border border-card-border card-interactive flex flex-col justify-between gap-6 glow-green">
          <div class="flex flex-col gap-3">
            <span class="text-xs font-mono text-muted">REAS-001</span>
            <h3 class="text-lg font-bold text-foreground">Pattern Recognition</h3>
            <p class="text-muted text-sm leading-relaxed">
              Identify the missing colored item completing a linear sequence block.
            </p>
          </div>
          <a href="/tests/pattern-reasoning?format=pattern" class="w-full inline-flex items-center justify-between rounded-md text-sm font-medium transition-standard h-10 px-4 py-2 cursor-pointer active:scale-[0.98] bg-[var(--btn-secondary-bg)] border border-[var(--btn-secondary-border)] text-[var(--btn-secondary-text)] hover:bg-[var(--btn-secondary-hover-bg)] group">
              <span>Play Format</span>
              <span>🧩</span>
          </a>
        </div>

        <!-- Matrix Reasoning -->
        <div class="p-6 rounded-xl bg-card border border-card-border card-interactive flex flex-col justify-between gap-6 glow-green">
          <div class="flex flex-col gap-3">
            <span class="text-xs font-mono text-muted">REAS-002</span>
            <h3 class="text-lg font-bold text-foreground">Matrix Reasoning</h3>
            <p class="text-muted text-sm leading-relaxed">
              Complete the 2x2 grid pattern matching visual nested structures.
            </p>
          </div>
          <a href="/tests/pattern-reasoning?format=matrix" class="w-full inline-flex items-center justify-between rounded-md text-sm font-medium transition-standard h-10 px-4 py-2 cursor-pointer active:scale-[0.98] bg-[var(--btn-secondary-bg)] border border-[var(--btn-secondary-border)] text-[var(--btn-secondary-text)] hover:bg-[var(--btn-secondary-hover-bg)] group">
              <span>Play Matrix</span>
              <span>🖼️</span>
          </a>
        </div>

        <!-- Sequence Logic -->
        <div class="p-6 rounded-xl bg-card border border-card-border card-interactive flex flex-col justify-between gap-6 glow-green">
          <div class="flex flex-col gap-3">
            <span class="text-xs font-mono text-muted">REAS-003</span>
            <h3 class="text-lg font-bold text-foreground">Sequence Logic</h3>
            <p class="text-muted text-sm leading-relaxed">
              Solve numerical growth curves and rotational arrow progressions.
            </p>
          </div>
          <a href="/tests/pattern-reasoning?format=sequence" class="w-full inline-flex items-center justify-between rounded-md text-sm font-medium transition-standard h-10 px-4 py-2 cursor-pointer active:scale-[0.98] bg-[var(--btn-secondary-bg)] border border-[var(--btn-secondary-border)] text-[var(--btn-secondary-text)] hover:bg-[var(--btn-secondary-hover-bg)] group">
              <span>Play Sequence</span>
              <span>🔢</span>
          </a>
        </div>

        <!-- Shape Analogies -->
        <div class="p-6 rounded-xl bg-card border border-card-border card-interactive flex flex-col justify-between gap-6 glow-green">
          <div class="flex flex-col gap-3">
            <span class="text-xs font-mono text-muted">REAS-004</span>
            <h3 class="text-lg font-bold text-foreground">Shape Analogies</h3>
            <p class="text-muted text-sm leading-relaxed">
              Deduce the morph transformation rule and apply it to target shapes.
            </p>
          </div>
          <a href="/tests/pattern-reasoning?format=analogy" class="w-full inline-flex items-center justify-between rounded-md text-sm font-medium transition-standard h-10 px-4 py-2 cursor-pointer active:scale-[0.98] bg-[var(--btn-secondary-bg)] border border-[var(--btn-secondary-border)] text-[var(--btn-secondary-text)] hover:bg-[var(--btn-secondary-hover-bg)] group">
              <span>Play Analogy</span>
              <span>📐</span>
          </a>
        </div>

        <!-- Spatial Orientation -->
