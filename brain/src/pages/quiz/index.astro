---
import Layout from "@/layouts/main.astro"

const title =
  "Interactive Quizzes — Cognitive Reasoning, Cognitive Style & Brain Health | CogniArena"
const description =
  "Take free interactive quizzes including a research-backed cognitive reasoning quiz, cognitive style assessment, and brain health check. Instant results, no sign-up required."
const canonicalUrl = "https://cogniarena.com/quiz"

const schemaJson = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "CogniArena Quizzes",
  description:
    "Free interactive cognitive quizzes including cognitive reasoning assessment, cognitive style quiz, and brain health screening.",
  provider: {
    "@type": "Organization",
    name: "CogniArena",
    url: "https://cogniarena.com",
  },
  about: { "@type": "Thing", name: "Cognitive Assessment" },
  hasPart: [
    {
      "@type": "Quiz",
      name: "Free Cognitive Reasoning Quiz",
      url: "https://cogniarena.com/quiz/iq-test",
    },
    {
      "@type": "Quiz",
      name: "Cognitive Style Quiz",
      url: "https://cogniarena.com/quiz/cognitive-style",
    },
  ],
}
---

<Layout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  schemaJson={schemaJson}
>
  <div class="mx-auto flex w-full max-w-4xl flex-col gap-12">
    <header class="flex flex-col gap-4">
      <div
        class="flex items-center gap-2 font-mono text-xs tracking-widest text-accent uppercase"
      >
        <span data-i18n="quiz.badge1">Quizzes</span>
        <span>&middot;</span>
        <span data-i18n="quiz.badge2">Hub</span>
      </div>
      <h1
        class="animate-fade-in text-3xl font-extrabold tracking-tight text-foreground md:text-4xl"
        data-i18n="quiz.title"
      >
        Interactive Cognitive Quizzes
      </h1>
      <p
        class="max-w-3xl text-sm leading-relaxed text-muted md:text-base"
        data-i18n="quiz.subtitle"
      >
        Free, research-backed quizzes that give you insight into your cognitive
        abilities and thinking style. All quizzes run entirely in your browser —
        no sign-up, no data collection.
      </p>
    </header>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
      <a
        href="/quiz/iq-test"
        class="transition-standard group flex flex-col gap-4 rounded-xl border border-card-border bg-subtle p-6 hover:border-accent/30 hover:bg-accent/5"
      >
        <div class="flex items-center gap-3">
          <span class="text-2xl">🧠</span>
          <div class="flex flex-col">
            <span
              class="text-base font-bold text-foreground transition-colors group-hover:text-accent"
              >Free Cognitive Reasoning Quiz</span
            >
            <span class="text-xs text-muted">~15 minutes</span>
          </div>
        </div>
        <p class="text-sm leading-relaxed text-muted">
          20 questions across numerical, verbal, spatial, and logical reasoning
          domains. Based on the ICAR cognitive ability framework. Instant
          browser-scored results with domain breakdown and percentile ranking.
        </p>
        <div
          class="mt-auto flex items-center gap-2 text-xs font-semibold text-accent"
        >
          <span>Start Test</span>
          <span class="transition-transform group-hover:translate-x-0.5"
            >&rarr;</span
          >
        </div>
      </a>

      <a
        href="/quiz/cognitive-style"
        class="transition-standard group flex flex-col gap-4 rounded-xl border border-card-border bg-subtle p-6 hover:border-accent/30 hover:bg-accent/5"
      >
        <div class="flex items-center gap-3">
          <span class="text-2xl">💭</span>
          <div class="flex flex-col">
            <span
              class="text-base font-bold text-foreground transition-colors group-hover:text-accent"
              >Cognitive Style Quiz</span
            >
            <span class="text-xs text-muted">~3 minutes</span>
          </div>
        </div>
        <p class="text-sm leading-relaxed text-muted">
          Discover how you think. This quick assessment identifies whether you
          lean toward visual, verbal, analytical, or holistic thinking — with
          personalized insights on how to leverage your cognitive style.
        </p>
        <div
          class="mt-auto flex items-center gap-2 text-xs font-semibold text-accent"
        >
          <span>Take Quiz</span>
          <span class="transition-transform group-hover:translate-x-0.5"
            >&rarr;</span
          >
        </div>
      </a>
    </div>

    <section class="flex flex-col gap-4 border-t border-card-border pt-8">
      <h2
        class="text-lg font-bold tracking-tight text-foreground"
        data-i18n="quiz.about_title"
      >
        About These Quizzes
      </h2>
      <div
        class="flex max-w-3xl flex-col gap-3 text-sm leading-relaxed text-muted"
      >
        <p>
          Our IQ test uses question formats inspired by the International
          Cognitive Ability Resource (ICAR), an open-source framework developed
          at Northwestern University. ICAR items show strong correlations with
          established measures like Raven's Progressive Matrices and WAIS
          subtests.
        </p>
        <p>
          All scoring happens entirely in your browser. Your answers never leave
          your device — no accounts, no data collection, no paywalls. Results
          are displayed instantly on screen.
        </p>
        <p>
          <strong class="text-foreground">Disclaimer:</strong> These quizzes are for
          entertainment and self-assessment purposes only. They are not clinical or
          diagnostic instruments and do not replace a professionally administered
          cognitive evaluation.
        </p>
      </div>
    </section>
  </div>
</Layout>
