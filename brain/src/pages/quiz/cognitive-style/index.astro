---
import Layout from "@/layouts/main.astro"
import CognitiveStyleQuiz from "@/components/quiz/CognitiveStyleQuiz"

const title =
  "Cognitive Style Quiz — Visual, Verbal, Analytical or Holistic | CogniArena"
const description =
  "Discover how you think with our free Cognitive Style Quiz. 8 quick questions reveal whether you are a visual, verbal, analytical, or holistic thinker. Instant results."
const canonicalUrl = "https://cogniarena.com/quiz/cognitive-style"

const schemaJson = {
  "@context": "https://schema.org",
  "@type": "Quiz",
  name: "Cognitive Style Quiz",
  description:
    "An 8-question self-assessment that identifies your dominant cognitive processing style: visual, verbal, analytical, or holistic.",
  about: { "@type": "Thing", name: "Cognitive Style" },
  educationalAlignment: {
    "@type": "AlignmentObject",
    alignmentType: "educationalRequirement",
    educationalFramework: "Cognitive Science",
  },
}
---

<Layout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  schemaJson={schemaJson}
>
  <div class="mx-auto flex w-full max-w-3xl flex-col gap-6">
    <header class="flex flex-col gap-3">
      <div
        class="flex items-center gap-2 font-mono text-xs tracking-widest text-accent uppercase"
      >
        <span>Quizzes</span>
        <span>&middot;</span>
        <span>Cognitive Style</span>
      </div>
      <h1
        class="text-3xl font-extrabold tracking-tight text-foreground md:text-4xl"
      >
        Cognitive Style Quiz
      </h1>
      <p class="max-w-2xl text-sm leading-relaxed text-muted md:text-base">
        8 quick questions to discover how you naturally process information.
      </p>
    </header>
    <section class="w-full"><CognitiveStyleQuiz client:visible /></section>
    <div
      class="rounded-xl border border-card-border bg-subtle p-4 text-xs leading-relaxed text-muted shadow-sm"
    >
      <strong class="font-semibold text-foreground"
        >Self-Tracking Notice:</strong
      > This quiz is for self-educational and entertainment purposes only. Not a clinical
      or diagnostic evaluation.
    </div>
  </div>
</Layout>
